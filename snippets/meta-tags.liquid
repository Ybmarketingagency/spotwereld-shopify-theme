{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

{%- comment -%} Spotwereld SEO: betere titles met keywords per page type {%- endcomment -%}
{%- liquid
  assign sw_brand = 'Spotwereld'
  assign sw_tagline = 'Premium LED Verlichting'
  if request.page_type == 'index'
    assign sw_title = 'LED Inbouwspots, Opbouwspots & Hanglampen | ' | append: sw_brand
    assign sw_desc = 'Premium LED verlichting voor elk interieur. CCT switch dimbaar, IP65, 25.000 uur levensduur. Voor 22:00 besteld, morgen in huis. 4.9/5 klantbeoordeling.'
  elsif request.page_type == 'product'
    assign sw_title = product.title | append: ' kopen | ' | append: sw_brand
    if product.description != blank
      assign sw_desc = product.description | strip_html | truncate: 155
    else
      assign sw_desc = product.title | append: ' - Premium LED kwaliteit, snelle levering en 2 jaar garantie bij Spotwereld.'
    endif
  elsif request.page_type == 'collection'
    assign sw_title = collection.title | append: ' kopen - LED ' | append: collection.title | append: ' | ' | append: sw_brand
    if collection.description != blank
      assign sw_desc = collection.description | strip_html | truncate: 155
    else
      assign sw_desc = 'Bekijk onze ' | append: collection.title | append: ' collectie. Premium LED kwaliteit met 2 jaar garantie. Voor 22:00 besteld, morgen in huis.'
    endif
  elsif request.page_type == 'article'
    assign sw_title = article.title | append: ' | ' | append: sw_brand | append: ' Blog'
    assign sw_desc = article.excerpt_or_content | strip_html | truncate: 155
  elsif request.page_type == 'page'
    assign sw_title = page.title | append: ' | ' | append: sw_brand
    if page.content != blank
      assign sw_desc = page.content | strip_html | truncate: 155
    else
      assign sw_desc = sw_tagline | append: ' bij ' | append: sw_brand
    endif
  else
    assign sw_title = page_title | append: ' | ' | append: sw_brand
    assign sw_desc = page_description | default: shop.description | default: sw_tagline
  endif
-%}

<title>
  {{ sw_title }}
  {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
  {%- if current_page != 1 %} &ndash; Pagina {{ current_page }}{% endif -%}
</title>

<meta name="description" content="{{ sw_desc | strip_html | escape }}">

<link rel="canonical" href="{{ canonical_url }}">

{%- comment -%} Spotwereld: extra SEO meta tags {%- endcomment -%}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="author" content="Spotwereld">
<meta name="format-detection" content="telephone=no">

{%- comment -%} Favicon - hardcoded gele lamp op blauwe achtergrond, overschrijft Shopify settings favicon {%- endcomment -%}
<link rel="icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/2ROeTRS.png">
<link rel="apple-touch-icon" sizes="180x180" href="https://i.imgur.com/2ROeTRS.png">
<link rel="shortcut icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<script>
(function(){
  function removeOldFavicons(){
    document.querySelectorAll('link[rel*="icon"]').forEach(function(el){
      if(el.href.indexOf('imgur.com/2ROeTRS') === -1){
        el.parentNode.removeChild(el);
      }
    });
    // Force browser favicon refresh
    var fresh = document.createElement('link');
    fresh.rel = 'icon';
    fresh.type = 'image/png';
    fresh.href = 'https://i.imgur.com/2ROeTRS.png?v=' + Date.now();
    document.head.appendChild(fresh);
  }
  removeOldFavicons();
  document.addEventListener('DOMContentLoaded', removeOldFavicons);
})();
</script>

{%- comment -%} JSON-LD Organization (alle pagina's) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Spotwereld",
  "alternateName": "Spotwereld Webshop",
  "url": "{{ request.origin }}",
  "logo": "https://i.imgur.com/2ROeTRS.png",
  "description": "{{ sw_tagline }} voor elk interieur. Premium LED inbouwspots, opbouwspots, hanglampen en meer.",
  "sameAs": [
    "https://www.facebook.com/spotwereld",
    "https://www.instagram.com/spotwereld"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "availableLanguage": ["Dutch", "Nederlands"]
  }
}
</script>

{%- comment -%} JSON-LD WebSite met SearchAction {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Spotwereld",
  "url": "{{ request.origin }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ request.origin }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- comment -%} JSON-LD BreadcrumbList op collection en product pages {%- endcomment -%}
{%- if request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"}
  ]
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {%- if collection -%}
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"},
    {"@type": "ListItem", "position": 3, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- else -%}
    {"@type": "ListItem", "position": 2, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} Open Graph image fallback (1200x630 minimum voor social sharing) {%- endcomment -%}
