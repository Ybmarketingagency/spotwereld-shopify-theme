      var t = e.target;
      if (!t) return;
      var nee = t.closest && t.closest('.sw-fake-nee');
      if (!nee) return;
      var inp = nee.querySelector('input');
      if (!inp || t !== inp) return;
      e.stopPropagation();
      e.stopImmediatePropagation();
      if (evtName === 'click'){
        setTimeout(function(){
          var p = new URLSearchParams(location.search);
