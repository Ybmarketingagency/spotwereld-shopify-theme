{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

{%- comment -%} Spotwereld SEO: betere titles met keywords per page type {%- endcomment -%}
{%- liquid
  assign sw_brand = 'Spotwereld'
  assign sw_tagline = 'Premium LED Verlichting'
  if request.page_type == 'index'
    assign sw_title = 'LED Inbouwspots, Opbouwspots & Hanglampen | ' | append: sw_brand
    assign sw_desc = 'Premium LED verlichting voor elk interieur. CCT switch dimbaar, IP65, 25.000 uur levensduur. Vandaag voor 22:00 besteld, morgen verzonden. 4.9/5 klantbeoordeling.'
  elsif request.page_type == 'product'
    assign sw_title = product.title | append: ' kopen | ' | append: sw_brand
    if product.description != blank
      assign sw_desc = product.description | strip_html | truncate: 155
    else
      assign sw_desc = product.title | append: ' - Premium LED kwaliteit, snelle levering en 2 jaar garantie bij Spotwereld.'
    endif
  elsif request.page_type == 'collection'
    assign sw_title = collection.title | append: ' kopen - LED ' | append: collection.title | append: ' | ' | append: sw_brand
    if collection.description != blank
      assign sw_desc = collection.description | strip_html | truncate: 155
    else
      assign sw_desc = 'Bekijk onze ' | append: collection.title | append: ' collectie. Premium LED kwaliteit met 2 jaar garantie. Vandaag voor 22:00 besteld, morgen verzonden.'
    endif
  elsif request.page_type == 'article'
    assign sw_title = article.title | append: ' | ' | append: sw_brand | append: ' Blog'
    assign sw_desc = article.excerpt_or_content | strip_html | truncate: 155
  elsif request.page_type == 'page'
    assign sw_title = page.title | append: ' | ' | append: sw_brand
    if page.content != blank
      assign sw_desc = page.content | strip_html | truncate: 155
    else
      assign sw_desc = sw_tagline | append: ' bij ' | append: sw_brand
    endif
  else
    assign sw_title = page_title | append: ' | ' | append: sw_brand
    assign sw_desc = page_description | default: shop.description | default: sw_tagline
  endif
-%}

<title>
  {{ sw_title }}
  {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
  {%- if current_page != 1 %} &ndash; Pagina {{ current_page }}{% endif -%}
</title>

<meta name="description" content="{{ sw_desc | strip_html | escape }}">

<link rel="canonical" href="{{ canonical_url }}">

{%- comment -%} Spotwereld: extra SEO meta tags {%- endcomment -%}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="author" content="Spotwereld">
<meta name="format-detection" content="telephone=no">

{%- comment -%} Favicon - hardcoded gele lamp op blauwe achtergrond, overschrijft Shopify settings favicon {%- endcomment -%}
<link rel="icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/2ROeTRS.png">
<link rel="apple-touch-icon" sizes="180x180" href="https://i.imgur.com/2ROeTRS.png">
<link rel="shortcut icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<script>
(function(){
  function removeOldFavicons(){
    document.querySelectorAll('link[rel*="icon"]').forEach(function(el){
      if(el.href.indexOf('imgur.com/2ROeTRS') === -1){
        el.parentNode.removeChild(el);
      }
    });
    // Force browser favicon refresh
    var fresh = document.createElement('link');
    fresh.rel = 'icon';
    fresh.type = 'image/png';
    fresh.href = 'https://i.imgur.com/2ROeTRS.png?v=' + Date.now();
    document.head.appendChild(fresh);
  }
  removeOldFavicons();
  document.addEventListener('DOMContentLoaded', removeOldFavicons);
})();
</script>

{%- comment -%} JSON-LD Organization (alle pagina's) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Spotwereld",
  "alternateName": "Spotwereld Webshop",
  "url": "{{ request.origin }}",
  "logo": "https://i.imgur.com/2ROeTRS.png",
  "description": "{{ sw_tagline }} voor elk interieur. Premium LED inbouwspots, opbouwspots, hanglampen en meer.",
  "sameAs": [
    "https://www.facebook.com/spotwereld",
    "https://www.instagram.com/spotwereld"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "availableLanguage": ["Dutch", "Nederlands"]
  }
}
</script>

{%- comment -%} JSON-LD WebSite met SearchAction {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Spotwereld",
  "url": "{{ request.origin }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ request.origin }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- comment -%} JSON-LD BreadcrumbList op collection en product pages {%- endcomment -%}
{%- if request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"}
  ]
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {%- if collection -%}
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"},
    {"@type": "ListItem", "position": 3, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- else -%}
    {"@type": "ListItem", "position": 2, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} Open Graph image fallback (1200x630 minimum voor social sharing) {%- endcomment -%}
{%- unless page_image -%}
<meta property="og:image" content="https://i.imgur.com/2ROeTRS.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{%- endunless -%}

{%- comment -%} Override Open Graph title/description met onze SEO versie {%- endcomment -%}
<meta property="og:title" content="{{ sw_title | escape }}" data-sw-override>
<meta property="og:description" content="{{ sw_desc | strip_html | escape }}" data-sw-override>
<meta name="twitter:title" content="{{ sw_title | escape }}" data-sw-override>
<meta name="twitter:description" content="{{ sw_desc | strip_html | escape }}" data-sw-override>

{%- comment -%} Card image override mechanisme (uitgeschakeld; images serverside correct) {%- endcomment -%}
<style>
/* Unify card titles: collection page (product-card H3/text-block) matches homepage (sw-pp-card .sw-pp-name) */
.sw-pp-name,
product-card h3,
product-card h4,
product-card .h4,
product-card .h3,
product-card [class*="product_title"],
product-card [class*="product-card__title"],
product-card .product-card__title,
product-card .product-card__title a,
product-card product-title,
product-card product-title a,
.product-card h3,
.product-card h4,
.product-card .h4{
  font-weight:600 !important;
  color:#1e293b !important;
  font-size:.85rem !important;
  line-height:1.35 !important;
  font-family:inherit !important;
  text-decoration:none !important;
  letter-spacing:normal !important;
}
/* Ook de inline tekst-block container die Horizon gebruikt */
product-card [class*="product_title"] *,
product-card .text-block[class*="product_title"]{
  color:#1e293b !important;
  font-weight:600 !important;
}
/* Vorm filter active chip & lichtkleur active */
.sw-active-chip{display:inline-flex;align-items:center;gap:.4rem;background:#f1f5f9;border:1px solid #cbd5e1;border-radius:999px;padding:.35rem .75rem;font-size:.78rem;color:#1e293b;margin:.25rem .35rem .25rem 0;font-weight:500}
.sw-active-chip button{background:none;border:0;cursor:pointer;color:#64748b;font-size:1rem;line-height:1;padding:0 0 0 .15rem;display:inline-flex;align-items:center}
.sw-active-chip button:hover{color:#dc2626}
.sw-lk-active,.sw-vorm-active{background:rgba(15,111,227,.08)!important;border-radius:6px}
.sw-lk-active .checkbox__label-text,.sw-vorm-active .checkbox__label-text{color:#0F6FE3!important;font-weight:700!important}
.sw-lk-active .icon-checkmark,.sw-vorm-active .icon-checkmark{background:#0F6FE3!important;border-color:#0F6FE3!important;color:#fff!important}
.sw-lk-active input[type="checkbox"],.sw-vorm-active input[type="checkbox"]{accent-color:#0F6FE3}
/* Force checked appearance regardless of native render */
.sw-lk-active .checkbox__label::before,.sw-vorm-active .checkbox__label::before{background:#0F6FE3!important;border-color:#0F6FE3!important}
/* Custom + Shopify native facet chevron */
.facets__item .facets__summary,details.facets__item summary{display:flex !important;justify-content:space-between;align-items:center;cursor:pointer;list-style:none}
.facets__item .facets__summary::-webkit-details-marker,details.facets__item summary::-webkit-details-marker{display:none}
.facets__item .facets__icon,details.facets__item summary .facets__icon{display:inline-flex;align-items:center}
.facets__item .facets__icon svg,details.facets__item summary .facets__icon svg{transition:transform .2s;color:#061f40;width:14px;height:14px}
details.facets__item[open] .facets__icon svg{transform:rotate(180deg)}
/* Inject chevron if not present (CSS fallback) */
.facets__item .facets__icon:empty::after{content:'';display:inline-block;width:8px;height:8px;border-right:2px solid #061f40;border-bottom:2px solid #061f40;transform:rotate(45deg);transition:transform .2s;margin-bottom:3px}
details.facets__item[open] .facets__icon:empty::after{transform:rotate(-135deg);margin-bottom:-3px}
/* Force checkbox visibility — gebruik ALLEEN icon-checkmark (custom), verberg de native input visueel */
.facets__item .checkbox{display:flex !important;align-items:center !important;gap:.5rem !important;position:relative}
.facets__item .checkbox__input{position:absolute !important;opacity:0 !important;width:18px !important;height:18px !important;margin:0 !important;left:0 !important;top:50% !important;transform:translateY(-50%) !important;cursor:pointer !important;z-index:1}
.facets__item .icon-checkmark{display:inline-block !important;width:18px !important;height:18px !important;border:1.5px solid #cbd5e1 !important;border-radius:4px !important;flex-shrink:0 !important;background:#fff !important;position:relative}
.facets__item .checkbox__input:checked + .checkbox__label .icon-checkmark,.facets__item .checkbox__input:checked ~ .checkbox__label .icon-checkmark{background:#061f40 !important;border-color:#061f40 !important}
.facets__item .checkbox__input:checked + .checkbox__label .icon-checkmark::after,.facets__item .checkbox__input:checked ~ .checkbox__label .icon-checkmark::after{content:'';position:absolute;left:5px;top:1px;width:5px;height:10px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}
.facets__item .swatch{display:none !important}
/* Productpagina H1 title flicker fix bij kleur-switch */
html.sw-product-page:not(.sw-title-ready) .product-information__details h1,
html.sw-product-page:not(.sw-title-ready) h1.product__title{opacity:0;transition:opacity .15s}
html.sw-product-page.sw-title-ready .product-information__details h1,
html.sw-product-page.sw-title-ready h1.product__title{opacity:1}
@keyframes swTitleFallback{to{opacity:1}}
html.sw-product-page .product-information__details h1,html.sw-product-page h1.product__title{animation:swTitleFallback 0s linear 1.2s forwards}
/* (LAOM FOUC-regels verwijderd: product images zijn nu correct serverside) */
/* Verberg facets sidebar tot mijn JS klaar is met layout (voorkomt flicker bij page load) */
body:not(.sw-filters-ready) .facets-block-wrapper--vertical,body:not(.sw-filters-ready) .facets__form-wrapper{opacity:0 !important;transition:none !important}
body.sw-filters-ready .facets-block-wrapper--vertical,body.sw-filters-ready .facets__form-wrapper{opacity:1 !important;transition:opacity .15s ease}
/* Fallback: na max 1.2s altijd tonen */
@keyframes swFiltersFallback{to{opacity:1}}
.facets-block-wrapper--vertical,.facets__form-wrapper{animation:swFiltersFallback 0s linear 1.2s forwards}
/* Dimbaar facet — override pill/button styling, force standard checkbox layout */
.facets__item button:not(.sw-show-more-diepte),.facets__item .button:not(.sw-show-more-diepte),.facets__item [class*="filter-pill"]{all:unset !important}
.sw-show-more-diepte{cursor:pointer !important;color:#061f40 !important;text-decoration:underline !important;font-weight:600 !important;font-size:.78rem !important;background:none !important;border:0 !important;padding:.5rem 0 0 !important}
.sw-show-more-diepte:hover{color:#0F6FE3 !important}
.facets__item .facets__inputs-list-item,.facets__item li{background:transparent !important;border:0 !important;padding:.2rem 0 !important;list-style:none !important}
.facets__item .facets__inputs-list-item:not([style*="display:none"]):not([data-sw-hidden]),.facets__item li:not([style*="display:none"]):not([data-sw-hidden]){display:block}
.facets__item [data-sw-hidden]{display:none !important}
.facets__item .checkbox__label{display:flex !important;align-items:center !important;gap:.5rem !important;background:transparent !important;color:#1e293b !important;font-weight:500 !important;padding:0 !important;border:0 !important;border-radius:0 !important;cursor:pointer}
/* ===== WELKOM 5% KORTING POPUP ===== */
.sw-popup-overlay{position:fixed;inset:0;background:rgba(6,31,64,0.55);z-index:99998;display:none;align-items:center;justify-content:center;padding:1rem;animation:swPopupFade .25s ease}
.sw-popup-overlay.sw-active{display:flex}
@keyframes swPopupFade{from{opacity:0}to{opacity:1}}
.sw-popup{background:#fff;border-radius:16px;max-width:440px;width:100%;padding:2rem 1.75rem;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:swPopupSlide .35s cubic-bezier(.16,1,.3,1);text-align:center;font-family:inherit}
