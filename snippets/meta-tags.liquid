  // ============== SCROLL PRESERVE bij Shopify form submit (Kleur, Lichtkleur native etc) ==============
  // Save scroll voor Shopify's facet form submit; restore na page load
  document.addEventListener('submit', function(e){
    var form = e.target;
    if (form && (form.id||'').indexOf('facets') > -1 || (form.className||'').indexOf('facets') > -1){
      try { sessionStorage.setItem('sw_scroll', String(window.scrollY)); } catch(err){}
    }
  }, true);
  // Bij click op native facet checkbox, save scroll vóór Shopify auto-submit
  document.addEventListener('click', function(e){
    var t = e.target;
    if (!t || t.tagName !== 'INPUT') return;
    var name = t.getAttribute('name')||'';
    if (name.indexOf('filter.') === 0){
      try { sessionStorage.setItem('sw_scroll', String(window.scrollY)); } catch(err){}
    }
  }, true);
  // Bij page load, herstel scroll
  try {
    var savedScroll = sessionStorage.getItem('sw_scroll');
    if (savedScroll !== null){
      sessionStorage.removeItem('sw_scroll');
      var target = parseInt(savedScroll, 10);
      if (!isNaN(target)){
        // Disable browser auto-scroll restoration
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        // Try multiple times tot DOM klaar is
        var tries = 0;
        var restoreFn = function(){
          window.scrollTo(0, target);
          if (++tries < 10) setTimeout(restoreFn, 100);
        };
        restoreFn();
      }
    }
  } catch(err){}
  function renameKleurLabels(){
    // Scan the entire facets wrapper (en active chips area) en vervang ALLE text nodes
    var scopes = document.querySelectorAll('.facets-block-wrapper--vertical, .facets__form-wrapper, .facets-controls-wrapper, [class*="active-facets"], [class*="facets__selected"], facet-remove, active-facets');
    scopes.forEach(function(scope){
      var walker = document.createTreeWalker(scope, NodeFilter.SHOW_TEXT, null);
      var n;
      while (n = walker.nextNode()){
        var v = n.nodeValue;
        if (!v) continue;
        if (v.indexOf('Mat Wit') > -1) n.nodeValue = v.replace(/Mat Wit/g, 'Wit');
        else if (v.indexOf('Mat Zwart') > -1) n.nodeValue = v.replace(/Mat Zwart/g, 'Zwart');
      }
      // Ook input values voor eventuele type=hidden in chips niet aanpassen (zou Shopify breken)
      // Alleen aria-label van remove-knoppen patchen
      scope.querySelectorAll('[aria-label*="Mat Wit"], [aria-label*="Mat Zwart"]').forEach(function(el){
        var a = el.getAttribute('aria-label');
        if (a) el.setAttribute('aria-label', a.replace(/Mat Wit/g,'Wit').replace(/Mat Zwart/g,'Zwart'));
      });
    });
  }
  function dedupeAndOrderFacets(){
    // Dedup: behoud alleen eerste van elk
    ['.sw-vorm-facet','.sw-ip-facet','.sw-zaag-facet','.sw-diepte-facet'].forEach(function(sel){
      var els = document.querySelectorAll(sel);
      for (var i=1; i<els.length; i++){ els[i].remove(); }
    });
    // Volgorde: Vorm → IP → Gatmaat → Inbouwdiepte, ALLES bovenaan vóór Kleur en de andere native facets
    var kleurFacet = findFacet('Kleur');
    if (!kleurFacet) return;
    var parent = kleurFacet.parentElement;
    if (!parent) return;
    // Vind eerste facet in de lijst (bovenste)
    var firstFacet = parent.querySelector('.facets__item');
    if (!firstFacet) return;
    var order = ['.sw-diepte-facet','.sw-zaag-facet','.sw-ip-facet','.sw-vorm-facet']; // reversed; we prependen
    order.forEach(function(sel){
      var el = parent.querySelector(sel);
      if (!el) return;
      // Prepend zodat Vorm uiteindelijk bovenaan komt
      if (el !== parent.firstElementChild) {
        parent.insertBefore(el, parent.firstElementChild);
      }
    });
  }
