<meta property="og:image" content="https://i.imgur.com/2ROeTRS.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{%- endunless -%}

{%- comment -%} Override Open Graph title/description met onze SEO versie {%- endcomment -%}
