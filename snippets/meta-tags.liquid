{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

{%- comment -%} Spotwereld SEO: betere titles met keywords per page type {%- endcomment -%}
{%- liquid
  assign sw_brand = 'Spotwereld'
  assign sw_tagline = 'Premium LED Verlichting'
  if request.page_type == 'index'
    assign sw_title = 'LED Inbouwspots, Opbouwspots & Hanglampen | ' | append: sw_brand
    assign sw_desc = 'Premium LED verlichting voor elk interieur. CCT switch dimbaar, IP65, 25.000 uur levensduur. Voor 22:00 besteld, morgen in huis. 4.9/5 klantbeoordeling.'
  elsif request.page_type == 'product'
    assign sw_title = product.title | append: ' kopen | ' | append: sw_brand
    if product.description != blank
      assign sw_desc = product.description | strip_html | truncate: 155
    else
      assign sw_desc = product.title | append: ' - Premium LED kwaliteit, snelle levering en 2 jaar garantie bij Spotwereld.'
    endif
  elsif request.page_type == 'collection'
    assign sw_title = collection.title | append: ' kopen - LED ' | append: collection.title | append: ' | ' | append: sw_brand
    if collection.description != blank
      assign sw_desc = collection.description | strip_html | truncate: 155
    else
      assign sw_desc = 'Bekijk onze ' | append: collection.title | append: ' collectie. Premium LED kwaliteit met 2 jaar garantie. Voor 22:00 besteld, morgen in huis.'
    endif
  elsif request.page_type == 'article'
    assign sw_title = article.title | append: ' | ' | append: sw_brand | append: ' Blog'
    assign sw_desc = article.excerpt_or_content | strip_html | truncate: 155
  elsif request.page_type == 'page'
    assign sw_title = page.title | append: ' | ' | append: sw_brand
    if page.content != blank
      assign sw_desc = page.content | strip_html | truncate: 155
    else
      assign sw_desc = sw_tagline | append: ' bij ' | append: sw_brand
    endif
  else
    assign sw_title = page_title | append: ' | ' | append: sw_brand
    assign sw_desc = page_description | default: shop.description | default: sw_tagline
  endif
-%}

<title>
  {{ sw_title }}
  {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
  {%- if current_page != 1 %} &ndash; Pagina {{ current_page }}{% endif -%}
</title>

<meta name="description" content="{{ sw_desc | strip_html | escape }}">

<link rel="canonical" href="{{ canonical_url }}">

{%- comment -%} Spotwereld: extra SEO meta tags {%- endcomment -%}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="author" content="Spotwereld">
<meta name="format-detection" content="telephone=no">

{%- comment -%} Favicon - hardcoded gele lamp op blauwe achtergrond, overschrijft Shopify settings favicon {%- endcomment -%}
<link rel="icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/2ROeTRS.png">
<link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/2ROeTRS.png">
<link rel="apple-touch-icon" sizes="180x180" href="https://i.imgur.com/2ROeTRS.png">
<link rel="shortcut icon" type="image/png" href="https://i.imgur.com/2ROeTRS.png">
<script>
(function(){
  function removeOldFavicons(){
    document.querySelectorAll('link[rel*="icon"]').forEach(function(el){
      if(el.href.indexOf('imgur.com/2ROeTRS') === -1){
        el.parentNode.removeChild(el);
      }
    });
    // Force browser favicon refresh
    var fresh = document.createElement('link');
    fresh.rel = 'icon';
    fresh.type = 'image/png';
    fresh.href = 'https://i.imgur.com/2ROeTRS.png?v=' + Date.now();
    document.head.appendChild(fresh);
  }
  removeOldFavicons();
  document.addEventListener('DOMContentLoaded', removeOldFavicons);
})();
</script>

{%- comment -%} JSON-LD Organization (alle pagina's) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Spotwereld",
  "alternateName": "Spotwereld Webshop",
  "url": "{{ request.origin }}",
  "logo": "https://i.imgur.com/2ROeTRS.png",
  "description": "{{ sw_tagline }} voor elk interieur. Premium LED inbouwspots, opbouwspots, hanglampen en meer.",
  "sameAs": [
    "https://www.facebook.com/spotwereld",
    "https://www.instagram.com/spotwereld"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "availableLanguage": ["Dutch", "Nederlands"]
  }
}
</script>

{%- comment -%} JSON-LD WebSite met SearchAction {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Spotwereld",
  "url": "{{ request.origin }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ request.origin }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- comment -%} JSON-LD BreadcrumbList op collection en product pages {%- endcomment -%}
{%- if request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"}
  ]
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}"},
    {%- if collection -%}
    {"@type": "ListItem", "position": 2, "name": "{{ collection.title | escape }}", "item": "{{ request.origin }}{{ collection.url }}"},
    {"@type": "ListItem", "position": 3, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- else -%}
    {"@type": "ListItem", "position": 2, "name": "{{ product.title | escape }}", "item": "{{ request.origin }}{{ product.url }}"}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} Open Graph image fallback (1200x630 minimum voor social sharing) {%- endcomment -%}
{%- unless page_image -%}
<meta property="og:image" content="https://i.imgur.com/2ROeTRS.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{%- endunless -%}

{%- comment -%} Override Open Graph title/description met onze SEO versie {%- endcomment -%}
<meta property="og:title" content="{{ sw_title | escape }}" data-sw-override>
<meta property="og:description" content="{{ sw_desc | strip_html | escape }}" data-sw-override>
<meta name="twitter:title" content="{{ sw_title | escape }}" data-sw-override>
<meta name="twitter:description" content="{{ sw_desc | strip_html | escape }}" data-sw-override>

{%- comment -%} Card image override (collection/index): swap placeholder met outledtl foto's {%- endcomment -%}
<style>
/* Unify card titles: collection page (product-card H3/text-block) matches homepage (sw-pp-card .sw-pp-name) */
.sw-pp-name,
product-card h3,
product-card h4,
product-card .h4,
product-card .h3,
product-card [class*="product_title"],
product-card [class*="product-card__title"],
product-card .product-card__title,
product-card .product-card__title a,
product-card product-title,
product-card product-title a,
.product-card h3,
.product-card h4,
.product-card .h4{
  font-weight:600 !important;
  color:#1e293b !important;
  font-size:.85rem !important;
  line-height:1.35 !important;
  font-family:inherit !important;
  text-decoration:none !important;
  letter-spacing:normal !important;
}
/* Ook de inline tekst-block container die Horizon gebruikt */
product-card [class*="product_title"] *,
product-card .text-block[class*="product_title"]{
  color:#1e293b !important;
  font-weight:600 !important;
}
/* Vorm filter active chip & lichtkleur active */
.sw-active-chip{display:inline-flex;align-items:center;gap:.4rem;background:#f1f5f9;border:1px solid #cbd5e1;border-radius:999px;padding:.35rem .75rem;font-size:.78rem;color:#1e293b;margin:.25rem .35rem .25rem 0;font-weight:500}
.sw-active-chip button{background:none;border:0;cursor:pointer;color:#64748b;font-size:1rem;line-height:1;padding:0 0 0 .15rem;display:inline-flex;align-items:center}
.sw-active-chip button:hover{color:#dc2626}
.sw-lk-active,.sw-vorm-active{background:rgba(15,111,227,.08)!important;border-radius:6px}
.sw-lk-active .checkbox__label-text,.sw-vorm-active .checkbox__label-text{color:#0F6FE3!important;font-weight:700!important}
.sw-lk-active .icon-checkmark,.sw-vorm-active .icon-checkmark{background:#0F6FE3!important;border-color:#0F6FE3!important;color:#fff!important}
.sw-lk-active input[type="checkbox"],.sw-vorm-active input[type="checkbox"]{accent-color:#0F6FE3}
/* Force checked appearance regardless of native render */
.sw-lk-active .checkbox__label::before,.sw-vorm-active .checkbox__label::before{background:#0F6FE3!important;border-color:#0F6FE3!important}
</style>
<script>
(function(){
  // Hardcoded overrides per handle voor cards waar geen liquid marker te plaatsen is (sw-pp-card op homepage etc)
  var SW_HANDLE_OVERRIDES = {
    'led-inbouwspot-laom-wit': 'https://www.outledtl.nl/wp-content/uploads/2023/10/OUTLEDTL-LED-INBOUWSPOT-LAOM-SLIM-FIT-6W-DIMBAAR-WIT.png',
    'led-inbouwspot-laom-mat-zwart': 'https://www.outledtl.nl/wp-content/uploads/2019/12/OUTLEDTL-LED-INBOUWSPOT-LAOM-SLIM-FIT-6W-DIMBAAR-ZWART.png',
    'led-inbouwspot-laom-zilver': 'https://www.outledtl.nl/wp-content/uploads/2023/10/OUTLEDTL-LED-INBOUWSPOT-LAOM-SLIM-FIT-6W-DIMBAAR-ZILVER.png'
  };
  function swapImgs(scope, url){
    scope.querySelectorAll('img, source').forEach(function(el){
      if (el.tagName === 'SOURCE') { el.srcset = url; return; }
      el.removeAttribute('srcset');
      el.removeAttribute('data-src');
      el.src = url;
      if (el.loading === 'lazy') el.loading = 'eager';
    });
  }
  function applyCardOverrides(){
    document.querySelectorAll('.sw-card-img-override').forEach(function(marker){
      var card = marker.closest('product-card');
      if (!card || card.dataset.swImgDone) return;
      var url = marker.dataset.url;
      if (!url) return;
      swapImgs(card, url);
      card.dataset.swImgDone = '1';
    });
    // Generic by handle: alleen binnen STRIKT product-card componenten (homepage sw-pp-card etc),
    // NOOIT op product detail page (anders swappen color-picker links de main media)
    document.querySelectorAll('product-card a[href*="/products/"], .sw-pp-card[href*="/products/"], a.sw-pp-card[href*="/products/"]').forEach(function(a){
      if (a.dataset.swImgDone) return;
      var m = a.getAttribute('href').match(/\/products\/([^?#\/]+)/);
      if (!m) return;
      var url = SW_HANDLE_OVERRIDES[m[1]];
      if (!url) return;
      // Scope MOET een echte card wrapper zijn, niet zomaar [class*="card"]
      var scope = a.closest('product-card, .sw-pp-card');
      if (!scope) scope = a; // fallback: alleen de link zelf (geen brede swap)
      swapImgs(scope, url);
      a.dataset.swImgDone = '1';
    });
  }
  applyCardOverrides();
  document.addEventListener('DOMContentLoaded', applyCardOverrides);
  // Re-apply after lazy load / variant change / pagination
  var mo = new MutationObserver(function(){ applyCardOverrides(); });
  document.addEventListener('DOMContentLoaded', function(){
    mo.observe(document.body, {childList:true, subtree:true, attributes:true, attributeFilter:['src','srcset']});
  });

  // ============== TITLE SPEC REWRITER ==============
  // Per handle, the full descriptive title
  var SW_TITLES = {
    'led-inbouwspot-aristo-mat-wit':        'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Mat Wit',
    'led-inbouwspot-aristo-mat-zwart':      'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Mat Zwart',
    'led-inbouwspot-aristo-zilver':         'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Zilver',
    'led-inbouwspot-aristo-koper':          'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Koper',
    'led-inbouwspot-aristo-goud':           'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Goud',
    'led-inbouwspot-aristo-satin-metallic': 'LED Inbouwspot Aristo | Dimbaar | IP65 | 4W en 6W | CCT Switch | Zaagmaat: Ø68-75 mm | Satin Metallic',
    'led-inbouwspot-miran-mat-wit':         'LED Inbouwspot Miran | Dimbaar | IP65 | 5W en 7W | CCT Switch | Zaagmaat: Ø68-75 mm | Mat Wit',
    'led-inbouwspot-miran-mat-zwart':       'LED Inbouwspot Miran | Dimbaar | IP65 | 5W en 7W | CCT Switch | Zaagmaat: Ø68-75 mm | Mat Zwart',
    'led-inbouwspot-miran-goud':            'LED Inbouwspot Miran | Dimbaar | IP65 | 5W en 7W | CCT Switch | Zaagmaat: Ø68-75 mm | Goud',
    'led-inbouwspot-laom-wit':              'LED Inbouwspot Laom | Dimbaar | IP44 | 6W | Vierkant | Zaagmaat: Ø68 mm | Wit',
    'led-inbouwspot-laom-mat-zwart':        'LED Inbouwspot Laom | Dimbaar | IP44 | 6W | Vierkant | Zaagmaat: Ø68 mm | Mat Zwart',
    'led-inbouwspot-laom-zilver':           'LED Inbouwspot Laom | Dimbaar | IP44 | 6W | Vierkant | Zaagmaat: Ø68 mm | Zilver'
  };
  function rewriteTitles(){
    // Cards (collection/home) — find any <a href="/products/HANDLE"> and rewrite text
    document.querySelectorAll('a[href*="/products/"]').forEach(function(a){
      if (a.dataset.swTitleDone) return;
      var m = a.getAttribute('href').match(/\/products\/([^?#\/]+)/);
      if (!m) return;
      var newT = SW_TITLES[m[1]];
      if (!newT) return;
      // Walk nodes in the parent card to find title text
      var card = a.closest('product-card, .sw-pp-card, .product-card');
      if (!card) {
        // Standalone link — if direct text content is the title, rewrite
        if (a.children.length === 0 && a.textContent.trim().length > 0) {
          a.textContent = newT;
        }
        a.dataset.swTitleDone = '1';
        return;
      }
      // Find title element(s) in card
      var titleEls = card.querySelectorAll('h1, h2, h3, h4, .sw-pp-name, .product-card__title, [class*="product_title"], product-title');
      titleEls.forEach(function(t){
        // Find deepest text node only
        var cur = t.textContent.trim();
        if (cur.length > 0 && cur.indexOf('|') === -1) {
          // Find the actual text node and replace
          var walk = document.createTreeWalker(t, NodeFilter.SHOW_TEXT, null);
          var firstText = null;
          var node;
          while (node = walk.nextNode()) {
            if (node.nodeValue.trim().length > 0) { firstText = node; break; }
          }
          if (firstText) firstText.nodeValue = newT;
        }
      });
      a.dataset.swTitleDone = '1';
    });
    // Product page H1
    var h1 = document.querySelector('h1');
    if (h1 && !h1.dataset.swTitleDone) {
      var path = location.pathname.match(/\/products\/([^?#\/]+)/);
      if (path && SW_TITLES[path[1]]) {
        h1.textContent = SW_TITLES[path[1]];
        h1.dataset.swTitleDone = '1';
      }
    }
  }
  rewriteTitles();
  document.addEventListener('DOMContentLoaded', rewriteTitles);
  setTimeout(rewriteTitles, 500);
  setTimeout(rewriteTitles, 1500);
  setTimeout(rewriteTitles, 3000);
  // Observe ONLY the product grid (not body) with debounce
  var titleDebounce = null;
  var titleObs = new MutationObserver(function(){
    clearTimeout(titleDebounce);
    titleDebounce = setTimeout(rewriteTitles, 200);
  });
  document.addEventListener('DOMContentLoaded', function(){
    var g = document.querySelector('.product-grid, results-list, .sw-pp-wrap, main');
    if (g) titleObs.observe(g, {childList:true, subtree:true});
  });

  // ============== MULTI FILTER HIJACK + CHIPS (Vorm + IP + Zaagmaat + Lichtkleur opties) ==============
  // Product spec lookup per handle
  var SW_PRODUCT_SPECS = {
    'led-inbouwspot-aristo-mat-wit':        {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-aristo-mat-zwart':      {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-aristo-zilver':         {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-aristo-koper':          {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-aristo-goud':           {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-aristo-satin-metallic': {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:25},
    'led-inbouwspot-miran-mat-wit':         {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:23},
    'led-inbouwspot-miran-mat-zwart':       {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:23},
    'led-inbouwspot-miran-goud':            {vorm:'rond', ip:'IP65', zaag:[68,75], diepte:23},
    'led-inbouwspot-laom-wit':              {vorm:'vierkant', ip:'IP44', zaag:[68,68], diepte:28},
    'led-inbouwspot-laom-mat-zwart':        {vorm:'vierkant', ip:'IP44', zaag:[68,68], diepte:28},
    'led-inbouwspot-laom-zilver':           {vorm:'vierkant', ip:'IP44', zaag:[68,68], diepte:28}
  };
  function getHandle(card){
    var link = card.querySelector('a[href*="/products/"]');
    if (!link) return '';
    return (link.getAttribute('href').split('/products/')[1]||'').split(/[?#\/]/)[0];
  }
  function getSpecs(handle){ return SW_PRODUCT_SPECS[handle] || null; }
  function zaagInRange(zaag, rangeKey){
    if (!zaag) return false;
    var lo=zaag[0], hi=zaag[1];
    var ranges = {
      'lt49': function(){return hi < 49},
      '50-59': function(){return lo<=59 && hi>=50},
      '60-69': function(){return lo<=69 && hi>=60},
      '70-79': function(){return lo<=79 && hi>=70},
      '80-99': function(){return lo<=99 && hi>=80},
      '100-129': function(){return lo<=129 && hi>=100},
      'gt130': function(){return lo > 130}
    };
    return ranges[rangeKey] ? ranges[rangeKey]() : false;
  }
  function applyAllFilters(){
    var params = new URLSearchParams(location.search);
    var vorms = params.getAll('sw_vorm');
    var ips = params.getAll('sw_ip');
    var zaags = params.getAll('sw_zaag');
    var dieptes = params.getAll('sw_diepte');
    document.querySelectorAll('product-card, .product-card').forEach(function(c){
      var h = getHandle(c);
      var s = getSpecs(h);
      var grid = c.closest('li, .grid__item, .product-grid__card-wrapper') || c;
      var keep = true;
      if (vorms.length>0) keep = keep && s && vorms.indexOf(s.vorm)>-1;
      if (ips.length>0) keep = keep && s && ips.indexOf(s.ip)>-1;
      if (zaags.length>0) keep = keep && s && zaags.some(function(z){return zaagInRange(s.zaag, z)});
      if (dieptes.length>0) keep = keep && s && dieptes.indexOf(String(s.diepte))>-1;
      grid.style.display = keep ? '' : 'none';
    });
  }

  // GUARD to prevent observer infinite loop
  var SW_FILTER_GUARD = false;
  function withGuard(fn){
    if (SW_FILTER_GUARD) return;
    SW_FILTER_GUARD = true;
    try { fn(); } finally {
      requestAnimationFrame(function(){ requestAnimationFrame(function(){ SW_FILTER_GUARD = false; }); });
    }
  }

  function findFacet(label){
    var details = document.querySelectorAll('.facets__item, details.facets__item');
    for (var i=0; i<details.length; i++){
      var l = details[i].querySelector('.facets__label, summary');
      if (l && l.textContent.trim().toLowerCase().indexOf(label.toLowerCase()) > -1) return details[i];
    }
    return null;
  }

  function fixVormInputs(){
    var vormFacet = document.querySelector('.sw-vorm-facet');
    if (!vormFacet) return;
    var actives = new URLSearchParams(location.search).getAll('sw_vorm');
    vormFacet.querySelectorAll('input').forEach(function(inp){
      if (inp.dataset.swFixed) return;
      inp.dataset.swFixed = '1';
      var val = inp.value.replace(/^vorm-/, '');
      inp.setAttribute('name','sw_vorm');
      inp.value = val;
      inp.checked = actives.indexOf(val) > -1;
      var li = inp.closest('li, .facets__inputs-list-item');
      if (li){ li.classList.toggle('sw-vorm-active', inp.checked); }
      inp.addEventListener('click', function(e){
        e.stopPropagation(); e.stopImmediatePropagation();
        setTimeout(function(){ toggleParamFromInputs('.sw-vorm-facet', 'sw_vorm'); }, 0);
      }, true);
      inp.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
    });
  }
  function addIPFilter(){
    if (document.querySelector('.sw-ip-facet')) { syncIPInputs(); return; }
    var anchor = document.querySelector('.sw-vorm-facet') || findFacet('Kleur');
    if (!anchor) return;
    var opts = [
      {v:'IP20', n:'IP20 (Stofbestendig)'},
      {v:'IP21', n:'IP21 (Stof- en druppelbestendig)'},
      {v:'IP44', n:'IP44 (Spatwaterdicht)'},
      {v:'IP54', n:'IP54 (Stof- en spatwaterdicht)'},
      {v:'IP65', n:'IP65 (Stof- en plenswaterdicht)'},
      {v:'IP67', n:'IP67 (Stof- en waterdicht)'}
    ];
    var html = '<details class="facets__item sw-ip-facet" open><summary class="facets__summary"><span class="facets__label">IP-waarde</span><span class="facets__icon"></span></summary><div class="facets__panel"><ul class="facets__inputs facets__inputs-list">'+
      opts.map(function(o){
        return '<li class="facets__inputs-list-item"><label class="checkbox"><input type="checkbox" class="checkbox__input" name="sw_ip" value="'+o.v+'"><span class="checkbox__label"><span class="icon-checkmark"></span><span class="checkbox__label-text">'+o.n+'</span></span></label></li>';
      }).join('')+'</ul></div></details>';
    withGuard(function(){ anchor.insertAdjacentHTML('afterend', html); });
    syncIPInputs();
  }
  function addDiepteFilter(){
    if (document.querySelector('.sw-diepte-facet')) { syncDiepteInputs(); return; }
    var anchor = document.querySelector('.sw-zaag-facet') || document.querySelector('.sw-ip-facet') || document.querySelector('.sw-vorm-facet') || findFacet('Kleur');
    if (!anchor) return;
    var opts = [12,15,23,25,26,27,28,30,35,36,37,38,45,47,62,68,78,80,125,133].map(function(d){return {v:String(d), n:d+' mm'};});
    var html = '<details class="facets__item sw-diepte-facet" open><summary class="facets__summary"><span class="facets__label">Inbouwdiepte</span><span class="facets__icon"></span></summary><div class="facets__panel"><ul class="facets__inputs facets__inputs-list">'+
      opts.map(function(o){
        return '<li class="facets__inputs-list-item"><label class="checkbox"><input type="checkbox" class="checkbox__input" name="sw_diepte" value="'+o.v+'"><span class="checkbox__label"><span class="icon-checkmark"></span><span class="checkbox__label-text">'+o.n+'</span></span></label></li>';
      }).join('')+'</ul></div></details>';
    withGuard(function(){ anchor.insertAdjacentHTML('afterend', html); });
    syncDiepteInputs();
  }
  function syncDiepteInputs(){
    var facet = document.querySelector('.sw-diepte-facet'); if (!facet) return;
    var actives = new URLSearchParams(location.search).getAll('sw_diepte');
    facet.querySelectorAll('input').forEach(function(inp){
      inp.checked = actives.indexOf(inp.value) > -1;
      var li = inp.closest('li'); if (li) li.classList.toggle('sw-vorm-active', inp.checked);
      if (inp.dataset.swFixed) return;
      inp.dataset.swFixed = '1';
      inp.addEventListener('click', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); setTimeout(function(){ toggleParamFromInputs('.sw-diepte-facet', 'sw_diepte'); }, 0); }, true);
      inp.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
    });
  }
  function renameKleurLabels(){
    var map = {'Mat Wit':'Wit','Mat Zwart':'Zwart'};
    // Rename inside the Kleur facet panel
    var kleurFacet = findFacet('Kleur');
    if (kleurFacet){
      kleurFacet.querySelectorAll('.checkbox__label-text, label span, .facets__label-text').forEach(function(lbl){
        var t = (lbl.textContent||'').trim();
        if (map[t]) lbl.textContent = map[t];
      });
    }
    // Rename Shopify's active filter chips that show "Mat Wit" / "Mat Zwart"
    document.querySelectorAll('.facets__selected button, .facets__selected a, .facets__selected span, [class*="active-facet"], [data-active-facet]').forEach(function(el){
      var t = (el.textContent||'');
      if (!t) return;
      if (t.indexOf('Mat Wit')>-1) {
        // Replace text nodes only (preserve nested icons)
        var w = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
        var n; while (n = w.nextNode()){ if (n.nodeValue.indexOf('Mat Wit')>-1) n.nodeValue = n.nodeValue.replace(/Mat Wit/g,'Wit'); }
      }
      if (t.indexOf('Mat Zwart')>-1) {
        var w2 = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
        var n2; while (n2 = w2.nextNode()){ if (n2.nodeValue.indexOf('Mat Zwart')>-1) n2.nodeValue = n2.nodeValue.replace(/Mat Zwart/g,'Zwart'); }
      }
    });
  }
  function dedupeAndOrderFacets(){
    // Remove duplicate sw-vorm-facet (oude inline code voegt soms tweede toe)
    var vorms = document.querySelectorAll('.sw-vorm-facet');
    for (var i=1; i<vorms.length; i++){ vorms[i].remove(); }
    // Verzeker dat onze filters NA Kleur staan, niet ervoor
    var kleurFacet = findFacet('Kleur');
    if (!kleurFacet) return;
    var parent = kleurFacet.parentElement;
    if (!parent) return;
    ['.sw-vorm-facet','.sw-ip-facet','.sw-zaag-facet','.sw-diepte-facet'].forEach(function(sel){
      var el = parent.querySelector(sel);
      if (!el) return;
      // Als el VOOR kleurFacet staat in dezelfde parent, verplaats naar erna
      var pos = kleurFacet.compareDocumentPosition(el);
      if (pos & Node.DOCUMENT_POSITION_PRECEDING){
        // move el right after kleurFacet
        kleurFacet.parentNode.insertBefore(el, kleurFacet.nextSibling);
      }
    });
  }
  function syncIPInputs(){
    var facet = document.querySelector('.sw-ip-facet'); if (!facet) return;
    var actives = new URLSearchParams(location.search).getAll('sw_ip');
    facet.querySelectorAll('input').forEach(function(inp){
      inp.checked = actives.indexOf(inp.value) > -1;
      var li = inp.closest('li'); if (li) li.classList.toggle('sw-vorm-active', inp.checked);
      if (inp.dataset.swFixed) return;
      inp.dataset.swFixed = '1';
      inp.addEventListener('click', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); setTimeout(function(){ toggleParamFromInputs('.sw-ip-facet', 'sw_ip'); }, 0); }, true);
      inp.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
    });
  }
  function addZaagFilter(){
    if (document.querySelector('.sw-zaag-facet')) { syncZaagInputs(); return; }
    var anchor = document.querySelector('.sw-ip-facet') || document.querySelector('.sw-vorm-facet') || findFacet('Kleur');
    if (!anchor) return;
    var opts = [
      {v:'lt49', n:'< 49 mm'},
      {v:'50-59', n:'50-59 mm'},
      {v:'60-69', n:'60-69 mm'},
      {v:'70-79', n:'70-79 mm'},
      {v:'80-99', n:'80-99 mm'},
      {v:'100-129', n:'100-129 mm'},
      {v:'gt130', n:'> 130 mm'}
    ];
    var html = '<details class="facets__item sw-zaag-facet" open><summary class="facets__summary"><span class="facets__label">Gatmaat / Zaagmaat</span><span class="facets__icon"></span></summary><div class="facets__panel"><ul class="facets__inputs facets__inputs-list">'+
      opts.map(function(o){
        return '<li class="facets__inputs-list-item"><label class="checkbox"><input type="checkbox" class="checkbox__input" name="sw_zaag" value="'+o.v+'"><span class="checkbox__label"><span class="icon-checkmark"></span><span class="checkbox__label-text">'+o.n+'</span></span></label></li>';
      }).join('')+'</ul></div></details>';
    withGuard(function(){ anchor.insertAdjacentHTML('afterend', html); });
    syncZaagInputs();
  }
  function syncZaagInputs(){
    var facet = document.querySelector('.sw-zaag-facet'); if (!facet) return;
    var actives = new URLSearchParams(location.search).getAll('sw_zaag');
    facet.querySelectorAll('input').forEach(function(inp){
      inp.checked = actives.indexOf(inp.value) > -1;
      var li = inp.closest('li'); if (li) li.classList.toggle('sw-vorm-active', inp.checked);
      if (inp.dataset.swFixed) return;
      inp.dataset.swFixed = '1';
      inp.addEventListener('click', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); setTimeout(function(){ toggleParamFromInputs('.sw-zaag-facet', 'sw_zaag'); }, 0); }, true);
      inp.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
    });
  }
  function expandLichtkleur(){
    var lkFacet = findFacet('Lichtkleur');
    if (!lkFacet) return;
    if (lkFacet.dataset.swLkExpanded) return;
    var list = lkFacet.querySelector('.facets__inputs, ul, .facets__inputs-list');
    if (!list) return;
    var origItem = list.querySelector('.facets__inputs-list-item, li');
    if (!origItem) return;
    // Hide original (Instelbaar) shown items already done by old code; we add comprehensive set
    var allOpts = [
      {v:'2200', n:'2200K (flame-wit)'},
      {v:'2700', n:'2700K (extra warm-wit)'},
      {v:'2700d', n:'2700K (extra warm-wit) (dimbaar)'},
      {v:'3000', n:'3000K (warm-wit)'},
      {v:'4000', n:'4000K (neutraal-wit)'},
      {v:'dim2warm', n:'Dim-to-warm'},
      {v:'rgbww', n:'RGBWW'},
      {v:'tri', n:'Tri-color (2700K, 3000K en 4000K)'}
    ];
    withGuard(function(){
      // Remove existing fake-lk clones to rebuild cleanly
      list.querySelectorAll('[class*="sw-fake-lk-"], [class*="sw-lk-opt-"]').forEach(function(el){ el.remove(); });
      allOpts.forEach(function(opt){
        var clone = origItem.cloneNode(true);
        clone.style.display = '';
        clone.classList.add('sw-lk-opt-'+opt.v);
        clone.setAttribute('data-sw-lk', opt.v);
        var lbl = clone.querySelector('.checkbox__label-text, label span');
        if (lbl) lbl.textContent = opt.n;
        var input = clone.querySelector('input');
        if (input){
          input.name = 'sw_lk';
          input.value = opt.v;
          input.checked = false;
          // Find existing original input name/value for actual Shopify filtering
          // Pass-through: clicking will filter on sw_lk URL param + match Instelbaar product option
          input.addEventListener('click', function(e){
            e.stopPropagation(); e.stopImmediatePropagation();
            setTimeout(function(){ toggleParamFromInputs('[data-sw-lk]','sw_lk', list); }, 0);
          }, true);
          input.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
        }
        list.appendChild(clone);
      });
    });
    lkFacet.dataset.swLkExpanded = '1';
    syncLkInputs();
  }
  function syncLkInputs(){
    var actives = new URLSearchParams(location.search).getAll('sw_lk');
    document.querySelectorAll('[class*="sw-lk-opt-"]').forEach(function(li){
      var inp = li.querySelector('input');
      if (inp){ inp.checked = actives.indexOf(inp.value) > -1; li.classList.toggle('sw-lk-active', inp.checked); }
    });
  }
  function toggleParamFromInputs(scopeSel, paramName, optionalScope){
    var scope = optionalScope || document;
    var p = new URLSearchParams(location.search);
    p.delete(paramName);
    (typeof scopeSel === 'string' ? scope.querySelectorAll(scopeSel + ' input:checked, ' + scopeSel + '[data-sw-lk] input:checked') : scope.querySelectorAll('input:checked')).forEach(function(i){
      if (i.name === paramName) p.append(paramName, i.value);
    });
    var s = p.toString();
    history.replaceState({}, '', location.pathname + (s ? '?' + s : ''));
    applyAllFilters();
    renderActiveChips();
    // Update visual active classes
    document.querySelectorAll('.sw-vorm-facet input, .sw-ip-facet input, .sw-zaag-facet input').forEach(function(i){
      var li = i.closest('li'); if (li) li.classList.toggle('sw-vorm-active', i.checked);
    });
    syncLkInputs();
  }
  function renderActiveChips(){
    var holder = document.querySelector('.facets-block-wrapper--vertical, .facets__form-wrapper');
    if (!holder) return;
    withGuard(function(){
      holder.querySelectorAll('.sw-active-chip[data-sw-chip]').forEach(function(c){ c.remove(); });
      var p = new URLSearchParams(location.search);
      var defs = [
        {param:'sw_vorm', label:'Vorm', facetSel:'.sw-vorm-facet', map:{rond:'Rond',vierkant:'Vierkant',rechthoek:'Rechthoek'}},
        {param:'sw_ip', label:'IP', facetSel:'.sw-ip-facet', map:{IP20:'IP20',IP21:'IP21',IP44:'IP44',IP54:'IP54',IP65:'IP65',IP67:'IP67'}},
        {param:'sw_zaag', label:'Gatmaat', facetSel:'.sw-zaag-facet', map:{'lt49':'< 49 mm','50-59':'50-59 mm','60-69':'60-69 mm','70-79':'70-79 mm','80-99':'80-99 mm','100-129':'100-129 mm','gt130':'> 130 mm'}},
        {param:'sw_diepte', label:'Inbouwdiepte', facetSel:'.sw-diepte-facet', map:{}},
        {param:'sw_lk', label:'Lichtkleur', facetSel:'[data-sw-lk]', map:{'2200':'2200K','2700':'2700K','2700d':'2700K dimbaar','3000':'3000K','4000':'4000K','dim2warm':'Dim-to-warm','rgbww':'RGBWW','tri':'Tri-color'}}
      ];
      defs.forEach(function(def){
        p.getAll(def.param).forEach(function(v){
          var chip = document.createElement('span');
          chip.className = 'sw-active-chip';
          chip.setAttribute('data-sw-chip', def.param+'-'+v);
          var lbl = def.map[v] || (def.param==='sw_diepte' ? (v + ' mm') : v);
          chip.innerHTML = def.label + ': ' + lbl + ' <button aria-label="Verwijder">✕</button>';
          chip.querySelector('button').addEventListener('click', function(){
            var p2 = new URLSearchParams(location.search);
            var keep = p2.getAll(def.param).filter(function(x){ return x !== v; });
            p2.delete(def.param);
            keep.forEach(function(k){ p2.append(def.param, k); });
            var s = p2.toString();
            history.replaceState({}, '', location.pathname + (s?'?'+s:''));
            var sel = def.facetSel + ' input[value="'+v+'"]';
            var inp = document.querySelector(sel);
            if (inp){ inp.checked = false; var li = inp.closest('li'); if (li) li.classList.remove('sw-vorm-active','sw-lk-active'); }
            applyAllFilters();
            renderActiveChips();
          });
          holder.insertBefore(chip, holder.firstChild);
        });
      });
    });
  }
  function runAllSwFilters(){
    if (SW_FILTER_GUARD) return;
    withGuard(function(){
      fixVormInputs();
      addIPFilter();
      addZaagFilter();
      addDiepteFilter();
      expandLichtkleur();
      renameKleurLabels();
      dedupeAndOrderFacets();
      applyAllFilters();
      renderActiveChips();
    });
  }
  runAllSwFilters();
  document.addEventListener('DOMContentLoaded', runAllSwFilters);
  setTimeout(runAllSwFilters, 400);
  setTimeout(runAllSwFilters, 1200);
  setTimeout(runAllSwFilters, 2500);
  // Observer with guard + debounce (target facet wrapper only, NOT body)
  var swFilterDebounce = null;
  var swFilterObs = new MutationObserver(function(){
    if (SW_FILTER_GUARD) return;
    clearTimeout(swFilterDebounce);
    swFilterDebounce = setTimeout(function(){ withGuard(runAllSwFilters); }, 150);
  });
  document.addEventListener('DOMContentLoaded', function(){
    var f = document.querySelector('.facets-block-wrapper--vertical, .facets__form-wrapper');
    if (f) swFilterObs.observe(f, {childList:true, subtree:true});
  });
})();
</script>

