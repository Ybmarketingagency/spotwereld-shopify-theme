  function expandLichtkleur(){
    var lkFacet = findFacet('Lichtkleur');
    if (!lkFacet) return;
    var list = lkFacet.querySelector('.facets__inputs, ul, .facets__inputs-list');
    if (!list) return;
    // ALTIJD oude sw-fake-lk-* clones uit collection.json verwijderen
    list.querySelectorAll('[class*="sw-fake-lk-"]').forEach(function(el){ el.remove(); });
    if (lkFacet.dataset.swLkExpanded) { syncLkInputs(); return; }
    // Vind origineel item (Instelbaar) als template, kloon, dan VERWIJDER het origineel
    var origItem = list.querySelector('.facets__inputs-list-item:not([class*="sw-lk-opt-"]), li:not([class*="sw-lk-opt-"])');
    if (!origItem) return;
    var origItemRef = origItem; // bewaar referentie om later te verwijderen
    // Hide original (Instelbaar) shown items already done by old code; we add comprehensive set
    var allOpts = [
      {v:'2200', n:'2200K (flame-wit)'},
      {v:'2700', n:'2700K (extra warm-wit)'},
      {v:'2700d', n:'2700K (extra warm-wit) (dimbaar)'},
      {v:'3000', n:'3000K (warm-wit)'},
      {v:'4000', n:'4000K (neutraal-wit)'},
      {v:'dim2warm', n:'Dim-to-warm'},
      {v:'rgbww', n:'RGBWW'},
      {v:'tri', n:'Tri-color (2700K, 3000K en 4000K)'}
    ];
    // Remove existing fake-lk clones to rebuild cleanly
    list.querySelectorAll('[class*="sw-fake-lk-"], [class*="sw-lk-opt-"]').forEach(function(el){ el.remove(); });
    allOpts.forEach(function(opt){
      var clone = origItem.cloneNode(true);
      clone.style.display = '';
      clone.classList.add('sw-lk-opt-'+opt.v);
      clone.setAttribute('data-sw-lk', opt.v);
      var lbl = clone.querySelector('.checkbox__label-text, label span');
      if (lbl) lbl.textContent = opt.n;
      var input = clone.querySelector('input');
      if (input){
        var uid = 'sw-lk-input-' + opt.v;
        input.id = uid;
        input.name = 'sw_lk';
        input.value = opt.v;
        input.checked = false;
        input.disabled = false;
        input.removeAttribute('disabled');
        // Fix labels in deze clone om naar de juiste input te wijzen
        clone.querySelectorAll('label').forEach(function(l){
          if (l.hasAttribute('for')) l.setAttribute('for', uid);
        });
        input.addEventListener('click', function(e){
          e.stopPropagation(); e.stopImmediatePropagation();
          setTimeout(function(){ toggleParamFromInputs('[data-sw-lk]','sw_lk', list); }, 0);
        }, true);
        input.addEventListener('change', function(e){ e.stopPropagation(); e.stopImmediatePropagation(); }, true);
      }
      list.appendChild(clone);
    });
    // Verwijder originele "Instelbaar (2700K-4000K)" item — voorkomt dat Shopify die submit
    if (origItemRef && origItemRef.parentNode) origItemRef.parentNode.removeChild(origItemRef);
    // Verwijder ook eventuele input[name*="lichtkleur"] elders in DOM (Shopify form hidden inputs)
    document.querySelectorAll('input[name="filter.v.option.lichtkleur"], input[name="filter.p.product_option.lichtkleur"]').forEach(function(i){
      // Alleen verwijderen als NIET een van mijn clones
      if (!i.closest('[class*="sw-lk-opt-"]')) i.remove();
