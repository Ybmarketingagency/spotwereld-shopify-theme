.sw-popup-close{position:absolute;top:.5rem;right:.5rem;background:#fff;border:0;font-size:1.6rem;cursor:pointer !important;color:#475569;width:36px;height:36px;border-radius:50%;display:flex !important;align-items:center;justify-content:center;transition:all .15s;line-height:1;z-index:100;pointer-events:auto !important;padding:0;font-family:inherit;font-weight:400;user-select:none;-webkit-appearance:none;appearance:none}
.sw-popup-close:hover{background:#f1f5f9;color:#061f40;transform:scale(1.05)}
.sw-popup-close:focus{outline:2px solid #0F6FE3;outline-offset:2px}
