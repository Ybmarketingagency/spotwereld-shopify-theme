      el.removeAttribute('srcset');
      el.removeAttribute('data-src');
      el.src = url;
      if (el.loading === 'lazy') el.loading = 'eager';
      // High prio voor LAOM card images zodat browser ze sneller fetched
      try { el.fetchPriority = 'high'; } catch(e){}
