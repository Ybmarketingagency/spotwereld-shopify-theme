<style>
.sw-ks-wrap{max-width:1280px;margin:0 auto;padding:3rem 1.5rem 5rem;display:grid;grid-template-columns:1fr;gap:2.5rem}
@media(min-width:768px){.sw-ks-wrap{grid-template-columns:220px 1fr}}
.sw-ks-sidebar{align-self:start;position:sticky;top:7rem}
.sw-ks-sidebar h3{font-size:.75rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.1em;margin:0 0 .75rem;padding:0 .75rem}
.sw-ks-sidebar nav{display:flex;flex-direction:column;gap:.125rem}
.sw-ks-sidebar a{display:block;padding:.5rem .75rem;border-radius:.5rem;color:#374151;font-size:.9375rem;text-decoration:none;font-weight:500;transition:background .15s,color .15s;line-height:1.4}
.sw-ks-sidebar a:hover{background:#EBF2FF;color:#0F6FE3}
.sw-ks-sidebar a.sw-active{background:#EBF2FF;color:#083D7D;font-weight:700;border-left:3px solid #0F6FE3;padding-left:calc(.75rem - 3px)}
.sw-faq-item{border-bottom:1px solid #e5e7eb;overflow:hidden}
.sw-faq-btn{width:100%;background:none;border:none;padding:1.25rem 1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;text-align:left;gap:1rem}
.sw-faq-btn:hover{background:#f9fafb}
.sw-faq-q{font-weight:600;color:#111827;font-size:1rem}
.sw-faq-icon{width:1.5rem;height:1.5rem;border-radius:50%;background:#EBF2FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s}
.sw-faq-answer{max-height:0;overflow:hidden;transition:max-height .3s ease,padding .3s ease}
.sw-faq-answer.open{max-height:500px}
.sw-faq-answer-inner{padding:.25rem 1rem 1.25rem;color:#6b7280;font-size:.9375rem;line-height:1.7}
</style>

<div style="background:#f9fafb">
  <div class="sw-ks-wrap">
    <aside class="sw-ks-sidebar">
      <h3>Klantenservice</h3>
      <nav>
        <a href="/pages/contact">Contact</a>
        <a href="/pages/over-ons">Over ons</a>
        <a href="/pages/veelgestelde-vragen">Veelgestelde vragen</a>
        <a href="/pages/verzending-retouren">Verzending &amp; Retouren</a>
        <a href="/pages/garantie">Garantie</a>
        <a href="/pages/algemene-voorwaarden">Algemene voorwaarden</a>
        <a href="/pages/privacyverklaring">Privacyverklaring</a>
      </nav>
    </aside>

    <div>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2.5rem" id="swFaqCats">
        <button onclick="swFaqFilter('all')" style="padding:.375rem 1rem;border-radius:9999px;font-size:.875rem;font-weight:600;cursor:pointer;border:2px solid #083D7D;background:#083D7D;color:#fff">Alle vragen</button>
        <button onclick="swFaqFilter('bestelling')" style="padding:.375rem 1rem;border-radius:9999px;font-size:.875rem;font-weight:600;cursor:pointer;border:2px solid #e5e7eb;background:#fff;color:#374151">Bestelling</button>
        <button onclick="swFaqFilter('levering')" style="padding:.375rem 1rem;border-radius:9999px;font-size:.875rem;font-weight:600;cursor:pointer;border:2px solid #e5e7eb;background:#fff;color:#374151">Levering</button>
        <button onclick="swFaqFilter('product')" style="padding:.375rem 1rem;border-radius:9999px;font-size:.875rem;font-weight:600;cursor:pointer;border:2px solid #e5e7eb;background:#fff;color:#374151">Producten</button>
        <button onclick="swFaqFilter('retour')" style="padding:.375rem 1rem;border-radius:9999px;font-size:.875rem;font-weight:600;cursor:pointer;border:2px solid #e5e7eb;background:#fff;color:#374151">Retour</button>
      </div>

      <div style="background:#fff;border-radius:1rem;box-shadow:0 1px 4px rgba(0,0,0,0.07);overflow:hidden">
        <div class="sw-faq-item" data-cat="bestelling">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Hoe kan ik een bestelling plaatsen?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Kies je product, voeg het toe aan je winkelwagen en gaa naar de kassa. Je kunt betalen met iDEAL, creditcard, Klarna of andere methoden. Je ontvangt na betaling een bevestigingsmail.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="bestelling">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Kan ik mijn bestelling annuleren of wijzigen?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Neem zo snel mogelijk contact op via info@spotwereld.nl of (0)85 060 09 36. Bestellingen die al in verwerking zijn kunnen niet meer worden aangepast.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="bestelling">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Welke betaalmethoden accepteren jullie?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Wij accepteren iDEAL, Visa, Mastercard, Klarna (achteraf betalen), PayPal en Bancontact. Alle betalingen worden beveiligd verwerkt.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="levering">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Hoe lang duurt de bezorging?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Vandaag voor 22:00 besteld, morgen verzonden. We werken samen met PostNL en DHL voor snelle en betrouwbare bezorging door heel Nederland.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="levering">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Zijn de verzendkosten gratis?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Gratis verzending bij bestellingen van &euro;50 of meer. Onder de &euro;50 rekenen we &euro;4,95 voor standaard bezorging.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="levering">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Kan ik mijn bestelling volgen?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Ja. Zodra je bestelling is verzonden ontvang je een track &amp; trace link per e-mail. Je kunt hiermee de status van je pakket realtime volgen.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="product">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Hoeveel garantie krijg ik op mijn product?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Alle Spotwereld producten hebben standaard 2 jaar garantie. Dit dekt fabricagefouten en materiaaldefecten. Schade door verkeerd gebruik valt niet onder de garantie.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="product">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Zijn de LED spots dimbaar?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Dit verschilt per product. In de productbeschrijving staat duidelijs vermeld of een spot dimbaar is. Let bij dimbare spots op compatibiliteit met je dimmer.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="product">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Wat is het verschil tussen warm wit en koud wit?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">WArm wit (2700&ndash;3000K) geeft een gezellig, sfeervol licht &mdash; ideaal voor woonkamers. Koud wit (4000&ndash;6500K) geeft helder, fris licht &mdash; perfect voor keukens en badkamers. Neutraal wit (3500K) zit er tussenin.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="retour">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Hoe retourneer ik een product?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Stuur een e-mail naar info@spotwereld.nl met je ordernummer en reden van retour. Je ontvangt binnen 1 werkdag een bevestiging. De retourzending is voor rekening van de koper — lever het pakket op eigen kosten in bij een PostNL Servicepunt.</div></div>
        </div>
        <div class="sw-faq-item" data-cat="retour">
          <button class="sw-faq-btn" onclick="swFaqToggle(this)"><span class="sw-faq-q">Wanneer ontvang ik mijn geld terug?</span><span class="sw-faq-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button>
          <div class="sw-faq-answer"><div class="sw-faq-answer-inner">Na ontvangst en controle van je retour storten we het bedrag binnen 5 werkdagen terug op je rekening of creditcard.</div></div>
        </div>
      </div>

      <div style="margin-top:3rem;background:#061f40;border-radius:1rem;padding:2rem;text-align:center">
        <h3 style="color:#fff;font-weight:700;font-size:1.125rem;margin:0 0 .5rem">Staat je vraag er niet bij?</h3>
        <p style="color:#93c5fd;font-size:.9375rem;margin:0 0 1.5rem">Ons team helpt je graag persoonlijk verder.</p>
        <a href="/pages/contact" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;font-weight:700;border-radius:.625rem;text-decoration:none">Neem contact op</a>
      </div>
    </div>
  </div>
</div>
<script>
document.querySelectorAll('.sw-ks-sidebar a').forEach(function(a){
  if(a.pathname===window.location.pathname){a.classList.add('sw-active');}
});
function swFaqToggle(btn){
  var answer=btn.nextElementSibling;
  var icon=btn.querySelector('.sw-faq-icon');
  var isOpen=answer.classList.contains('open');
  document.querySelectorAll('.sw-faq-answer.open').forEach(function(a){a.classList.remove('open');});
  document.querySelectorAll('.sw-faq-icon').forEach(function(i){i.style.transform='rotate(0deg)';});
  if(!isOpen){answer.classList.add('open');icon.style.transform='rotate(180deg)';}
}
function swFaqFilter(cat){
  document.querySelectorAll('.sw-faq-item').forEach(function(item){
    item.style.display=(cat==='all'||item.getAttribute('data-cat')===cat)?'block':'none';
  });
  document.querySelectorAll('#swFaqCats button').forEach(function(btn){
    var isActive=btn.getAttribute('onclick').includes("'"+cat+"'");
    btn.style.background=isActive?'#083D7D':'#fff';
    btn.style.color=isActive?'#fff':'#374151';
    btn.style.borderColor=isActive?'#083D7D':'#e5e7eb';
  });
}
</script>

