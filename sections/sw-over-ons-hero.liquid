<style>
.sw-hero-split{display:grid;grid-template-columns:1fr;min-height:420px}
@media(min-width:900px){.sw-hero-split{grid-template-columns:1fr 1fr;min-height:480px}}
.sw-hero-left{display:flex;flex-direction:column;justify-content:center;padding:3.5rem 2rem 3.5rem 0;padding-left:max(1.5rem,calc((100vw - 1280px)/2 + 1.5rem))}
.sw-hero-right{position:relative;overflow:hidden;min-height:300px}
@media(max-width:899px){.sw-hero-right{min-height:220px;border-radius:0}}
.sw-hero-right img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.sw-hero-badge{display:inline-flex;align-items:center;gap:.4rem;background:#EBF2FF;color:#083D7D;font-size:.75rem;font-weight:700;padding:.3rem .9rem;border-radius:9999px;margin-bottom:1.25rem;width:fit-content}
.sw-hero-trust{display:flex;flex-wrap:wrap;gap:1.25rem;margin-top:2rem}
.sw-hero-trust span{display:flex;align-items:center;gap:.4rem;color:#374151;font-size:.875rem;font-weight:600}
</style>

<div style="background:#f8fafc;border-bottom:1px solid #e5e7eb">
  <div style="max-width:1280px;margin:0 auto">
    <div class="sw-hero-split">
      <div class="sw-hero-left">
        <div class="sw-hero-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#083D7D" stroke-width="2.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          OVER ONS
        </div>
        <h1 style="font-size:clamp(1.875rem,4vw,2.75rem);font-weight:800;color:#0f172a;line-height:1.15;margin:0 0 1rem">Jouw specialist in<br><span style="background:linear-gradient(135deg,#083D7D,#0F6FE3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">premium LED verlichting</span></h1>
        <p style="color:#475569;font-size:1.0625rem;line-height:1.75;margin:0 0 1.75rem;max-width:520px">Wij geloven dat goede verlichting een ruimte transformeert. Spotwereld levert kwalitatieve LED producten — van inbouwspots tot hanglampen — direct aan jou, met persoonlijk advies.</p>
        <div style="display:flex;flex-wrap:wrap;gap:.875rem">
          <a href="/collections/all" style="display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 1.75rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;font-weight:700;border-radius:.625rem;text-decoration:none;font-size:.9375rem">
            Bekijk producten
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/pages/contact" style="display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 1.75rem;background:#fff;color:#083D7D;font-weight:700;border-radius:.625rem;text-decoration:none;font-size:.9375rem;border:1.5px solid #bfdbfe">Contact opnemen</a>
        </div>
        <div class="sw-hero-trust">
          <span><svg width="15" height="15" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 4.9/5 klantbeoordeling</span>
          <span><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0F6FE3" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Gratis verzending v.a. &euro;50</span>
          <span><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0F6FE3" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.47"/></svg> 30 dagen retour</span>
        </div>
      </div>
      <div class="sw-hero-right">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=900&q=80" alt="Spotwereld LED verlichting">
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(8,61,125,0.15),transparent)"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Over Ons Hero",
  "settings": []
}
{% endschema %}
