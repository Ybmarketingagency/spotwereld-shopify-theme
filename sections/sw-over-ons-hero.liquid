<style>
.sw-oo-hero{position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center}
.sw-oo-hero-bg{position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1600210492493-0946911123ea?auto=format&fit=crop&w=1600&q=80');background-size:cover;background-position:center}
.sw-oo-hero-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(6,31,64,0.88) 0%,rgba(8,61,125,0.72) 55%,rgba(6,31,64,0.45) 100%)}
.sw-oo-hero-content{position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:4rem 1.5rem;display:grid;grid-template-columns:1fr;gap:3rem}
@media(min-width:900px){.sw-oo-hero-content{grid-template-columns:1fr 1fr;align-items:center}}
.sw-oo-badge{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,0.12);backdrop-filter:blur(4px);color:#93c5fd;font-size:.75rem;font-weight:700;padding:.35rem 1rem;border-radius:9999px;border:1px solid rgba(255,255,255,0.2);margin-bottom:1.25rem;width:fit-content}
.sw-oo-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(255,255,255,0.12);border-radius:1rem;overflow:hidden;backdrop-filter:blur(8px)}
.sw-oo-stat{padding:1.25rem 1.5rem;background:rgba(255,255,255,0.06);text-align:center}
.sw-oo-stat-num{font-size:2rem;font-weight:800;color:#fff;line-height:1}
.sw-oo-stat-lbl{color:#93c5fd;font-size:.8125rem;margin-top:.25rem}
.sw-oo-trust{display:flex;flex-wrap:wrap;gap:1.25rem;margin-top:2rem}
.sw-oo-trust span{display:flex;align-items:center;gap:.4rem;color:#bfdbfe;font-size:.875rem;font-weight:600}
</style>

<div class="sw-oo-hero">
  <div class="sw-oo-hero-bg"></div>
  <div class="sw-oo-hero-overlay"></div>
  <div class="sw-oo-hero-content">

    <div>
      <div class="sw-oo-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        OVER ONS
      </div>
      <h1 style="font-size:clamp(2rem,4vw,3rem);font-weight:800;color:#fff;line-height:1.15;margin:0 0 1.25rem">Jouw specialist in<br><span style="color:#60a5fa">premium LED verlichting</span></h1>
      <p style="color:#bfdbfe;font-size:1.0625rem;line-height:1.75;margin:0 0 2rem;max-width:500px">Wij geloven dat goede verlichting een ruimte compleet transformeert. Spotwereld levert kwalitatieve LED producten met eerlijke prijzen en persoonlijk advies.</p>
      <div style="display:flex;flex-wrap:wrap;gap:.875rem">
        <a href="/collections/all" style="display:inline-flex;align-items:center;gap:.5rem;padding:.875rem 1.875rem;background:#0F6FE3;color:#fff;font-weight:700;border-radius:.625rem;text-decoration:none;font-size:.9375rem">
          Bekijk producten
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/pages/contact" style="display:inline-flex;align-items:center;gap:.5rem;padding:.875rem 1.875rem;background:transparent;color:#fff;font-weight:700;border-radius:.625rem;text-decoration:none;font-size:.9375rem;border:2px solid rgba(255,255,255,0.35)">Contact opnemen</a>
      </div>
      <div class="sw-oo-trust">
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>4.9/5 klantbeoordeling</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.47"/></svg>30 dagen retour</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>Gratis v.a. &euro;50</span>
      </div>
    </div>

    <div class="sw-oo-stats">
      <div class="sw-oo-stat"><div class="sw-oo-stat-num">500+</div><div class="sw-oo-stat-lbl">Tevreden klanten</div></div>
      <div class="sw-oo-stat"><div class="sw-oo-stat-num">200+</div><div class="sw-oo-stat-lbl">LED producten</div></div>
      <div class="sw-oo-stat"><div class="sw-oo-stat-num">2 jr</div><div class="sw-oo-stat-lbl">Garantie</div></div>
      <div class="sw-oo-stat"><div class="sw-oo-stat-num">4.9★</div><div class="sw-oo-stat-lbl">Score</div></div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Over Ons Hero",
  "settings": []
}
{% endschema %}
