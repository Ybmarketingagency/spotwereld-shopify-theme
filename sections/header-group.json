    "spotwereld_popup_overlay": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div id=\"sw-popup-overlay\" style=\"display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:99998;align-items:center;justify-content:center\"><div id=\"sw-popup-box\" style=\"background:#fff;border-radius:16px;max-width:480px;width:calc(100% - 2rem);margin:1rem;padding:2rem 2rem 1.75rem;position:relative;box-shadow:0 25px 60px rgba(0,0,0,.25);animation:swPopIn .35s cubic-bezier(.34,1.56,.64,1)\"><button onclick=\"swClosePopup()\" style=\"position:absolute;top:.875rem;right:.875rem;background:none;border:none;cursor:pointer;color:#94a3b8;font-size:1.25rem;line-height:1;padding:.25rem\">&#10005;</button><div style=\"text-align:center;margin-bottom:1.25rem\"><div style=\"display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;background:linear-gradient(135deg,#083D7D,#0F6FE3);border-radius:50%;margin-bottom:.875rem\"><span style=\"color:#facc15;font-size:1.5rem\">&#9889;</span></div><h2 style=\"font-size:1.375rem;font-weight:900;color:#061f40;margin:0 0 .5rem;line-height:1.2\">Exclusieve aanbieding!</h2><p style=\"font-size:.95rem;color:#475569;margin:0 0 .25rem\">Ontvang <strong style=\"color:#0F6FE3\">10% korting</strong> op je eerste bestelling</p><p style=\"font-size:.82rem;color:#94a3b8;margin:0\">Vul je e-mailadres in en ontvang je kortingscode direct</p></div><form onsubmit=\"swSubmitPopup(event)\" style=\"display:flex;flex-direction:column;gap:.75rem\"><input type=\"email\" id=\"sw-popup-email\" placeholder=\"jouw@emailadres.nl\" required style=\"padding:.75rem 1rem;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.9375rem;outline:none;transition:border-color .15s\" onfocus=\"this.style.borderColor='#0F6FE3'\" onblur=\"this.style.borderColor='#e2e8f0'\"><button type=\"submit\" style=\"padding:.875rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:.02em\">Ontvang 10% korting &#8594;</button></form><p style=\"text-align:center;font-size:.75rem;color:#cbd5e1;margin:.875rem 0 0\">Geen spam. Uitschrijven kan altijd. &#128274; Veilig &amp; vertrouwd</p></div></div><style>@keyframes swPopIn{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}#sw-popup-overlay.sw-popup-show{display:flex}</style><script>(function(){var shown=sessionStorage.getItem('swPopup');if(shown)return;setTimeout(function(){var el=document.getElementById('sw-popup-overlay');if(el){el.classList.add('sw-popup-show');}},30000);})();function swClosePopup(){var el=document.getElementById('sw-popup-overlay');if(el){el.style.opacity='0';el.style.transition='opacity .2s';setTimeout(function(){el.style.display='none';},200);}sessionStorage.setItem('swPopup','1');}function swSubmitPopup(e){e.preventDefault();var email=document.getElementById('sw-popup-email').value;var box=document.getElementById('sw-popup-box');box.innerHTML='<div style=\"text-align:center;padding:1.5rem 0\"><div style=\"font-size:3rem;margin-bottom:.75rem\">&#127881;</div><h2 style=\"font-size:1.25rem;font-weight:800;color:#061f40;margin:0 0 .5rem\">Bedankt!</h2><p style=\"color:#475569;margin:0 0 .25rem\">Je kortingscode is: <strong style=\"color:#0F6FE3;font-size:1.1rem\">WELKOM10</strong></p><p style=\"font-size:.82rem;color:#94a3b8;margin:0\">We sturen ook een bevestiging naar '+email+'</p><button onclick=\"swClosePopup()\" style=\"margin-top:1.25rem;padding:.75rem 2rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;border:none;border-radius:8px;font-weight:700;cursor:pointer\">Verder winkelen</button></div>';sessionStorage.setItem('swPopup','1');}document.addEventListener('keydown',function(e){if(e.key==='Escape')swClosePopup();});</script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
