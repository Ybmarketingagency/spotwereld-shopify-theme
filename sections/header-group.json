        "custom_liquid": "<div style=\"background:#061f40;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.08)\"><div style=\"display:flex;width:max-content;white-space:nowrap;animation:swTick 28s linear infinite\" aria-label=\"Aankondigingen\"><span style=\"display:inline-flex;align-items:center;gap:0;font-size:.8rem;color:#fff;padding:9px 0\">&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span></span></div></div><style>@keyframes swTick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}.header__row--top{padding-block:0.5rem!important;min-block-size:0!important}.header__row--bottom{padding-block:0.25rem!important;min-block-size:0!important}.header{min-block-size:0!important}.cart-drawer__header{background:#fff!important;padding:1.1rem 1.5rem!important;border-bottom:1px solid #f0f4f8!important}.cart-drawer__heading{font-size:1.2rem!important;font-weight:800!important;color:#061f40!important;letter-spacing:-.01em!important}.cart-items__media-image{width:76px!important;height:76px!important;object-fit:cover!important;border-radius:8px!important;border:1.5px solid #f0f4f8!important}.cart-items__title{font-weight:700!important;color:#061f40!important;font-size:.875rem!important;text-decoration:none!important;line-height:1.3!important}.cart-items__title:hover{color:#0F6FE3!important}.cart-items__remove{color:#d1d5db!important}.cart-items__remove:hover{color:#ef4444!important}.cart-items__price,.cart-items__price .price,.cart-secondary-typography .price{font-weight:800!important;color:#061f40!important}.quantity-selector{border-color:#e2e8f0!important;border-radius:6px!important}.cart-drawer__summary{padding:1rem 1.5rem!important;background:#f8fafc!important;border-top:1px solid #f0f4f8!important}.cart-totals__total-label{font-weight:600!important;color:#374151!important}.cart-totals__total-value{font-weight:800!important;color:#061f40!important;font-size:1.1rem!important}.cart-discount__input{border-radius:6px!important;border:1.5px solid #e2e8f0!important}.cart-discount__button{background:#061f40!important;color:#fff!important;border-radius:6px!important;border:none!important}.cart__ctas{padding:.75rem 1.5rem 1.25rem!important;gap:.5rem!important}.cart__checkout-button{background:linear-gradient(135deg,#083D7D 0%,#0F6FE3 100%)!important;border:none!important;border-radius:8px!important;font-weight:700!important;font-size:1rem!important;padding:.875rem!important;letter-spacing:.02em!important}.cart__checkout-button:hover{background:linear-gradient(135deg,#062d5c 0%,#0a5abf 100%)!important}.cart-items__variant{font-size:.78rem!important;color:#94a3b8!important}.cart-items__variant:not(:first-child){display:none!important}.shopify-payment-button,.shopify-payment-button__button,.product-form__payment-wrapper,accelerated-checkout-component,[class*="dynamic-checkout"]{display:none!important}</style><script>(function(){function swCart(){var d=document.querySelector('cart-items-component');if(!d||d.dataset.sw)return;d.dataset.sw='1';var h=d.querySelector('.cart-drawer__heading');if(h&&/^cart$/i.test(h.textContent.trim()))h.textContent='Winkelmandje';var cBtn=d.querySelector('.cart__checkout-button .button-text,.cart__checkout-button');if(cBtn){var t=cBtn.querySelector('.button-text')||cBtn;if(/check.?out/i.test(t.textContent))t.textContent='Door naar de kassa →';}d.querySelectorAll('span,p,div,strong').forEach(function(el){if(el.children.length)return;var t=el.textContent.trim();if(t==='Estimated total')el.textContent='Geschat totaal';if(t==='Discount')el.textContent='Kortingscode';if(t==='Check out')el.textContent='Door naar de kassa →';if(t==='Duties and taxes included. Shipping is calculated at checkout.')el.textContent='Verzending berekend bij afrekenen.';});var ctas=d.querySelector('.cart__ctas');if(ctas&&!ctas.querySelector('.sw-cart-link')){ctas.insertAdjacentHTML('beforeend','<a href=\"/cart\" class=\"sw-cart-link\" style=\"display:block;text-align:center;padding:.7rem;border:2px solid #061f40;border-radius:8px;font-weight:600;color:#061f40;text-decoration:none;font-size:.9rem;margin-top:.25rem\">Bekijk winkelmand →</a><div style=\"display:flex;gap:1rem;padding:.75rem 0 .25rem;border-top:1px solid #f0f4f8;margin-top:.5rem\"><div style=\"display:flex;align-items:center;gap:.4rem;font-size:.78rem;color:#374151\"><span style=\"color:#16a34a;font-size:1rem\">✓</span>Gratis verzending v.a. €50</div><div style=\"display:flex;align-items:center;gap:.4rem;font-size:.78rem;color:#374151\"><span style=\"color:#16a34a;font-size:1rem\">✓</span>30 dagen retour</div></div>');}d.dataset.sw='done';}document.addEventListener('DOMContentLoaded',function(){setTimeout(swCart,300);setTimeout(swCart,1200);var obs=new MutationObserver(function(){setTimeout(swCart,150);});var t=document.querySelector('cart-drawer-component')||document.body;obs.observe(t,{subtree:true,childList:true,attributes:true,attributeFilter:['open']});});})()</script>",
