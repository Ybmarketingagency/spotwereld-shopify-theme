    "spotwereld_announcement_bar": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"background:#061f40;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.08)\"><div style=\"display:flex;width:max-content;white-space:nowrap;animation:swTick 42s linear infinite\" aria-label=\"Aankondigingen\"><span style=\"display:inline-flex;align-items:center;gap:0;font-size:.8rem;color:#fff;padding:9px 0\">&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9889;&nbsp;Voor 22:00 besteld, morgen in huis&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;<span style=\"color:#facc15;font-weight:700\">&#10003;</span>&nbsp;Gratis verzending bij &euro;50+&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#9733;&nbsp;4.9/5 klantbeoordeling&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span>&nbsp;&#8635;&nbsp;30 dagen retourgarantie&nbsp;<span style=\"opacity:.25;margin:0 1.5rem\">|</span></span></div></div><style>@keyframes swTick{0%{transform:translateX(0)}100%{transform:translateX(-25%)}}.header__row--top{padding-block:0.5rem!important;min-block-size:0!important}.header__row--bottom{padding-block:0.25rem!important;min-block-size:0!important}.header{min-block-size:0!important}.cart-drawer__header{background:#fff!important;padding:1.1rem 1.5rem!important;border-bottom:1px solid #f0f4f8!important}.cart-drawer__heading{font-size:1.2rem!important;font-weight:800!important;color:#061f40!important;letter-spacing:-.01em!important}.cart-items__media-image{width:76px!important;height:76px!important;object-fit:cover!important;border-radius:8px!important;border:1.5px solid #f0f4f8!important}.cart-items__title{font-weight:700!important;color:#061f40!important;font-size:.875rem!important;text-decoration:none!important;line-height:1.3!important}.cart-items__title:hover{color:#0F6FE3!important}.cart-items__remove{color:#d1d5db!important}.cart-items__remove:hover{color:#ef4444!important}.cart-items__price,.cart-items__price .price,.cart-secondary-typography .price{font-weight:800!important;color:#061f40!important}.quantity-selector{border-color:#e2e8f0!important;border-radius:6px!important}.cart-drawer__summary{padding:1rem 1.5rem!important;background:#f8fafc!important;border-top:1px solid #f0f4f8!important}.cart-totals__total-label{font-weight:600!important;color:#374151!important}.cart-totals__total-value{font-weight:800!important;color:#061f40!important;font-size:1.1rem!important}.cart-discount__input{border-radius:6px!important;border:1.5px solid #e2e8f0!important}.cart-discount__button{background:#061f40!important;color:#fff!important;border-radius:6px!important;border:none!important}.cart__ctas{padding:.75rem 1.5rem 1.25rem!important;gap:.5rem!important}.cart__checkout-button{background:linear-gradient(135deg,#083D7D 0%,#0F6FE3 100%)!important;border:none!important;border-radius:8px!important;font-weight:700!important;font-size:1rem!important;padding:.875rem!important;letter-spacing:.02em!important}.cart__checkout-button:hover{background:linear-gradient(135deg,#062d5c 0%,#0a5abf 100%)!important}.cart-items__variant{font-size:.78rem!important;color:#94a3b8!important}.cart-items__variant:not(:first-child){display:none!important}.shopify-payment-button,.shopify-payment-button__button,.product-form__payment-wrapper,accelerated-checkout-component,[class*=\"dynamic-checkout\"]{display:none!important}media-gallery [data-media-type] button[aria-label],media-gallery .product-media-modal-trigger,.product-media-modal,.product-media__zoom-trigger{display:none!important}media-gallery img,media-gallery model-viewer{cursor:default!important}media-gallery [data-media-type]{cursor:default!important}.sw-cart-link{transition:background .15s,color .15s}</style>",
