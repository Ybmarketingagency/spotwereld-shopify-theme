<div id="sw-thumbs-source" style="display:none" data-main-override="{{ sw_main_override }}">
  <div class="sw-thumbs" style="display:flex;gap:8px;margin-top:10px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:4px">
    {%- comment -%} Als sw_main_override actief is: gebruik die als 1ste thumb (geselecteerd) en skip product.media (placeholder) {%- endcomment -%}
    {%- if sw_main_override != blank -%}
      <img src="{{ sw_main_override }}" alt="{{ product.title | escape }}" loading="lazy"
           data-full-src="{{ sw_main_override }}"
           style="width:76px;height:76px;flex-shrink:0;object-fit:cover;border-radius:6px;border:2px solid #061f40;cursor:pointer;transition:all .15s;background:#fff"
           onclick="swSwitchMain(this)">
    {%- elsif product.media.size > 0 -%}
      {%- comment -%} Eerst echte product media {%- endcomment -%}
      {%- for sw_media in product.media limit: 8 -%}
        <img src="{{ sw_media | image_url: width: 150 }}" alt="{{ product.title | escape }}" loading="lazy"
             data-full-src="{{ sw_media | image_url: width: 1200 }}"
             style="width:76px;height:76px;flex-shrink:0;object-fit:cover;border-radius:6px;border:{% if forloop.first %}2px solid #061f40{% else %}1.5px solid #e2e8f0{% endif %};cursor:pointer;transition:all .15s;background:#fff"
             onclick="swSwitchMain(this)">
      {%- endfor -%}
    {%- endif -%}
    {%- comment -%} Daarna extra outledtl thumbnails (lookup-based) {%- endcomment -%}
    {%- if sw_extras != '' -%}
      {%- for sw_url in sw_extras_arr -%}
        <img src="{{ sw_url }}" alt="{{ product.title | escape }}" loading="lazy"
             data-full-src="{{ sw_url }}"
             style="width:76px;height:76px;flex-shrink:0;object-fit:cover;border-radius:6px;border:1.5px solid #e2e8f0;cursor:pointer;transition:all .15s;background:#fff"
             onclick="swSwitchMain(this)">
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback voor producten zonder lookup: clones van hoofdfoto {%- endcomment -%}
      {%- assign sw_main = product.featured_image -%}
      {%- if sw_main != blank and product.media.size < 5 -%}
        {%- assign sw_clones_needed = 5 | minus: product.media.size -%}
        {%- for i in (1..sw_clones_needed) -%}
          <img src="{{ sw_main | image_url: width: 150 }}" alt="{{ product.title | escape }}" loading="lazy"
               data-full-src="{{ sw_main | image_url: width: 1200 }}"
               style="width:76px;height:76px;flex-shrink:0;object-fit:cover;border-radius:6px;border:1.5px solid #e2e8f0;cursor:pointer;transition:all .15s;background:#fff"
               onclick="swSwitchMain(this)">
        {%- endfor -%}
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<!-- SW_SPECS_START -->
<div class="sw-specs-direct" style="max-width:1280px;margin:1.5rem auto 0;padding:0 1.5rem">
  <div class="sw-specs-table" style="margin:1.5rem 0 0;background:#fff;border:1px solid #e8edf4;border-radius:12px;padding:1.5rem 1.75rem 1rem">
    <h3 style="font-size:1rem;font-weight:800;color:#061f40;margin:0 0 .75rem;padding-bottom:.5rem;border-bottom:2px solid #e8edf4">Specificaties</h3>
    {%- comment -%} Bepaal merk uit tag (Aristo/Miran) ipv vendor {%- endcomment -%}
    {%- assign sw_merk = '' -%}
    {%- if product.tags contains 'aristo' -%}{%- assign sw_merk = 'Aristo' -%}
    {%- elsif product.tags contains 'miran' -%}{%- assign sw_merk = 'Miran' -%}
    {%- else -%}
      {%- assign sw_title_parts = product.title | split: '&mdash;' | first | split: ' ' -%}
      {%- assign sw_merk = sw_title_parts | last | strip -%}
      {%- if sw_merk == 'Inbouwspot' or sw_merk == 'LED' or sw_merk == '' -%}{%- assign sw_merk = product.vendor -%}{%- endif -%}
    {%- endif -%}
    {%- assign sw_wattage = product.metafields.custom.wattage | default: '4W of 6W (instelbaar)' -%}
    {%- assign sw_lumen = product.metafields.custom.lumen | default: '400 lm' -%}
    {%- assign sw_garantie = product.metafields.custom.garantie | default: '2 jaar' -%}
    {%- assign sw_levensduur = product.metafields.custom.levensduur | default: '25.000 uur' -%}
    {%- assign sw_materiaal = product.metafields.custom.materiaal | default: 'Aluminium' -%}
    {%- assign sw_driver = product.metafields.custom.driver | default: 'Ja, externe driver' -%}
    {%- assign sw_fitting = product.metafields.custom.fitting | default: 'Ge&iuml;ntegreerd' -%}
    {%- assign sw_ip = product.metafields.custom.ip_waarde | default: 'IP65' -%}
    <table style="width:100%;border-collapse:collapse;font-size:.875rem">
      <tbody>
        {%- if product.selected_or_first_available_variant.sku != blank -%}
        <tr style="border-bottom:1px solid #f0f3f8"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500;width:45%">SKU</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ product.selected_or_first_available_variant.sku }}</td></tr>
        {%- endif -%}
        <tr style="border-bottom:1px solid #f0f3f8;background:#f8fafc"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Merk</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_merk }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Verwachte levensduur</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_levensduur }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8;background:#f8fafc"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Garantie</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_garantie }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Materiaal</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_materiaal }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8;background:#f8fafc"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Wattage</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_wattage }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Lichtopbrengst</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_lumen }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8;background:#f8fafc"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Inclusief driver</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_driver }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">Fitting</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_fitting }}</td></tr>
        <tr style="border-bottom:1px solid #f0f3f8;background:#f8fafc"><td style="padding:.6rem .75rem .6rem 0;color:#6b7280;font-weight:500">IP-waarde</td><td style="padding:.6rem 0;color:#1e293b;font-weight:600">{{ sw_ip }}</td></tr>
        {%- for opt in product.options_with_values -%}
          {%- assign opt_name = opt.name | downcase -%}
          {%- unless opt_name == 'title' or opt_name == 'ip-waarde' -%}
