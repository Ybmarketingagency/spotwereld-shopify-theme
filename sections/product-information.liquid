/* Hide old Klantbeoordelingen statische sectie */
.sw-pr-grid,.sw-old-reviews{display:none!important}
section:has(> div > .sw-pr-grid){display:none!important}
</style>
<script>
(function(){
  function initPR2(){
    var track=document.querySelector('.sw-pr2-track');
    var viewport=document.querySelector('.sw-pr2-viewport');
    var prev=document.querySelector('.sw-pr2-prev');
    var next=document.querySelector('.sw-pr2-next');
    if(!track||!prev||!next)return;
    var pos=0;
    function getStep(){var c=track.querySelector('.sw-pr2-card');return c?c.offsetWidth+16:300;}
    function getMax(){return Math.max(0,track.scrollWidth-viewport.offsetWidth);}
    function upd(){track.style.transform='translateX(-'+pos+'px)';}
    next.addEventListener('click',function(){pos=Math.min(pos+getStep(),getMax());upd();});
    prev.addEventListener('click',function(){pos=Math.max(pos-getStep(),0);upd();});
  }
  if(document.readyState!=='loading')initPR2();
  else document.addEventListener('DOMContentLoaded',initPR2);
  // Hide oude Klantbeoordelingen statische grid via JS backup
  setTimeout(function(){
    document.querySelectorAll('.sw-pr-grid').forEach(function(el){
      var section=el.closest('section');
      if(section)section.style.display='none';
    });
  },200);
})();
</script>

<!-- Spotwereld: Payment icons from Shopify (same as footer) -->
<div id="sw-pay-icons-source" style="display:none">
