</div>

<script>
(function() {
  function initSwProductPage() {
    if (document.querySelector('.sw-vol')) return;
    var form = document.querySelector('form.shopify-product-form');
    if (!form) { form = document.querySelector('button[name="add"]'); }
    if (!form || form.closest('cart-drawer-component, [id*="CartDrawer"], .cart-drawer')) return;

    // Color picker (only for products with color siblings)
    var d = document.getElementById('sw-color-data');
    if (d && !document.querySelector('.sw-color-picker')) {
      var currentHandle = d.dataset.currentHandle;
      var currentColor = d.dataset.currentColor;
      var items = Array.from(d.querySelectorAll('span'));
      if (items.length > 0) {
        var colorBtns = items.map(function(s) {
          if (s.dataset.handle === currentHandle) {
            return '<span style="display:inline-flex;align-items:center;padding:.375rem .875rem;border:2px solid #061f40;border-radius:4px;font-size:.875rem;color:#fff;background:#061f40;font-weight:600">' + s.dataset.color + '</span>';
          }
          return '<a href="' + s.dataset.url + '" style="display:inline-flex;align-items:center;padding:.375rem .875rem;border:1.5px solid #d1d5db;border-radius:4px;font-size:.875rem;color:#061f40;background:#fff;text-decoration:none">' + s.dataset.color + '</a>';
        }).join('');
        var pickerHtml = '<div class="sw-color-picker" style="margin:0 0 1.25rem"><p style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin:0 0 .625rem">Kleur: <strong style="color:#061f40">' + currentColor + '</strong></p><div style="display:flex;flex-wrap:wrap;gap:.5rem">' + colorBtns + '</div></div>';
        form.insertAdjacentHTML('beforebegin', pickerHtml);
      }
    }

    // Volume pricing (clickable, updates quantity)
    var price = {{ product.price | divided_by: 100.0 }};
    var tiers = [
      { qty: 1, label: '1 stuk', discount: 0 },
      { qty: 10, label: '10 stuks', discount: 0.08 },
      { qty: 50, label: '50 stuks', discount: 0.16 }
    ];
    var volHtml = '<div class="sw-vol" style="display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap">';
    tiers.forEach(function(tier, i) {
      var tp = price * (1 - tier.discount);
      var isFirst = i === 0;
      var border = isFirst ? '2px solid #061f40' : '1.5px solid #d1d5db';
      var bg = isFirst ? 'background:#f8faff;' : '';
      volHtml += '<div class="sw-vol-tier" data-qty="' + tier.qty + '" data-index="' + i + '" style="flex:1;min-width:90px;border:' + border + ';border-radius:6px;padding:.5rem .625rem;cursor:pointer;' + bg + 'transition:border-color .15s,background .15s">' +
        '<div style="font-size:.75rem;font-weight:700;color:#061f40">' + tier.label + '</div>' +
        '<div style="font-size:.9rem;font-weight:800;color:#061f40">&euro;' + tp.toFixed(2).replace('.',',') + '/stuk</div>';
      if (tier.discount > 0) {
        volHtml += '<div style="font-size:.7rem;color:#0F6FE3;font-weight:600">▼ ' + Math.round(tier.discount * 100) + '% korting</div>';
      }
      volHtml += '</div>';
    });
    volHtml += '</div>';
    form.insertAdjacentHTML('beforebegin', volHtml);

    // Make volume tiers clickable &mdash; update quantity input
    document.querySelectorAll('.sw-vol-tier').forEach(function(tier) {
      tier.addEventListener('click', function() {
        var qty = parseInt(this.dataset.qty);
        // Update quantity input
        var qtyInput = document.querySelector('input[name="quantity"], quantity-selector input[type="number"]');
        if (qtyInput) {
          qtyInput.value = qty;
          qtyInput.dispatchEvent(new Event('change', {bubbles: true}));
        }
        // Visual: highlight selected tier
        document.querySelectorAll('.sw-vol-tier').forEach(function(t) {
          t.style.border = '1.5px solid #d1d5db';
          t.style.background = '#fff';
        });
        this.style.border = '2px solid #061f40';
        this.style.background = '#f8faff';
      });
    });

    // Stars + Op voorraad after price (universal)
    var priceWrap = Array.from(document.querySelectorAll('.price__regular')).find(function(el) {
      return !el.closest('[id*="cart"], .cart-drawer, .cart-items, .sticky-add-to-cart');
    });
    if (priceWrap && !document.querySelector('.sw-extras')) {
      priceWrap.insertAdjacentHTML('afterend',
        '<div class="sw-extras" style="display:flex;align-items:center;gap:1rem;margin:.5rem 0 .75rem;flex-wrap:wrap">' +
        '<div style="display:flex;align-items:center;gap:.35rem">' +
        '<span style="color:#f59e0b;font-size:1rem;letter-spacing:-.05em">&#9733;&#9733;&#9733;&#9733;&#9733;</span>' +
        '<span style="font-size:.82rem;font-weight:700;color:#1e293b">4.9</span>' +
        '<span style="font-size:.78rem;color:#94a3b8">(47)</span></div>' +
        '<div style="display:flex;align-items:center;gap:.3rem">' +
        '<span style="color:#16a34a;font-size:.9rem">&#9679;</span>' +
        '<span style="color:#16a34a;font-size:.82rem;font-weight:600">Op voorraad</span>' +
        '<span style="color:#94a3b8;font-size:.78rem">&mdash; direct leverbaar</span></div>' +
        '</div>');
    }

    // Hide buy it now
    document.querySelectorAll('.shopify-payment-button, .shopify-payment-button__button, accelerated-checkout-component').forEach(function(el) {
      el.style.setProperty('display','none','important');
    });

    // Specificaties tabel &mdash; inject after payment icons section
    function injectSpecs() {
      if (document.querySelector('.sw-specs-table')) return;
      var specsSource = document.getElementById('sw-specs-source');
      if (!specsSource) return;
      // Try: inject after .sw-delivery or after form parent
      var anchor = document.querySelector('.sw-delivery') || form.parentElement;
      if (anchor) {
        anchor.insertAdjacentHTML('afterend', specsSource.innerHTML);
      }
    }
    injectSpecs();

    // Delivery badge + payment icons + lichtkleur
    if (!document.querySelector('.sw-delivery')) {
      // Find the trust bullets or form parent to insert after
      var trustList = Array.from(document.querySelectorAll('ul')).find(function(ul) {
        return ul.textContent.includes('Gratis verzenden') || ul.textContent.includes('retourrecht');
      });
      var insertTarget = trustList || form.parentElement;

      var deliveryHtml =
        '<div class="sw-delivery" style="display:flex;align-items:center;gap:.5rem;margin:.75rem 0 .25rem;padding:.6rem .875rem;background:#f0fdf4;border-radius:8px;border:1px solid #bbf7d0">' +
        '<span style="color:#16a34a;font-size:1.1rem">&#9679;</span>' +
        '<span style="font-size:.875rem;color:#15803d;font-weight:600">Vandaag besteld, morgen in huis</span>' +
        '</div>';

      // Payment icons &mdash; grab from the hidden Liquid-rendered div
      var paySource = document.getElementById('sw-pay-icons-source');
      if (paySource) {
        deliveryHtml += paySource.innerHTML;
      }

      insertTarget.insertAdjacentHTML('afterend', deliveryHtml);
    }

    // Lichtkleur selector before volume pricing
    if (!document.querySelector('.sw-lichtkleur')) {
      var volEl = document.querySelector('.sw-vol');
      if (volEl) {
        volEl.insertAdjacentHTML('beforebegin',
          '<div class="sw-lichtkleur" style="margin:0 0 1rem">' +
          '<p style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin:0 0 .5rem">Lichtkleur</p>' +
          '<select style="width:100%;padding:.625rem .875rem;border:1.5px solid #d1d5db;border-radius:6px;font-size:.875rem;color:#061f40;background:#fff;cursor:pointer;appearance:auto">' +
          '<option value="2700K">2700K (extra warm-wit)</option>' +
          '<option value="3000K">3000K (warm-wit)</option>' +
          '<option value="4000K">4000K (neutraal-wit)</option>' +
          '</select></div>');
      }
    }
  }

  // Robuuste main-image switcher voor Horizon media-gallery
  window.swSwitchMain = function(thumbEl){
    try {
      var url = thumbEl.dataset.fullSrc;
      if (!url) return;
      document.querySelectorAll('.sw-thumbs img').forEach(function(t){ t.style.border='1.5px solid #e2e8f0'; });
      thumbEl.style.border='2px solid #061f40';
      var mediaCol = document.querySelector('.product-information__media');
      if (!mediaCol) return;
      // Update alle main media img/source elementen (sla onze eigen .sw-thumbs over)
      mediaCol.querySelectorAll('img, source').forEach(function(el){
        if (el.closest && el.closest('.sw-thumbs')) return;
        if (el.tagName === 'SOURCE') {
          el.srcset = url;
        } else {
          el.removeAttribute('srcset');
          el.removeAttribute('data-src');
          el.src = url;
          if (el.loading === 'lazy') el.loading = 'eager';
        }
      });
    } catch(e){ console.log('swSwitchMain err', e); }
  };

  // Thumbnail strip + Specs table (universal)
  function initSwThumbs() {
    var mediaCol = document.querySelector('.product-information__media');
    if (!mediaCol) return;
    // Inject thumbs INSIDE de sticky media-gallery zodat ze meebewegen, niet erover
    var stickyTarget = mediaCol.querySelector('media-gallery') || mediaCol;
    // Skip alleen als thumbs AL in stickyTarget staan (niet in hidden source)
    if (stickyTarget.querySelector('.sw-thumbs')) return;
    var source = document.getElementById('sw-thumbs-source');
    if (!source) return;
    // Main image override (voor producten met placeholder als hoofdfoto)
    var override = source.getAttribute('data-main-override');
    if (override) {
      mediaCol.querySelectorAll('img, source').forEach(function(el){
        if (el.closest && el.closest('.sw-thumbs')) return;
        if (el.tagName === 'SOURCE') {
          el.srcset = override;
        } else {
          el.removeAttribute('srcset');
          el.removeAttribute('data-src');
          el.src = override;
          if (el.loading === 'lazy') el.loading = 'eager';
        }
      });
    }
    // FOUC fix: laat CSS pas main image tonen na override
    document.documentElement.classList.add('sw-main-img-ready-html');
    stickyTarget.insertAdjacentHTML('beforeend', source.innerHTML);
    // Specs tabel onder thumbnails injecteren (alleen als nog niet in mediaCol)
    var specsSource = document.getElementById('sw-specs-source');
    if (specsSource && !mediaCol.querySelector('.sw-specs-table')) {
      mediaCol.insertAdjacentHTML('beforeend', specsSource.innerHTML);
    }
  }

  function initAll(){
    initSwProductPage();
    initSwThumbs();
    if(document.body) document.body.classList.add('sw-product-ready');
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
})();
</script>
<style>
/* Voorkom FOUC: verberg variant picker + product form tot mijn JS klaar is, dan smooth fade-in */
.product-information__details variant-picker-component,
.product-information__details .product-form,
.product-information__details product-form-component{opacity:0;transition:opacity .15s ease-out}
body.sw-product-ready .product-information__details variant-picker-component,
body.sw-product-ready .product-information__details .product-form,
body.sw-product-ready .product-information__details product-form-component{opacity:1}
/* Reserveer ruimte voor injected elementen (kleurpicker + volume) zodat layout niet shift */
.product-information__details:not(.sw-product-ready) .product-form{min-height:280px}
/* Smooth fade voor sw-injected elementen */
.sw-color-picker,.sw-vol,.sw-extras,.sw-delivery,.sw-payment-icons,.sw-specs-table,.sw-thumbs{animation:swFadeIn .2s ease-out}
@keyframes swFadeIn{from{opacity:0}to{opacity:1}}
</style>

{% stylesheet %}
  .sticky-add-to-cart__bar {
    position: fixed;
    bottom: 20px;
    left: 50%;
    opacity: 0;
    transform: translateX(-50%) translateY(calc(100% + 40px));
    z-index: calc(var(--layer-sticky) - 1); /* Below sticky header */
    display: block;
    width: 600px;
    border-radius: calc(
      var(--style-border-radius-buttons-primary) + min(var(--padding-sm), var(--style-border-radius-buttons-primary))
    );
    box-shadow: var(--shadow-popover);
    padding: var(--padding-sm);
    /* Layout styling */
    display: flex;
    align-items: center;
    gap: var(--gap-md);

    @starting-style {
      opacity: 0;
      transform: translateX(-50%) translateY(calc(100% + 40px));
    }

    &::before {
      --border: 2px;
      content: '';
      position: absolute;
      inset: calc(var(--border) * -1);
      background: linear-gradient(var(--color-background) 0 100%), linear-gradient(hsl(0 0% 0% / 0.15) 0 100%);
      background-clip: content-box, border-box;
      border: var(--border) solid #0000;
      border-radius: inherit;
      z-index: -1;
      backdrop-filter: blur(20px) saturate(180%) brightness(1.5);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .sticky-add-to-cart__bar {
      transition-property: transform, opacity, display;
      transition-duration: 0.3s;
      transition-timing-function: var(--ease-out-quad);
      transition-behavior: allow-discrete;
    }
  }

  .sticky-add-to-cart__bar[data-stuck='true'] {
    transform: translateX(-50%) translateY(0%);
    opacity: 1;
  }

  sticky-add-to-cart:not([data-variant-available='true']) .sticky-add-to-cart__bar {
    opacity: 0;
    transform: translateX(-50%) translateY(calc(100% + 40px));
    display: none;
  }

  .sticky-add-to-cart__info[data-has-image='false'] {
    padding-left: var(--padding-lg);
  }

  .sticky-add-to-cart__image {
    flex-shrink: 0;
    aspect-ratio: 1;
    height: var(--height-buy-buttons);
    overflow: hidden;
    border-radius: var(--style-border-radius-buttons-primary);
    background: var(--color-background-secondary);
  }

  .sticky-add-to-cart__image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sticky-add-to-cart__info {
    flex: 1;
    min-width: 0; /* Allow text truncation */
  }

  .sticky-add-to-cart__title {
    font-size: var(--font-paragraph-medium--size);
    font-weight: var(--font-weight-semibold);
    line-height: var(--font-paragraph--line-height);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sticky-add-to-cart__variant {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-paragraph-small--size);
    margin-top: var(--margin-3xs);
  }

  .sticky-add-to-cart__price {
    font-weight: var(--font-weight-semibold);
  }

  .sticky-add-to-cart__button {
    height: var(--height-buy-buttons);
    position: relative;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .sticky-add-to-cart__bar {
      bottom: 0;
      width: 100%;
      max-width: none;
      border-radius: 0;

      &::before {
        --border: 1px;
      }
    }

    .sticky-add-to-cart__bar .add-to-cart-text__content {
      display: none;
    }

    .sticky-add-to-cart__info[data-has-image='false'] {
      padding-left: 0;
    }

    .sticky-add-to-cart__title {
      font-size: var(--font-paragraph--size);
    }

    .sticky-add-to-cart__button {
      padding: var(--padding-lg);
    }

    .sticky-add-to-cart__price {
      font-size: var(--font-paragraph-small--size);
    }

    .sticky-add-to-cart__button {
      width: var(--height-buy-buttons);
    }

    sticky-add-to-cart:not([data-variant-available='true']) .add-to-cart-text__content {
      display: initial;
    }

    sticky-add-to-cart:not([data-variant-available='true']) .sticky-add-to-cart__button {
      width: auto;
    }
  }

  /* Small mobile - hide text content and compare price */
  @media screen and (max-width: 389px) {
    .sticky-add-to-cart__bar {
      .compare-at-price {
        display: none;
      }
    }

    .sticky-add-to-cart__title {
      display: none;
    }

    /* For product with only default variant show title */
    .sticky-add-to-cart__info[data-singleton='true'] .sticky-add-to-cart__title {
      display: block;
    }

    /* For single variant show title and variant, truncate both. variant should be identifiable with truncation */
    .sticky-add-to-cart__info[data-single-option='true'] .sticky-add-to-cart__title {
      display: block;
    }

    .sticky-add-to-cart__info[data-single-option='true'] .sticky-add-to-cart__variant {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
  /* Hide only extra variant labels (Dimbaar/IP-waarde) in cart, keep product row visible */
  .cart-items__variant-option:not(:first-child) {
    display: none !important;
  }
  /* Hide Buy it now */
  .shopify-payment-button,
  .shopify-payment-button__button,
  .product-form__payment-wrapper,
  accelerated-checkout-component {
    display: none !important;
  }
  /* Thumbnails inside sticky gallery */
  media-gallery {
    overflow: visible !important;
  }
  .product-information__media {
    position: relative;
  }
  .sw-thumbs {
    position: relative;
    z-index: 100;
    background: #fff;
    padding-top: 8px;
    clear: both;
  }
  /* Spotwereld: gradient buy button */
  form.cart-form button[type="submit"],
  button[name="add"] {
    background: linear-gradient(135deg, #083D7D 0%, #0F6FE3 100%) !important;
    border: none !important;
    border-radius: 8px !important;
    font-weight: 700 !important;
    letter-spacing: 0.02em !important;
  }
  form.cart-form button[type="submit"]:hover,
  button[name="add"]:hover {
    background: linear-gradient(135deg, #062d5c 0%, #0a5abf 100%) !important;
  }
  .shopify-payment-button__button--unbranded {
    background: linear-gradient(135deg, #0F6FE3 0%, #083D7D 100%) !important;
    border-radius: 8px !important;
  }
  .sw-color-picker a:hover {
    border-color: #061f40 !important;
    color: #061f40 !important;
    background: #f0f4ff !important;
  }
  .sw-pay-svg {
    height: 24px;
    width: auto;
  }
  .sw-lichtkleur-select:focus {
    border-color: #061f40;
    outline: none;
    box-shadow: 0 0 0 2px rgba(6,31,64,0.1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_information",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "content-center-aligned",
          "label": "t:options.page"
        },
        {
          "value": "content-full-width",
          "label": "t:options.full"
        }
      ],
      "default": "content-center-aligned"
    },
    {
      "type": "select",
      "id": "desktop_media_position",
      "label": "t:settings.media_position",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "equal_columns",
      "label": "t:settings.equal_columns",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "limit_details_width",
      "label": "t:settings.limit_product_details_width",
      "default": false,
      "visible_if": "{{ section.settings.equal_columns }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_add_to_cart",
      "label": "t:settings.enable_sticky_add_to_cart",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
