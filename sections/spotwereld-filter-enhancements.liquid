<!-- v3 cache bust -->
<style>
.sw-coll-stock{position:absolute;top:.5rem;right:.5rem;z-index:5;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem}
.sw-coll-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a}
.sw-coll-stars{color:#f59e0b;font-size:.78rem;letter-spacing:-.05em;margin:.3rem 0 .1rem;line-height:1}
.sw-coll-stars span{color:#94a3b8;font-size:.72rem;margin-left:.25rem;letter-spacing:0}
.sw-coll-cart,.sw-coll-bekijk{display:flex!important;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;padding:.65rem .75rem!important;font-weight:700!important;font-size:.82rem!important;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em;margin-top:.5rem;text-decoration:none!important;line-height:1;box-sizing:border-box}
.sw-coll-cart:hover,.sw-coll-bekijk:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}
.sw-coll-cart svg,.sw-coll-bekijk svg{flex-shrink:0;transition:transform .2s}
.sw-coll-bekijk:hover svg{transform:translateX(3px)}
.product-card{position:relative}
.quick-add{display:block!important;opacity:1!important;visibility:visible!important;transform:none!important;position:static!important}
.quick-add__button{background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;font-weight:700!important;letter-spacing:.01em!important;padding:.65rem .75rem!important;width:100%!important;font-size:.82rem!important;display:flex!important;align-items:center;justify-content:center;gap:.4rem}
.quick-add__button:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}
.product-card .product-card__content,.product-card__content{padding-bottom:.5rem}
.product-card__title,.product-grid__item .product-card__title{font-size:.875rem!important;font-weight:600!important;color:#1e293b!important}
.product-card .price{font-weight:800!important;color:#061f40!important;font-size:1.05rem!important}
</style>
<script>
(function(){
  function enhanceColCards(){
    var cards = document.querySelectorAll('.product-card');
    cards.forEach(function(card){
      if(card.dataset.swEnh) return;
      card.dataset.swEnh = '1';
      // Op voorraad badge
      if(!card.querySelector('.sw-coll-stock')){
        var mediaContainer = card.querySelector('.product-media-container, .card-gallery, .product-media');
        if(mediaContainer){
          mediaContainer.style.position = 'relative';
          var stock = document.createElement('span');
          stock.className = 'sw-coll-stock';
          stock.textContent = 'Op voorraad';
          mediaContainer.appendChild(stock);
        }
      }
      // Sterren rating onder de titel
      if(!card.querySelector('.sw-coll-stars')){
        var title = card.querySelector('.product-card__title, [class*="product-card__title"], product-title, .product-title');
        if(title){
          var stars = document.createElement('div');
          stars.className = 'sw-coll-stars';
          stars.innerHTML = '&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';
          var titleEl = title.tagName === 'PRODUCT-TITLE' ? title : title;
          titleEl.insertAdjacentElement('afterend', stars);
        }
      }
      // Vervang Quick-add knop door "Bekijk Product" link
      var qaContainer = card.querySelector('.quick-add');
      var productLink = card.querySelector('.product-card__link, a[href*="/products/"]');
      if(qaContainer && productLink && !qaContainer.dataset.swReplaced){
        qaContainer.dataset.swReplaced = '1';
        var prodHref = productLink.getAttribute('href');
        var bekijkBtn = document.createElement('a');
        bekijkBtn.href = prodHref;
        bekijkBtn.className = 'sw-coll-bekijk';
        bekijkBtn.innerHTML = 'Bekijk Product <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
        qaContainer.style.display = 'none';
        qaContainer.parentNode.insertBefore(bekijkBtn, qaContainer.nextSibling);
      }
    });
  }
  function rnK(){
    document.querySelectorAll('.facets__label,.facets__summary .facets__label').forEach(function(el){
      var t=el.textContent.trim();
      if(t==='Kleur'||t==='Color')el.textContent='Kleur behuizing';
    });
  }
  function findFacetByName(name){
    var details=document.querySelectorAll('details.facets__item,.facets__item details,.facets__item');
    for(var i=0;i<details.length;i++){
      var lbl=details[i].querySelector('.facets__label');
      if(lbl&&lbl.textContent.trim().toLowerCase().indexOf(name.toLowerCase())>-1)return details[i];
    }
    return null;
  }
  function addNeeOption(){
    if(document.querySelector('.sw-fake-nee'))return;
    var dimFacet=findFacetByName('Dimbaar');
    if(!dimFacet)return;
    var list=dimFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');
    if(!list)return;
    var existingItem=list.querySelector('.facets__inputs-list-item,li');
    if(!existingItem)return;
    var hasNee=Array.from(list.querySelectorAll('label,.checkbox__label-text')).some(function(el){return el.textContent.trim()==='Nee';});
    if(hasNee)return;
    var clone=existingItem.cloneNode(true);
    clone.classList.add('sw-fake-nee');
    var lblTxt=clone.querySelector('.checkbox__label-text,label span,label');
    if(lblTxt)lblTxt.textContent='Nee';
    var input=clone.querySelector('input');
    if(input){input.disabled=true;input.checked=false;input.value='Nee';}
    var countEl=clone.querySelector('.facets__count,.facets__item-count');
    if(countEl)countEl.textContent='(0)';
    clone.style.opacity='.55';
    list.appendChild(clone);
  }
  function splitLichtkleur(){
    if(document.querySelector('.sw-fake-lk-2700'))return;
    var lkFacet=findFacetByName('Lichtkleur');
    if(!lkFacet)return;
    var list=lkFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');
    if(!list)return;
    var origItem=null;
    var origInputName='filter.p.product_option.lichtkleur';
    var origInputValue='Instelbaar (2700K-4000K)';
    Array.from(list.querySelectorAll('.facets__inputs-list-item,li')).forEach(function(it){
      var t=it.textContent;
      if(t.indexOf('Instelbaar')>-1||t.indexOf('2700K-4000K')>-1){
        origItem=it;
        var oi=it.querySelector('input');
        if(oi){origInputName=oi.name||origInputName;origInputValue=oi.value||origInputValue;}
        it.style.display='none';
      }
    });
    if(!origItem)origItem=list.querySelector('.facets__inputs-list-item,li');
    if(!origItem)return;
    [{c:'2700',n:'2700K (Warm wit)'},{c:'3000',n:'3000K (Sfeer wit)'},{c:'4000',n:'4000K (Daglicht)'}].forEach(function(opt){
      var clone=origItem.cloneNode(true);
      clone.style.display='';
      clone.classList.add('sw-fake-lk-'+opt.c);
      var lbl=clone.querySelector('.checkbox__label-text,label span');
      if(lbl)lbl.textContent=opt.n;
      var input=clone.querySelector('input');
      if(input){input.name=origInputName;input.value=origInputValue;input.checked=false;}
      list.appendChild(clone);
    });
  }
  function addVormFilter(){
    if(document.querySelector('.sw-vorm-facet'))return;
    var kleurFacet=findFacetByName('Kleur');
    if(!kleurFacet)return;
    var vormHtml='<details class="facets__item sw-vorm-facet" open><summary class="facets__summary"><span class="facets__label">Vorm</span><span class="facets__icon"></span></summary><div class="facets__panel"><ul class="facets__inputs facets__inputs-list">'+
      [{v:'rond',n:'Rond'},{v:'vierkant',n:'Vierkant'},{v:'rechthoek',n:'Rechthoek'}].map(function(o){
        return '<li class="facets__inputs-list-item"><label class="checkbox"><input type="checkbox" class="checkbox__input" name="filter.p.tag" value="vorm-'+o.v+'"><span class="checkbox__label"><span class="icon-checkmark"></span><span class="checkbox__label-text">'+o.n+'</span></span></label></li>';
      }).join('')+'</ul></div></details>';
    kleurFacet.insertAdjacentHTML('beforebegin',vormHtml);
    var vormInputs=document.querySelectorAll('.sw-vorm-facet input');
    var urlParams=new URLSearchParams(window.location.search);
    var activeTags=urlParams.getAll('filter.p.tag');
    vormInputs.forEach(function(inp){
      if(activeTags.indexOf(inp.value)>-1)inp.checked=true;
      inp.addEventListener('change',function(){
        var params=new URLSearchParams(window.location.search);
        var tags=params.getAll('filter.p.tag');
        params.delete('filter.p.tag');
        if(inp.checked){tags.push(inp.value);}
        else{tags=tags.filter(function(t){return t!==inp.value;});}
        tags.forEach(function(t){params.append('filter.p.tag',t);});
        window.location.search=params.toString();
      });
    });
  }
  function runAll(){rnK();addNeeOption();splitLichtkleur();addVormFilter();enhanceColCards();}
  document.addEventListener('DOMContentLoaded',runAll);
  setTimeout(runAll,300);
  setTimeout(runAll,900);
  setTimeout(runAll,2000);
  document.addEventListener('shopify:section:load',runAll);
  var obs=new MutationObserver(function(muts){
    var hasFacetChange=muts.some(function(m){
      return Array.from(m.addedNodes).some(function(n){
        return n.nodeType===1&&(n.classList&&(n.classList.contains('facets__item')||n.querySelector&&n.querySelector('.facets__item')));
      });
    });
    if(hasFacetChange)runAll();else rnK();
  });
  document.addEventListener('DOMContentLoaded',function(){
    var f=document.querySelector('.facets-block-wrapper--vertical,.facets__form-wrapper');
    if(f)obs.observe(f,{childList:true,subtree:true});
  });
})();
</script>

{% schema %}
{
  "name": "Filter Enhancements",
  "settings": [],
  "presets": [
    { "name": "Filter Enhancements" }
  ]
}
{% endschema %}
