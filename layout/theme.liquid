<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- comment -%} Spotwereld favicon: gele lamp op blauwe achtergrond - overrules Shopify Brand setting {%- endcomment -%}
    <link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/2ROeTRS.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/2ROeTRS.png">
    <link rel="apple-touch-icon" sizes="180x180" href="https://i.imgur.com/2ROeTRS.png">
    <link rel="shortcut icon" href="https://i.imgur.com/2ROeTRS.png">

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {%- if request.page_type == 'collection' or request.page_type == 'search' -%}
    <script>
    (function(){
      function rnK(){document.querySelectorAll('.facets__label,.facets__summary .facets__label').forEach(function(el){var t=el.textContent.trim();if(t==='Kleur'||t==='Color')el.textContent='Kleur behuizing';});}
      function findFacetByName(name){var details=document.querySelectorAll('details.facets__item,.facets__item details,.facets__item');for(var i=0;i<details.length;i++){var lbl=details[i].querySelector('.facets__label');if(lbl&&lbl.textContent.trim().toLowerCase().indexOf(name.toLowerCase())>-1)return details[i];}return null;}
      function addNeeOption(){if(document.querySelector('.sw-fake-nee'))return;var dimFacet=findFacetByName('Dimbaar');if(!dimFacet)return;var list=dimFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var existingItem=list.querySelector('.facets__inputs-list-item,li');if(!existingItem)return;var hasNee=Array.from(list.querySelectorAll('label,.checkbox__label-text')).some(function(el){return el.textContent.trim()==='Nee';});if(hasNee)return;var clone=existingItem.cloneNode(true);clone.classList.add('sw-fake-nee');var lblTxt=clone.querySelector('.checkbox__label-text,label span,label');if(lblTxt)lblTxt.textContent='Nee';var input=clone.querySelector('input');if(input){input.disabled=true;input.checked=false;input.value='Nee';}var countEl=clone.querySelector('.facets__count,.facets__item-count');if(countEl)countEl.textContent='(0)';clone.style.opacity='.55';list.appendChild(clone);}
      function splitLichtkleur(){if(document.querySelector('.sw-fake-lk-2700'))return;var lkFacet=findFacetByName('Lichtkleur');if(!lkFacet)return;var list=lkFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var origItem=null;var origInputName='filter.p.product_option.lichtkleur';var origInputValue='Instelbaar (2700K-4000K)';Array.from(list.querySelectorAll('.facets__inputs-list-item,li')).forEach(function(it){var t=it.textContent;if(t.indexOf('Instelbaar')>-1||t.indexOf('2700K-4000K')>-1){origItem=it;var oi=it.querySelector('input');if(oi){origInputName=oi.name||origInputName;origInputValue=oi.value||origInputValue;}it.style.display='none';}});if(!origItem)origItem=list.querySelector('.facets__inputs-list-item,li');if(!origItem)return;[{c:'2700',n:'2700K (Warm wit)'},{c:'3000',n:'3000K (Sfeer wit)'},{c:'4000',n:'4000K (Daglicht)'}].forEach(function(opt){var clone=origItem.cloneNode(true);clone.style.display='';clone.classList.add('sw-fake-lk-'+opt.c);var lbl=clone.querySelector('.checkbox__label-text,label span');if(lbl)lbl.textContent=opt.n;var input=clone.querySelector('input');if(input){input.name=origInputName;input.value=origInputValue;input.checked=false;}list.appendChild(clone);});}
      function addVormFilter(){if(document.querySelector('.sw-vorm-facet'))return;var kleurFacet=findFacetByName('Kleur');if(!kleurFacet)return;var vormHtml='<details class="facets__item sw-vorm-facet" open><summary class="facets__summary"><span class="facets__label">Vorm</span><span class="facets__icon"></span></summary><div class="facets__panel"><ul class="facets__inputs facets__inputs-list">'+[{v:'rond',n:'Rond'},{v:'vierkant',n:'Vierkant'},{v:'rechthoek',n:'Rechthoek'}].map(function(o){return '<li class="facets__inputs-list-item"><label class="checkbox"><input type="checkbox" class="checkbox__input" name="filter.p.tag" value="vorm-'+o.v+'"><span class="checkbox__label"><span class="icon-checkmark"></span><span class="checkbox__label-text">'+o.n+'</span></span></label></li>';}).join('')+'</ul></div></details>';kleurFacet.insertAdjacentHTML('beforebegin',vormHtml);var vormInputs=document.querySelectorAll('.sw-vorm-facet input');var urlParams=new URLSearchParams(window.location.search);var activeTags=urlParams.getAll('filter.p.tag');vormInputs.forEach(function(inp){if(activeTags.indexOf(inp.value)>-1)inp.checked=true;inp.addEventListener('change',function(){var params=new URLSearchParams(window.location.search);var tags=params.getAll('filter.p.tag');params.delete('filter.p.tag');if(inp.checked){tags.push(inp.value);}else{tags=tags.filter(function(t){return t!==inp.value;});}tags.forEach(function(t){params.append('filter.p.tag',t);});window.location.search=params.toString();});});}
      function runAll(){rnK();addNeeOption();splitLichtkleur();addVormFilter();}
      document.addEventListener('DOMContentLoaded',runAll);
      setTimeout(runAll,300);setTimeout(runAll,900);setTimeout(runAll,2000);
      document.addEventListener('shopify:section:load',runAll);
      var obs=new MutationObserver(function(){runAll();});
      document.addEventListener('DOMContentLoaded',function(){var f=document.querySelector('.facets-block-wrapper--vertical,.facets__form-wrapper');if(f)obs.observe(f,{childList:true,subtree:true});});
    })();
    </script>
    <style>
    /* Collection page product card enhancements */
    .product-grid .product-card,
    product-card.product-card,
    results-list .product-card{position:relative}
    .product-grid .product-card .product-card__information,
    product-card.product-card .product-card__information{padding-top:.5rem!important}
    .sw-coll-stock{position:absolute;top:.5rem;right:.5rem;z-index:5;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem;backdrop-filter:blur(4px)}
    .sw-coll-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a}
    .sw-coll-stars{color:#f59e0b;font-size:.78rem;letter-spacing:-.05em;margin:.25rem 0;line-height:1}
    .sw-coll-stars span{color:#94a3b8;font-size:.72rem;margin-left:.25rem;letter-spacing:0}
    .sw-coll-cart{display:flex;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;padding:.6rem .75rem!important;font-weight:700!important;font-size:.82rem!important;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em;margin-top:.5rem;text-decoration:none;line-height:1}
    .sw-coll-cart:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}
    .sw-coll-cart svg{flex-shrink:0}
    .product-grid product-form-component button[type="submit"]:not(.sw-coll-cart),
    .product-grid form button[name="add"]:not(.sw-coll-cart){background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;font-weight:700!important;letter-spacing:.01em!important}
    .product-card__information .price{font-weight:800!important;color:#061f40!important;font-size:1.05rem!important}
    .product-card{position:relative}
    .sw-cb-stock{position:absolute;top:.5rem;right:.5rem;z-index:5;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem}
    .sw-cb-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a;display:inline-block;margin-right:.25rem}
    .sw-cb-stars{color:#f59e0b;font-size:.78rem;letter-spacing:-.05em;margin:.3rem 0 .1rem;line-height:1}
    .sw-cb-stars span{color:#94a3b8;font-size:.72rem;margin-left:.25rem;letter-spacing:0}
    .sw-cb-bekijk{display:flex!important;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;padding:.65rem .75rem!important;font-weight:700!important;font-size:.82rem!important;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em;margin-top:.5rem;text-decoration:none!important;line-height:1;box-sizing:border-box}
    .sw-cb-bekijk:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}
    .sw-cb-bekijk svg{flex-shrink:0;transition:transform .2s}
    .sw-cb-bekijk:hover svg{transform:translateX(3px)}
    .quick-add{display:none!important}
    </style>
    {%- if request.page_type == 'collection' or request.page_type == 'search' -%}
    <script id="sw-card-boost-v5">
    (function swBoostV5(){
      function boost(){
        var cards = document.querySelectorAll('.product-card');
        cards.forEach(function(card){
          if(card.dataset.swCb)return;
          card.dataset.swCb='1';
          var mc = card.querySelector('.product-media-container, .card-gallery, .product-media');
          if(mc && !card.querySelector('.sw-cb-stock')){
            mc.style.position='relative';
            var st=document.createElement('span');
            st.className='sw-cb-stock';
            st.textContent='Op voorraad';
            mc.appendChild(st);
          }
          var ti = card.querySelector('.product-card__title, product-title, .product-title');
          if(ti && !card.querySelector('.sw-cb-stars')){
            var sr=document.createElement('div');
            sr.className='sw-cb-stars';
            sr.innerHTML='&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';
            ti.insertAdjacentElement('afterend', sr);
          }
          var pl = card.querySelector('.product-card__link, a[href*="/products/"]');
          if(pl && !card.querySelector('.sw-cb-bekijk')){
            var bk=document.createElement('a');
            bk.href=pl.getAttribute('href');
            bk.className='sw-cb-bekijk';
            bk.innerHTML='Bekijk Product <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
            var ct = card.querySelector('.product-card__content') || card;
            ct.appendChild(bk);
          }
        });
      }
      if(document.readyState!=='loading')boost();
      else document.addEventListener('DOMContentLoaded', boost);
      [300,800,1500,3000].forEach(function(t){setTimeout(boost,t);});
      document.addEventListener('shopify:section:load', boost);
      var obs=new MutationObserver(function(){boost();});
      setTimeout(function(){
        var g=document.querySelector('.product-grid,results-list');
        if(g)obs.observe(g,{childList:true,subtree:true});
      },500);
    })();
    </script>
    <script>
    (function(){
      function enhanceCards(){
        var cards = document.querySelectorAll('.product-card, product-card');
        cards.forEach(function(card){
          if(card.dataset.swEnhanced) return;
          card.dataset.swEnhanced = '1';
          // Op voorraad badge
          if(!card.querySelector('.sw-coll-stock')){
            var stock = document.createElement('span');
            stock.className = 'sw-coll-stock';
            stock.textContent = 'Op voorraad';
            var imgWrap = card.querySelector('.product-card__media, .product-card-gallery, .product-card__gallery, a img')?.closest('a, .product-card__media, .product-card-gallery') || card;
            (imgWrap.parentElement || card).style.position = 'relative';
            imgWrap.appendChild ? imgWrap.appendChild(stock) : card.appendChild(stock);
          }
          // Sterren rating
          if(!card.querySelector('.sw-coll-stars')){
            var stars = document.createElement('div');
            stars.className = 'sw-coll-stars';
            stars.innerHTML = '&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';
            var title = card.querySelector('.product-card__title, .product-title, [class*="title"]');
            if(title) title.insertAdjacentElement('afterend', stars);
          }
          // In Winkelwagen knop - vervang de standaard button als die er is
          var existingCart = card.querySelector('.sw-coll-cart');
          if(!existingCart){
            // Style existing button OR add new one
            var existingBtn = card.querySelector('form[action*="/cart/add"] button, button[name="add"]');
            if(existingBtn){
              existingBtn.classList.add('sw-coll-cart');
              existingBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>In Winkelwagen';
            }
          }
        });
      }
      function init(){enhanceCards();}
      if(document.readyState!=='loading')init();
      else document.addEventListener('DOMContentLoaded',init);
      setTimeout(enhanceCards,500);
      setTimeout(enhanceCards,1500);
      document.addEventListener('shopify:section:load',enhanceCards);
      var obs=new MutationObserver(function(muts){var hasNewCards=muts.some(function(m){return Array.from(m.addedNodes).some(function(n){return n.nodeType===1&&(n.matches&&(n.matches('.product-card, product-card')||n.querySelector&&n.querySelector('.product-card, product-card')));});});if(hasNewCards)enhanceCards();});
      document.addEventListener('DOMContentLoaded',function(){var grid=document.querySelector('.product-grid, results-list');if(grid)obs.observe(grid,{childList:true,subtree:true});});
    })();
    </script>
    {%- endif -%}
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
