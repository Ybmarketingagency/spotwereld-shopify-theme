<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- comment -%} Spotwereld favicon: blauwe O-spotlight uit logo - overrules Shopify Brand setting {%- endcomment -%}
    <link rel="icon" type="image/png" sizes="32x32" href="https://i.imgur.com/wwoqIM6.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://i.imgur.com/wwoqIM6.png">
    <link rel="apple-touch-icon" sizes="180x180" href="https://i.imgur.com/wwoqIM6.png">
    <link rel="shortcut icon" href="https://i.imgur.com/wwoqIM6.png">

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    {% assign sw_vg = false %}
    {% if template == 'page.inbouwspots-plaatsen' or template == 'page.led-dimmer-kiezen' or template == 'page.tl-naar-led' %}
      {% assign sw_vg = true %}
    {% endif %}

    {% if sw_vg %}
    <style>
    .sw-vg-outer{background:#f3f4f6;min-height:60vh;padding-bottom:4rem}
    .sw-vg-wrap{max-width:1280px;margin:0 auto;padding:2.5rem 1.5rem 0;display:grid;grid-template-columns:1fr;gap:2rem;align-items:start}
    @media(min-width:768px){.sw-vg-wrap{grid-template-columns:230px 1fr;gap:2.5rem}}

    /* Sidebar card */
    .sw-vg-sidebar{align-self:start;position:sticky;top:7rem;background:#fff;border-radius:1rem;border:1px solid #e5e7eb;padding:1.25rem 1rem;box-shadow:0 1px 4px rgba(0,0,0,.05)}
    .sw-vg-sidebar-head{font-size:.6875rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.1em;margin:0 0 1rem;padding:0 .375rem}
    .sw-vg-nav{display:flex;flex-direction:column;gap:.125rem}
    .sw-vg-nav a{display:block;padding:.5rem .625rem;border-radius:.5rem;color:#374151;font-size:.9rem;text-decoration:none;font-weight:500;transition:background .15s,color .15s;line-height:1.4}
    .sw-vg-nav a:hover{background:#EBF2FF;color:#0F6FE3}
    .sw-vg-nav a.sw-active{background:#EBF2FF;color:#083D7D;font-weight:700;border-left:3px solid #0F6FE3;padding-left:calc(.625rem - 3px)}
    .sw-vg-nav-cat{font-size:.65rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;padding:.5rem .625rem .2rem;margin-top:.25rem;display:block}
    .sw-vg-nav-divider{height:1px;background:#f3f4f6;margin:.5rem .25rem}
    .sw-vg-sidebar-cta{margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid #f3f4f6}
    .sw-vg-sidebar-cta a{display:flex;align-items:center;justify-content:center;gap:.4rem;padding:.7rem 1rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;font-weight:700;border-radius:.625rem;text-decoration:none;font-size:.875rem}

    /* Content card */
    .sw-vg-content{min-width:0;background:#fff;border-radius:1rem;border:1px solid #e5e7eb;box-shadow:0 1px 4px rgba(0,0,0,.04);overflow:hidden}
    .sw-vg-content .sw-guide{border-radius:0!important;box-shadow:none!important;border:none!important;max-width:100%!important;padding:2rem 2.25rem 3rem!important}
    @media(max-width:767px){.sw-vg-content .sw-guide{padding:1.5rem 1.25rem 2.5rem!important}}
    </style>
    {% endif %}

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {% if sw_vg %}
        <div class="sw-vg-outer">
          <div class="sw-vg-wrap">
            <aside class="sw-vg-sidebar">
              <p class="sw-vg-sidebar-head">Verlichtingsgids</p>
              <nav class="sw-vg-nav">
                <span class="sw-vg-nav-cat">Installatie</span>
                <a href="/pages/inbouwspots-plaatsen">Inbouwspots plaatsen</a>
                <a href="/pages/tl-naar-led">TL naar LED vervangen</a>
                <div class="sw-vg-nav-divider"></div>
                <span class="sw-vg-nav-cat">Keuze &amp; advies</span>
                <a href="/pages/led-dimmer-kiezen">De juiste LED-dimmer kiezen</a>
                <div class="sw-vg-nav-divider"></div>
              </nav>
              <div class="sw-vg-sidebar-cta">
                <a href="/collections/inbouwspots">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                  Bekijk alle inbouwspots
                </a>
              </div>
            </aside>
            <div class="sw-vg-content">
              {{ content_for_layout }}
            </div>
          </div>
        </div>
        <script>
        document.querySelectorAll('.sw-vg-nav a').forEach(function(a){
          if(a.pathname===window.location.pathname){a.classList.add('sw-active');}
        });
        </script>
      {% else %}
        {{ content_for_layout }}
      {% endif %}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
