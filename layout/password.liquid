<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spotwereld — Bijna er!</title>
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100svh;
      background: #061f40;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.25rem;
      overflow-x: hidden;
    }

    /* Ambient light glow */
    body::before {
      content: '';
      position: fixed;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse at center, rgba(15,111,227,0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    .cs-wrap {
      width: 100%;
      max-width: 520px;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    /* Logo */
    .cs-logo {
      margin-bottom: 2.5rem;
    }
    .cs-logo img {
      height: 3.25rem;
      width: auto;
      border-radius: 6px;
    }

    /* Spotlight icon */
    .cs-icon {
      width: 5rem;
      height: 5rem;
      background: linear-gradient(135deg, #083D7D, #0F6FE3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 2rem;
      box-shadow: 0 0 40px rgba(15,111,227,0.35);
    }

    h1 {
      font-size: clamp(2rem, 6vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #fff 40%, #93c5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .cs-sub {
      color: #93c5fd;
      font-size: 1.0625rem;
      line-height: 1.65;
      margin-bottom: 2.5rem;
    }

    /* Divider dots */
    .cs-dots {
      display: flex;
      gap: .5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .cs-dots span {
      width: .4rem;
      height: .4rem;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
    }
    .cs-dots span:nth-child(2) { background: #0F6FE3; }

    /* Email form */
    .cs-form-label {
      font-size: .875rem;
      font-weight: 600;
      color: #bfdbfe;
      margin-bottom: .75rem;
      display: block;
    }
    .cs-form-row {
      display: flex;
      gap: .5rem;
      flex-wrap: wrap;
    }
    .cs-form-row input[type="email"] {
      flex: 1;
      min-width: 0;
      padding: .8125rem 1rem;
      border-radius: .625rem;
      border: 1.5px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      color: #fff;
      font-size: .9375rem;
      outline: none;
      transition: border-color .2s;
      font-family: inherit;
    }
    .cs-form-row input[type="email"]::placeholder { color: rgba(255,255,255,0.35); }
    .cs-form-row input[type="email"]:focus { border-color: #0F6FE3; }
    .cs-form-row button {
      padding: .8125rem 1.5rem;
      background: linear-gradient(135deg, #083D7D, #0F6FE3);
      color: #fff;
      font-weight: 700;
      font-size: .9375rem;
      border: none;
      border-radius: .625rem;
      cursor: pointer;
      white-space: nowrap;
      font-family: inherit;
      transition: opacity .2s;
    }
    .cs-form-row button:hover { opacity: .85; }

    .cs-form-note {
      font-size: .75rem;
      color: rgba(255,255,255,0.35);
      margin-top: .625rem;
    }

    .cs-success {
      background: rgba(22,163,74,0.15);
      border: 1px solid rgba(134,239,172,0.3);
      color: #86efac;
      border-radius: .75rem;
      padding: 1rem;
      font-size: .9375rem;
      font-weight: 600;
    }

    /* Contact strip */
    .cs-contact {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }
    .cs-contact a {
      display: flex;
      align-items: center;
      gap: .5rem;
      color: #93c5fd;
      text-decoration: none;
      font-size: .875rem;
      font-weight: 500;
      transition: color .2s;
    }
    .cs-contact a:hover { color: #fff; }

    /* Admin access */
    .cs-admin-link {
      margin-top: 3rem;
      font-size: .6875rem;
      color: rgba(255,255,255,0.18);
    }
    .cs-admin-link button {
      background: none;
      border: none;
      color: rgba(255,255,255,0.18);
      font-size: .6875rem;
      cursor: pointer;
      font-family: inherit;
      text-decoration: underline;
      padding: 0;
    }
    .cs-admin-link button:hover { color: rgba(255,255,255,0.4); }

    /* Password dialog */
    dialog {
      background: #0c2d58;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 1rem;
      padding: 2rem;
      max-width: 380px;
      width: 90vw;
      color: #fff;
    }
    dialog::backdrop { background: rgba(0,0,0,0.6); }
    .pwd-dialog-title {
      font-size: 1.125rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
    }
    .pwd-dialog-row {
      display: flex;
      gap: .5rem;
    }
    .pwd-dialog-row input[type="password"] {
      flex: 1;
      padding: .75rem 1rem;
      border-radius: .5rem;
      border: 1.5px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      color: #fff;
      font-size: .9375rem;
      outline: none;
      font-family: inherit;
    }
    .pwd-dialog-row input[type="password"]:focus { border-color: #0F6FE3; }
    .pwd-dialog-row button[type="submit"] {
      padding: .75rem 1.25rem;
      background: linear-gradient(135deg, #083D7D, #0F6FE3);
      color: #fff;
      font-weight: 700;
      border: none;
      border-radius: .5rem;
      cursor: pointer;
      font-family: inherit;
    }
    .pwd-error {
      color: #fca5a5;
      font-size: .8125rem;
      margin-top: .5rem;
    }
    .pwd-close {
      display: block;
      margin-top: 1rem;
      background: none;
      border: none;
      color: rgba(255,255,255,0.4);
      font-size: .8125rem;
      cursor: pointer;
      font-family: inherit;
      text-decoration: underline;
      padding: 0;
    }

    @media (max-width: 400px) {
      .cs-form-row { flex-direction: column; }
      .cs-form-row button { width: 100%; }
    }
  </style>
</head>
<body>

  <div class="cs-wrap">

    <!-- Logo -->
    <div class="cs-logo">
      <img src="https://i.imgur.com/mwLhDyg.jpg" alt="Spotwereld">
    </div>

    <!-- Spotlight icon -->
    <div class="cs-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </div>

    <!-- Headline -->
    <h1>Spotwereld is bijna klaar</h1>

    <!-- Subtext -->
    <p class="cs-sub">
      We werken hard aan onze nieuwe webshop voor premium LED verlichting.<br>
      Schrijf je in en ontvang als eerste onze openingsdeal.
    </p>

    <div class="cs-dots">
      <span></span><span></span><span></span>
    </div>

    <!-- Email signup -->
    {%- form 'customer', id: 'cs-email-form' -%}
      <input type="hidden" name="contact[tags]" value="coming-soon-signup">
      {%- if form.posted_successfully? -%}
        <div class="cs-success">&#10003; Bedankt! Je hoort van ons zodra we live gaan.</div>
      {%- else -%}
        <label class="cs-form-label" for="cs-email">Meld je aan voor exclusieve openingskorting</label>
        <div class="cs-form-row">
          <input type="email" id="cs-email" name="contact[email]" placeholder="jouw@email.nl" required autocomplete="email">
          <button type="submit">Houd me op de hoogte</button>
        </div>
        <p class="cs-form-note">Geen spam. Alleen de lancering + openingsdeal.</p>
      {%- endif -%}
    {%- endform -%}

    <!-- Contact -->
    <div class="cs-contact">
      <a href="mailto:info@spotwereld.nl">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        info@spotwereld.nl
      </a>
      <a href="tel:0850600936">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (0)85 060 09 36
      </a>
    </div>

    <!-- Admin access link -->
    <div class="cs-admin-link">
      <button type="button" onclick="document.getElementById('sw-pwd-dialog').showModal()">Beheerder toegang</button>
    </div>

  </div>

  <!-- Admin password dialog (required by Shopify) -->
  {%- form 'storefront_password' -%}
    <dialog id="sw-pwd-dialog">
      <p class="pwd-dialog-title">Beheerder toegang</p>
      <div class="pwd-dialog-row">
        <label for="sw-pwd" style="display:none">Wachtwoord</label>
        <input type="password" id="sw-pwd" name="password" placeholder="Winkelwachtwoord" autocomplete="current-password" {% if form.errors %}autofocus{% endif %}>
        <button type="submit">Ga naar winkel</button>
      </div>
      {%- if form.errors -%}
        <p class="pwd-error">Onjuist wachtwoord. Probeer het opnieuw.</p>
      {%- endif -%}
      <button type="button" class="pwd-close" onclick="document.getElementById('sw-pwd-dialog').close()">Annuleren</button>
    </dialog>
  {%- endform -%}

  <script>
    // Auto-open dialog if password error
    {% if form.errors %}
      document.getElementById('sw-pwd-dialog').showModal();
    {% endif %}
  </script>

</body>
</html>
