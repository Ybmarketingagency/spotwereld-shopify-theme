{
  "sections": {
    "legal_hero": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style='background:#061f40;padding:3rem 0 2.5rem'><div style='max-width:1280px;margin:0 auto;padding:0 1.5rem'><nav style='display:flex;align-items:center;gap:.375rem;font-size:.8125rem;color:#93c5fd;flex-wrap:wrap;margin-bottom:.875rem'><a href='/' style='color:#93c5fd;text-decoration:none;transition:color .2s'>Home</a><span style='opacity:.4;margin:0 .1rem'>/</span><span style='color:#bfdbfe'>Klantenservice</span><span style='opacity:.4;margin:0 .1rem'>/</span><span style='color:#e0eaff'>{{ page.title }}</span></nav><h1 style='color:#fff;font-weight:800;font-size:clamp(1.75rem,4vw,2.5rem);margin:0;line-height:1.2'>{{ page.title }}</h1></div></div>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
