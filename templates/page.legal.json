      }
    },
    "legal_body": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.sw-legal-wrap{max-width:1280px;margin:0 auto;padding:3rem 1.5rem 5rem;display:grid;grid-template-columns:1fr;gap:2.5rem}@media(min-width:768px){.sw-legal-wrap{grid-template-columns:220px 1fr}}.sw-legal-sidebar{align-self:start;position:sticky;top:7rem}.sw-legal-sidebar h3{font-size:.75rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.1em;margin:0 0 .75rem;padding:0 .75rem}.sw-legal-sidebar nav{display:flex;flex-direction:column;gap:.125rem}.sw-legal-sidebar a{display:block;padding:.5rem .75rem;border-radius:.5rem;color:#374151;font-size:.9375rem;text-decoration:none;font-weight:500;transition:background .15s,color .15s;line-height:1.4}.sw-legal-sidebar a:hover{background:#EBF2FF;color:#0F6FE3}.sw-legal-sidebar a.sw-active{background:#EBF2FF;color:#083D7D;font-weight:700;border-left:3px solid #0F6FE3;padding-left:calc(.75rem - 3px)}.sw-legal-content{background:#fff;border:1px solid #e5e7eb;border-radius:1rem;padding:2.5rem;min-width:0;box-shadow:0 1px 6px rgba(0,0,0,0.06)}.sw-legal-content h1{display:none}.sw-legal-content h2{font-size:1.25rem;font-weight:800;color:#061f40;margin:2.25rem 0 .625rem;padding-top:1.75rem;border-top:1px solid #f3f4f6}.sw-legal-content>*:first-child,.sw-legal-content h2:first-child{margin-top:0;padding-top:0;border-top:none}.sw-legal-content h3{font-size:1rem;font-weight:700;color:#111827;margin:1.5rem 0 .5rem}.sw-legal-content p{color:#374151;font-size:.9375rem;line-height:1.75;margin:0 0 .875rem}.sw-legal-content p:last-child{margin-bottom:0}.sw-legal-content strong{color:#111827;font-weight:700}.sw-legal-content a{color:#0F6FE3;text-decoration:underline}.sw-legal-content ul,.sw-legal-content ol{color:#374151;font-size:.9375rem;line-height:1.75;margin:0 0 .875rem;padding-left:1.5rem}.sw-legal-content li{margin-bottom:.375rem}.sw-legal-content table{width:100%;border-collapse:collapse;font-size:.875rem;margin:.75rem 0}.sw-legal-content table th{background:#f9fafb;font-weight:700;color:#111827;padding:.625rem .875rem;text-align:left;border:1px solid #e5e7eb}.sw-legal-content table td{padding:.5rem .875rem;border:1px solid #e5e7eb;color:#374151}</style><div style='background:#f9fafb;border-top:1px solid #e5e7eb'><div class='sw-legal-wrap'><aside class='sw-legal-sidebar'><h3>Klantenservice</h3><nav><a href='/pages/contact'>Contact</a><a href='/pages/over-ons'>Over ons</a><a href='/pages/veelgestelde-vragen'>Veelgestelde vragen</a><a href='/pages/verzending-retouren'>Verzending &amp; Retouren</a><a href='/pages/garantie'>Garantie</a><a href='/pages/algemene-voorwaarden'>Algemene voorwaarden</a><a href='/pages/privacyverklaring'>Privacyverklaring</a></nav></aside><div class='sw-legal-content'>{{ page.content }}</div></div></div><script>document.querySelectorAll('.sw-legal-sidebar a').forEach(function(a){if(a.pathname===window.location.pathname){a.classList.add('sw-active');}});</script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    }
