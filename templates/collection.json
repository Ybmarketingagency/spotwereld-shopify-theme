    "spotwereld_filter_styles": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.facets-block-wrapper--vertical{border-right:2px solid #e8edf4}.facets--vertical .facets__item{border-bottom:1px solid #f0f3f8!important}.facets--vertical .facets__summary{padding-top:1.1rem!important;padding-bottom:1rem!important}.facets--vertical .facets__summary .facets__label{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .checkbox__label-text{font-size:.9375rem!important;color:#1e293b!important;font-weight:500!important;line-height:1.4!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .checkbox__label-text{color:#061f40!important;font-weight:600!important}.facets--vertical .checkbox__input:checked + .checkbox__label .checkbox__label-text{color:#061f40!important;font-weight:700!important}.facets--vertical .checkbox--disabled .checkbox__label-text{color:#94a3b8!important;font-weight:400!important}.facets--vertical .icon-checkmark{border-color:#cbd5e1!important;border-radius:4px!important;width:18px!important;height:18px!important}.facets--vertical .checkbox__input:checked + .checkbox__label .icon-checkmark{background-color:#061f40!important;border-color:#061f40!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .icon-checkmark{border-color:#061f40!important}.facets--vertical .facets__bubble{background-color:#061f40!important;color:#fff!important;font-size:.7rem!important;min-width:1.25rem!important}.facets--vertical .clear-filter{font-size:.75rem!important;border-radius:20px!important;color:#061f40!important}.facets-block-wrapper--vertical .facets--filters-title,.facets-controls-wrapper .facets--filters-title{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .facets__inputs-list-item{margin-bottom:.3rem!important}.facets--vertical .facets__inputs{padding-bottom:1.1rem!important}.facets--vertical .facets__count,.facets--vertical .facets__item-count{color:#94a3b8!important;font-size:.8rem!important}@media screen and (max-width:749px){.facets-controls-wrapper .button-secondary:not(.clear-filter){background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border-color:transparent!important;border-radius:8px!important}}h4.facets--filters-title,.facets--filters-title,.facets-controls-wrapper h4,.facets-controls-wrapper h3,.facets-controls-wrapper h2{display:none!important}.facets__item:has([data-testid=\"price-filter\"]),.facets__item:has(.price-filter-form),.facets__item:has(.facets__price){display:none!important}details[data-testid=\"price-filter\"]{display:none!important}.facets__panel[data-testid=\"price-filter\"]{display:none!important}</style><script>(function(){function rnK(){document.querySelectorAll('.facets__label,.facets__summary .facets__label').forEach(function(el){var t=el.textContent.trim();if(t==='Kleur'||t==='Color')el.textContent='Kleur behuizing';});}function findFacetByName(name){var details=document.querySelectorAll('details.facets__item,.facets__item details,.facets__item');for(var i=0;i<details.length;i++){var lbl=details[i].querySelector('.facets__label');if(lbl&&lbl.textContent.trim().toLowerCase().indexOf(name.toLowerCase())>-1)return details[i];}return null;}function findCheckedTagInput(){return document.querySelector('input[name=\"filter.p.tag\"]');}function addNeeOption(){if(document.querySelector('.sw-fake-nee'))return;var dimFacet=findFacetByName('Dimbaar');if(!dimFacet)return;var list=dimFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var existingItem=list.querySelector('.facets__inputs-list-item,li');if(!existingItem)return;var hasNee=Array.from(list.querySelectorAll('label,.checkbox__label-text')).some(function(el){return el.textContent.trim()==='Nee';});if(hasNee)return;var clone=existingItem.cloneNode(true);clone.classList.add('sw-fake-nee');var lblTxt=clone.querySelector('.checkbox__label-text,label span,label');if(lblTxt)lblTxt.textContent='Nee';var input=clone.querySelector('input');if(input){input.disabled=true;input.checked=false;input.value='Nee';}var countEl=clone.querySelector('.facets__count,.facets__item-count');if(countEl)countEl.textContent='(0)';clone.style.opacity='.55';list.appendChild(clone);}function splitLichtkleur(){if(document.querySelector('.sw-fake-lk-2700'))return;var lkFacet=findFacetByName('Lichtkleur');if(!lkFacet)return;var list=lkFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var origItem=null;var origInputName='filter.p.product_option.lichtkleur';var origInputValue='Instelbaar (2700K-4000K)';Array.from(list.querySelectorAll('.facets__inputs-list-item,li')).forEach(function(it){var t=it.textContent;if(t.indexOf('Instelbaar')>-1||t.indexOf('2700K-4000K')>-1){origItem=it;var origInput=it.querySelector('input');if(origInput){origInputName=origInput.name||origInputName;origInputValue=origInput.value||origInputValue;}it.style.display='none';}});if(!origItem)origItem=list.querySelector('.facets__inputs-list-item,li');if(!origItem)return;[{c:'2700',n:'2700K (Warm wit)'},{c:'3000',n:'3000K (Sfeer wit)'},{c:'4000',n:'4000K (Daglicht)'}].forEach(function(opt){var clone=origItem.cloneNode(true);clone.style.display='';clone.classList.add('sw-fake-lk-'+opt.c);var lbl=clone.querySelector('.checkbox__label-text,label span');if(lbl)lbl.textContent=opt.n;var input=clone.querySelector('input');if(input){input.name=origInputName;input.value=origInputValue;input.checked=false;}list.appendChild(clone);});}function addVormFilter(){if(document.querySelector('.sw-vorm-facet'))return;var kleurFacet=findFacetByName('Kleur');if(!kleurFacet)return;var vormHtml='<details class=\"facets__item sw-vorm-facet\" open><summary class=\"facets__summary\"><span class=\"facets__label\">Vorm</span><span class=\"facets__icon\"></span></summary><div class=\"facets__panel\"><ul class=\"facets__inputs facets__inputs-list\">'+[{v:'rond',n:'Rond'},{v:'vierkant',n:'Vierkant'},{v:'rechthoek',n:'Rechthoek'}].map(function(o){return '<li class=\"facets__inputs-list-item\"><label class=\"checkbox\"><input type=\"checkbox\" class=\"checkbox__input\" name=\"filter.p.tag\" value=\"vorm-'+o.v+'\"><span class=\"checkbox__label\"><span class=\"icon-checkmark\"></span><span class=\"checkbox__label-text\">'+o.n+'</span></span></label></li>';}).join('')+'</ul></div></details>';kleurFacet.insertAdjacentHTML('beforebegin',vormHtml);var vormInputs=document.querySelectorAll('.sw-vorm-facet input');var urlParams=new URLSearchParams(window.location.search);var activeTags=urlParams.getAll('filter.p.tag');vormInputs.forEach(function(inp){if(activeTags.indexOf(inp.value)>-1)inp.checked=true;inp.addEventListener('change',function(){var params=new URLSearchParams(window.location.search);var tags=params.getAll('filter.p.tag');params.delete('filter.p.tag');if(inp.checked){tags.push(inp.value);}else{tags=tags.filter(function(t){return t!==inp.value;});}tags.forEach(function(t){params.append('filter.p.tag',t);});window.location.search=params.toString();});});}function enhanceColCards(){var cards=document.querySelectorAll('.product-card');cards.forEach(function(card){if(card.dataset.swEnh)return;card.dataset.swEnh='1';var mc=card.querySelector('.product-media-container, .card-gallery, .product-media');if(mc&&!card.querySelector('.sw-coll-stock')){mc.style.position='relative';var st=document.createElement('span');st.className='sw-coll-stock';st.textContent='Op voorraad';mc.appendChild(st);}var ti=card.querySelector('.product-card__title, product-title, .product-title');if(ti&&!card.querySelector('.sw-coll-stars')){var sr=document.createElement('div');sr.className='sw-coll-stars';sr.innerHTML='&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';ti.insertAdjacentElement('afterend',sr);}var pl=card.querySelector('.product-card__link, a[href*=\"/products/\"]');var qa=card.querySelector('.quick-add');if(pl&&!card.querySelector('.sw-coll-bekijk')){if(qa)qa.style.display='none';var bk=document.createElement('a');bk.href=pl.getAttribute('href');bk.className='sw-coll-bekijk';bk.innerHTML='Bekijk Product <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>';var ct=card.querySelector('.product-card__content')||card;ct.appendChild(bk);}});}function runAll(){rnK();addNeeOption();splitLichtkleur();addVormFilter();enhanceColCards();}document.addEventListener('DOMContentLoaded',runAll);setTimeout(runAll,300);setTimeout(runAll,900);setTimeout(runAll,2000);document.addEventListener('shopify:section:load',runAll);var obs=new MutationObserver(function(muts){var hasFacetChange=muts.some(function(m){return Array.from(m.addedNodes).some(function(n){return n.nodeType===1&&(n.classList&&(n.classList.contains('facets__item')||n.querySelector&&n.querySelector('.facets__item')));});});if(hasFacetChange)runAll();else{rnK();enhanceColCards();}});document.addEventListener('DOMContentLoaded',function(){var f=document.querySelector('.facets-block-wrapper--vertical,.facets__form-wrapper');if(f)obs.observe(f,{childList:true,subtree:true});var g=document.querySelector('.product-grid,results-list');if(g)obs.observe(g,{childList:true,subtree:true});});})();</script><style>.product-card{position:relative}.sw-coll-stock{position:absolute;top:.5rem;right:.5rem;z-index:5;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem}.sw-coll-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a;display:inline-block;margin-right:.25rem}.sw-coll-stars{color:#f59e0b;font-size:.78rem;letter-spacing:-.05em;margin:.3rem 0 .1rem;line-height:1}.sw-coll-stars span{color:#94a3b8;font-size:.72rem;margin-left:.25rem;letter-spacing:0}.sw-coll-bekijk{display:flex!important;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;padding:.65rem .75rem!important;font-weight:700!important;font-size:.82rem!important;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em;margin-top:.5rem;text-decoration:none!important;line-height:1;box-sizing:border-box}.sw-coll-bekijk:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}.sw-coll-bekijk svg{flex-shrink:0;transition:transform .2s}.sw-coll-bekijk:hover svg{transform:translateX(3px)}</style>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
