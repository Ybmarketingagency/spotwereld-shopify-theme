{
  "sections": {
    "spotwereld_collection_header": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{%- assign hi = '' -%}{%- assign hs = '' -%}{%- case collection.handle -%}{%- when 'inbouwspots' -%}{%- assign hi = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1400&q=80' -%}{%- assign hs = 'Strak en modern ingebouwd in uw plafond' -%}{%- when 'opbouwspots' -%}{%- assign hi = 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=1400&q=80' -%}{%- assign hs = 'Veelzijdig en eenvoudig te monteren' -%}{%- when 'hanglampen' -%}{%- assign hi = 'https://images.unsplash.com/photo-1513506003901-1e6a35421bff?auto=format&fit=crop&w=1400&q=80' -%}{%- assign hs = 'Sfeervolle verlichting voor elk interieur' -%}{%- when 'trapverlichting' -%}{%- assign hi = 'https://images.unsplash.com/photo-1459767129954-1b1c1f9b9ace?auto=format&fit=crop&w=1400&q=80' -%}{%- assign hs = 'Veilig en sfeervol uw trap verlichten' -%}{%- when 'wandlampen' -%}{%- assign hi = 'https://images.unsplash.com/photo-1550581190-9c1c48d21d6c?auto=format&fit=crop&w=1400&q=80' -%}{%- assign hs = 'Accentverlichting voor de mooiste muren' -%}{%- endcase -%}{%- if collection.image -%}{%- assign hi = collection.image | image_url: width: 1400 -%}{%- endif -%}<div style=\"position:relative;height:280px;background:#061f40;overflow:hidden\">{%- if hi != '' -%}<img src=\"{{ hi }}\" alt=\"{{ collection.title }}\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.45\" loading=\"eager\">{%- endif -%}<div style=\"position:absolute;inset:0;background:linear-gradient(135deg,rgba(6,31,64,0.78) 0%,rgba(6,31,64,0.35) 100%)\"></div><div style=\"position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 1.5rem;height:100%;display:flex;flex-direction:column;justify-content:center\"><h1 style=\"color:#fff;font-weight:800;font-size:2.25rem;margin:0 0 0.5rem;text-shadow:0 2px 12px rgba(0,0,0,0.4)\">{{ collection.title }}</h1>{%- if collection.description != blank -%}<p style=\"color:#bfdbfe;margin:0;font-size:1.1rem;text-shadow:0 1px 4px rgba(0,0,0,0.3)\">{{ collection.description }}</p>{%- elsif hs != '' -%}<p style=\"color:#bfdbfe;margin:0;font-size:1.1rem;text-shadow:0 1px 4px rgba(0,0,0,0.3)\">{{ hs }}</p>{%- endif -%}</div></div>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "spotwereld_filter_styles": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.facets-block-wrapper--vertical{border-right:2px solid #e8edf4}.facets--vertical .facets__item{border-bottom:1px solid #f0f3f8!important}.facets--vertical .facets__summary{padding-top:1.1rem!important;padding-bottom:1rem!important}.facets--vertical .facets__summary .facets__label{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .checkbox__label-text{font-size:.9375rem!important;color:#1e293b!important;font-weight:500!important;line-height:1.4!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .checkbox__label-text{color:#061f40!important;font-weight:600!important}.facets--vertical .checkbox__input:checked + .checkbox__label .checkbox__label-text{color:#061f40!important;font-weight:700!important}.facets--vertical .checkbox--disabled .checkbox__label-text{color:#94a3b8!important;font-weight:400!important}.facets--vertical .icon-checkmark{border-color:#cbd5e1!important;border-radius:4px!important;width:18px!important;height:18px!important}.facets--vertical .checkbox__input:checked + .checkbox__label .icon-checkmark{background-color:#061f40!important;border-color:#061f40!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .icon-checkmark{border-color:#061f40!important}.facets--vertical .facets__bubble{background-color:#061f40!important;color:#fff!important;font-size:.7rem!important;min-width:1.25rem!important}.facets--vertical .clear-filter{font-size:.75rem!important;border-radius:20px!important;color:#061f40!important}.facets-block-wrapper--vertical .facets--filters-title,.facets-controls-wrapper .facets--filters-title{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .facets__inputs-list-item{margin-bottom:.3rem!important}.facets--vertical .facets__inputs{padding-bottom:1.1rem!important}.facets--vertical .facets__count,.facets--vertical .facets__item-count{color:#94a3b8!important;font-size:.8rem!important}@media screen and (max-width:749px){.facets-controls-wrapper .button-secondary:not(.clear-filter){background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border-color:transparent!important;border-radius:8px!important}}</style>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
