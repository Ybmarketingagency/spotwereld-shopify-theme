"display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem\"><div><h1 style=\"color:#fff;font-weight:900;font-size:clamp(1.75rem,4vw,2.5rem);margin:0 0 .5rem;letter-spacing:-.03em;line-height:1.1\">{{ collection.title }}</h1>{%- if sub != '' -%}<p style=\"color:rgba(255,255,255,.7);margin:0;font-size:.95rem;line-height:1.55;max-width:500px\">{{ sub }}</p>{%- endif -%}</div><div style=\"display:flex;align-items:center;gap:.625rem;background:rgba(255,255,255,.1);backdrop-filter:blur(8px);padding:.6rem 1.1rem;border-radius:999px;border:1px solid rgba(255,255,255,.12);flex-shrink:0\"><span style=\"color:#facc15;font-size:1rem\">&#9733;</span><span style=\"color:#fff;font-size:.85rem;font-weight:600\">{{ collection.products_count }} producten</span></div></div></div></div>",
