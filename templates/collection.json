{
  "sections": {
    "spotwereld_collection_header": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{%- assign sub = '' -%}{%- case collection.handle -%}{%- when 'inbouwspots' -%}{%- assign sub = 'Strak en modern ingebouwd in uw plafond — eenvoudig zelf te installeren.' -%}{%- when 'opbouwspots' -%}{%- assign sub = 'Veelzijdig en eenvoudig te monteren, ook op betonnen plafonds.' -%}{%- when 'hanglampen' -%}{%- assign sub = 'Sfeervolle verlichting die elke ruimte compleet maakt.' -%}{%- when 'trapverlichting' -%}{%- assign sub = 'Veilig en sfeervol uw trap verlichten met LED.' -%}{%- when 'wandlampen' -%}{%- assign sub = 'Accentverlichting voor de mooiste muren.' -%}{%- endcase -%}{%- if sub == '' and collection.description != blank -%}{%- assign sub = collection.description | strip_html | truncate: 120 -%}{%- endif -%}<div style=\"background:linear-gradient(120deg,#061f40 0%,#0a2d5e 55%,#0f3d7a 100%);padding:2.25rem 0 2rem;position:relative;overflow:hidden\"><div style=\"position:absolute;right:-80px;top:-80px;width:320px;height:320px;border-radius:50%;background:rgba(255,255,255,0.035);pointer-events:none\"></div><div style=\"position:absolute;right:60px;top:30px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,0.05);pointer-events:none\"></div><div style=\"position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:100%;height:100%;background:radial-gradient(ellipse at 70% 50%,rgba(15,111,227,0.15) 0%,transparent 60%);pointer-events:none\"></div><div style=\"max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1\"><nav style=\"display:flex;align-items:center;gap:.375rem;margin-bottom:.875rem;font-size:.78rem;color:rgba(255,255,255,.45)\"><a href=\"/\" style=\"color:rgba(255,255,255,.45);text-decoration:none;transition:color .15s\" onmouseover=\"this.style.color='rgba(255,255,255,.8)'\" onmouseout=\"this.style.color='rgba(255,255,255,.45)'\">Home</a><span style=\"font-size:.6rem\">&#9656;</span><span style=\"color:rgba(255,255,255,.8)\">{{ collection.title }}</span></nav><div style=\"display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem\"><div><h1 style=\"color:#fff;font-weight:900;font-size:clamp(1.75rem,4vw,2.5rem);margin:0 0 .5rem;letter-spacing:-.03em;line-height:1.1\">{{ collection.title }}</h1>{%- if sub != '' -%}<p style=\"color:rgba(255,255,255,.7);margin:0;font-size:.95rem;line-height:1.55;max-width:500px\">{{ sub }}</p>{%- endif -%}</div><div style=\"display:flex;align-items:center;gap:.625rem;background:rgba(255,255,255,.1);backdrop-filter:blur(8px);padding:.6rem 1.1rem;border-radius:999px;border:1px solid rgba(255,255,255,.12);flex-shrink:0\"><span style=\"color:#facc15;font-size:1rem\">&#9733;</span><span style=\"color:#fff;font-size:.85rem;font-weight:600\">{{ collection.products_count }} producten</span></div></div></div></div>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "spotwereld_filter_styles": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.facets-block-wrapper--vertical{border-right:2px solid #e8edf4}.facets--vertical .facets__item{border-bottom:1px solid #f0f3f8!important}.facets--vertical .facets__summary{padding-top:1.1rem!important;padding-bottom:1rem!important}.facets--vertical .facets__summary .facets__label{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .checkbox__label-text{font-size:.9375rem!important;color:#1e293b!important;font-weight:500!important;line-height:1.4!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .checkbox__label-text{color:#061f40!important;font-weight:600!important}.facets--vertical .checkbox__input:checked + .checkbox__label .checkbox__label-text{color:#061f40!important;font-weight:700!important}.facets--vertical .checkbox--disabled .checkbox__label-text{color:#94a3b8!important;font-weight:400!important}.facets--vertical .icon-checkmark{border-color:#cbd5e1!important;border-radius:4px!important;width:18px!important;height:18px!important}.facets--vertical .checkbox__input:checked + .checkbox__label .icon-checkmark{background-color:#061f40!important;border-color:#061f40!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .icon-checkmark{border-color:#061f40!important}.facets--vertical .facets__bubble{background-color:#061f40!important;color:#fff!important;font-size:.7rem!important;min-width:1.25rem!important}.facets--vertical .clear-filter{font-size:.75rem!important;border-radius:20px!important;color:#061f40!important}.facets-block-wrapper--vertical .facets--filters-title,.facets-controls-wrapper .facets--filters-title{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .facets__inputs-list-item{margin-bottom:.3rem!important}.facets--vertical .facets__inputs{padding-bottom:1.1rem!important}.facets--vertical .facets__count,.facets--vertical .facets__item-count{color:#94a3b8!important;font-size:.8rem!important}@media screen and (max-width:749px){.facets-controls-wrapper .button-secondary:not(.clear-filter){background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border-color:transparent!important;border-radius:8px!important}}</style>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "main": {
      "type": "main-collection",
      "blocks": {
        "filters": {
          "type": "filters",
          "static": true,
          "settings": {
            "enable_filtering": true,
            "filter_style": "vertical",
            "filter_width": "centered",
            "text_label_case": "default",
            "show_swatch_label": true,
            "show_filter_label": true,
            "enable_sorting": true,
            "enable_grid_density": true,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "padding-block-start": 16,
            "padding-block-end": 8,
            "padding-inline-start": 0,
            "padding-inline-end": 0,
            "facets_margin_bottom": 8,
            "facets_margin_right": 24
          },
          "blocks": {}
        },
        "product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 4,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "card-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "adapt",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "product_title": {
              "type": "product-title",
              "name": "Producttitel",
              "settings": {
                "width": "100%",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "color": "var(--color-foreground)",
                "background": false,
                "background_color": "#00000026",
                "corner_radius": 0,
                "padding-block-start": 4,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": false,
                "show_tax_info": false,
                "type_preset": "h6",
                "width": "100%",
                "alignment": "left",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "color": "var(--color-foreground)",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": [
            "card-gallery",
            "product_title",
            "price"
          ]
        }
      },
      "settings": {
        "layout_type": "grid",
        "product_card_size": "medium",
        "mobile_product_card_size": "small",
        "product_grid_width": "centered",
        "full_width_on_mobile": true,
        "columns_gap_horizontal": 16,
        "columns_gap_vertical": 24,
        "padding-inline-start": 0,
        "padding-inline-end": 0,
        "color_scheme": "scheme-1",
        "padding-block-start": 24,
        "padding-block-end": 32
      }
    }
  },
  "order": [
    "spotwereld_collection_header",
    "spotwereld_filter_styles",
    "main"
  ]
}
