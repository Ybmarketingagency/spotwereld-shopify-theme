    "spotwereld_filter_styles": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.facets-block-wrapper--vertical{border-right:2px solid #e8edf4}.facets--vertical .facets__item{border-bottom:1px solid #f0f3f8!important}.facets--vertical .facets__summary{padding-top:1.1rem!important;padding-bottom:1rem!important}.facets--vertical .facets__summary .facets__label{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .checkbox__label-text{font-size:.9375rem!important;color:#1e293b!important;font-weight:500!important;line-height:1.4!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .checkbox__label-text{color:#061f40!important;font-weight:600!important}.facets--vertical .checkbox__input:checked + .checkbox__label .checkbox__label-text{color:#061f40!important;font-weight:700!important}.facets--vertical .checkbox--disabled .checkbox__label-text{color:#94a3b8!important;font-weight:400!important}.facets--vertical .icon-checkmark{border-color:#cbd5e1!important;border-radius:4px!important;width:18px!important;height:18px!important}.facets--vertical .checkbox__input:checked + .checkbox__label .icon-checkmark{background-color:#061f40!important;border-color:#061f40!important}.facets--vertical .checkbox:not(.checkbox--disabled):hover .icon-checkmark{border-color:#061f40!important}.facets--vertical .facets__bubble{background-color:#061f40!important;color:#fff!important;font-size:.7rem!important;min-width:1.25rem!important}.facets--vertical .clear-filter{font-size:.75rem!important;border-radius:20px!important;color:#061f40!important}.facets-block-wrapper--vertical .facets--filters-title,.facets-controls-wrapper .facets--filters-title{font-size:.8rem!important;font-weight:800!important;text-transform:uppercase!important;letter-spacing:.08em!important;color:#061f40!important}.facets--vertical .facets__inputs-list-item{margin-bottom:.3rem!important}.facets--vertical .facets__inputs{padding-bottom:1.1rem!important}.facets--vertical .facets__count,.facets--vertical .facets__item-count{color:#94a3b8!important;font-size:.8rem!important}@media screen and (max-width:749px){.facets-controls-wrapper .button-secondary:not(.clear-filter){background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border-color:transparent!important;border-radius:8px!important}}h4.facets--filters-title,.facets--filters-title,.facets-controls-wrapper h4,.facets-controls-wrapper h3,.facets-controls-wrapper h2{display:none!important}.facets__item:has([data-testid=\"price-filter\"]),.facets__item:has(.price-filter-form),.facets__item:has(.facets__price){display:none!important}details[data-testid=\"price-filter\"]{display:none!important}.facets__panel[data-testid=\"price-filter\"]{display:none!important}</style><script>(function(){function rnK(){document.querySelectorAll('.facets__label,.facets__summary .facets__label').forEach(function(el){var t=el.textContent.trim();if(t==='Kleur'||t==='Color')el.textContent='Kleur behuizing';});}function findFacetByName(name){var details=document.querySelectorAll('details.facets__item,.facets__item details,.facets__item');for(var i=0;i<details.length;i++){var lbl=details[i].querySelector('.facets__label');if(lbl&&lbl.textContent.trim().toLowerCase().indexOf(name.toLowerCase())>-1)return details[i];}return null;}function findCheckedTagInput(){return document.querySelector('input[name=\"filter.p.tag\"]');}function addNeeOption(){if(document.querySelector('.sw-fake-nee'))return;var dimFacet=findFacetByName('Dimbaar');if(!dimFacet)return;var list=dimFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var existingItem=list.querySelector('.facets__inputs-list-item,li');if(!existingItem)return;var hasNee=Array.from(list.querySelectorAll('label,.checkbox__label-text')).some(function(el){return el.textContent.trim()==='Nee';});if(hasNee)return;var clone=existingItem.cloneNode(true);clone.classList.add('sw-fake-nee');var lblTxt=clone.querySelector('.checkbox__label-text,label span,label');if(lblTxt)lblTxt.textContent='Nee';var input=clone.querySelector('input');if(input){input.disabled=true;input.checked=false;input.value='Nee';}var countEl=clone.querySelector('.facets__count,.facets__item-count');if(countEl)countEl.textContent='(0)';clone.style.opacity='.55';list.appendChild(clone);}function splitLichtkleur(){if(document.querySelector('.sw-fake-lk-2700'))return;var lkFacet=findFacetByName('Lichtkleur');if(!lkFacet)return;var list=lkFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');if(!list)return;var origItem=null;var origInputName='filter.p.product_option.lichtkleur';var origInputValue='Instelbaar (2700K-4000K)';Array.from(list.querySelectorAll('.facets__inputs-list-item,li')).forEach(function(it){var t=it.textContent;if(t.indexOf('Instelbaar')>-1||t.indexOf('2700K-4000K')>-1){origItem=it;var origInput=it.querySelector('input');if(origInput){origInputName=origInput.name||origInputName;origInputValue=origInput.value||origInputValue;}it.style.display='none';}});if(!origItem)origItem=list.querySelector('.facets__inputs-list-item,li');if(!origItem)return;var urlSel=null;try{urlSel=sessionStorage.getItem('sw_lk_sel');}catch(e){}[{c:'2700',n:'2700K (Warm wit)'},{c:'3000',n:'3000K (Sfeer wit)'},{c:'4000',n:'4000K (Daglicht)'}].forEach(function(opt){var clone=origItem.cloneNode(true);clone.style.display='';clone.classList.add('sw-fake-lk-'+opt.c);clone.setAttribute('data-sw-lk',opt.c);var lbl=clone.querySelector('.checkbox__label-text,label span');if(lbl)lbl.textContent=opt.n;var input=clone.querySelector('input');if(input){input.name=origInputName;input.value=origInputValue;var hasFilter=new URLSearchParams(window.location.search).get(origInputName);input.checked=(urlSel===opt.c && !!hasFilter);if(urlSel===opt.c && !!hasFilter)clone.classList.add('sw-lk-active');input.addEventListener('click',function(){try{sessionStorage.setItem('sw_lk_sel',opt.c);}catch(e){}},true);}list.appendChild(clone);});}function getVorm(handle){if(!handle)return null;if(handle.indexOf('aristo')>-1||handle.indexOf('miran')>-1)return 'rond';if(handle.indexOf('laom')>-1)return 'vierkant';return null;}function applyVormFilter(){var actives=new URLSearchParams(window.location.search).getAll('sw_vorm');var cards=document.querySelectorAll('product-card,.product-card');cards.forEach(function(c){var link=c.querySelector('a[href*=\"/products/\"]');var handle=link?(link.getAttribute('href').split('/products/')[1]||'').split('?')[0].split('#')[0]:'';var vorm=getVorm(handle);var gridItem=c.closest('li,.grid__item,.product-grid__card-wrapper')||c;if(actives.length===0||(vorm&&actives.indexOf(vorm)>-1)){gridItem.style.display='';}else{gridItem.style.display='none';}});}function addVormFilter(){if(document.querySelector('.sw-vorm-facet'))return;var kleurFacet=findFacetByName('Kleur');if(!kleurFacet)return;var vormHtml='<details class=\"facets__item sw-vorm-facet\" open><summary class=\"facets__summary\"><span class=\"facets__label\">Vorm</span><span class=\"facets__icon\"></span></summary><div class=\"facets__panel\"><ul class=\"facets__inputs facets__inputs-list\">'+[{v:'rond',n:'Rond'},{v:'vierkant',n:'Vierkant'},{v:'rechthoek',n:'Rechthoek'}].map(function(o){return '<li class=\"facets__inputs-list-item\"><label class=\"checkbox\"><input type=\"checkbox\" class=\"checkbox__input\" name=\"sw_vorm\" value=\"'+o.v+'\"><span class=\"checkbox__label\"><span class=\"icon-checkmark\"></span><span class=\"checkbox__label-text\">'+o.n+'</span></span></label></li>';}).join('')+'</ul></div></details>';kleurFacet.insertAdjacentHTML('beforebegin',vormHtml);var vormInputs=document.querySelectorAll('.sw-vorm-facet input');var activeVorms=new URLSearchParams(window.location.search).getAll('sw_vorm');vormInputs.forEach(function(inp){if(activeVorms.indexOf(inp.value)>-1)inp.checked=true;inp.addEventListener('change',function(){var params=new URLSearchParams(window.location.search);params.delete('sw_vorm');document.querySelectorAll('.sw-vorm-facet input:checked').forEach(function(i){params.append('sw_vorm',i.value);});var s=params.toString();window.history.replaceState({},'','?'+s);applyVormFilter();});});applyVormFilter();}function enhanceColCards(){var cards=document.querySelectorAll('.product-card');cards.forEach(function(card){if(card.dataset.swEnh)return;card.dataset.swEnh='1';var mc=card.querySelector('.product-media-container, .card-gallery, .product-media');if(mc&&!card.querySelector('.sw-coll-stock')){mc.style.position='relative';var st=document.createElement('span');st.className='sw-coll-stock';st.textContent='Op voorraad';mc.appendChild(st);}var ti=card.querySelector('.product-card__title, product-title, .product-title');if(ti&&!card.querySelector('.sw-coll-stars')){var sr=document.createElement('div');sr.className='sw-coll-stars';sr.innerHTML='&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';ti.insertAdjacentElement('afterend',sr);}var pl=card.querySelector('.product-card__link, a[href*=\"/products/\"]');var qa=card.querySelector('.quick-add');if(pl&&!card.querySelector('.sw-coll-bekijk')){if(qa)qa.style.display='none';var bk=document.createElement('a');bk.href=pl.getAttribute('href');bk.className='sw-coll-bekijk';bk.innerHTML='Bekijk Product <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>';var ct=card.querySelector('.product-card__content')||card;ct.appendChild(bk);}});}function runAll(){rnK();addNeeOption();splitLichtkleur();addVormFilter();enhanceColCards();applyVormFilter();}document.addEventListener('DOMContentLoaded',runAll);setTimeout(runAll,300);setTimeout(runAll,900);setTimeout(runAll,2000);document.addEventListener('shopify:section:load',runAll);var obs=new MutationObserver(function(muts){var hasFacetChange=muts.some(function(m){return Array.from(m.addedNodes).some(function(n){return n.nodeType===1&&(n.classList&&(n.classList.contains('facets__item')||n.querySelector&&n.querySelector('.facets__item')));});});if(hasFacetChange)runAll();else{rnK();enhanceColCards();}});document.addEventListener('DOMContentLoaded',function(){var f=document.querySelector('.facets-block-wrapper--vertical,.facets__form-wrapper');if(f)obs.observe(f,{childList:true,subtree:true});var g=document.querySelector('.product-grid,results-list');if(g)obs.observe(g,{childList:true,subtree:true});});})();</script><style>.product-card{position:relative}.sw-coll-stock{position:absolute;top:.5rem;right:.5rem;z-index:5;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem}.sw-coll-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a;display:inline-block;margin-right:.25rem}.sw-coll-stars{color:#f59e0b;font-size:.78rem;letter-spacing:-.05em;margin:.3rem 0 .1rem;line-height:1}.sw-coll-stars span{color:#94a3b8;font-size:.72rem;margin-left:.25rem;letter-spacing:0}.sw-coll-bekijk{display:flex!important;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3)!important;color:#fff!important;border:none!important;border-radius:.5rem!important;padding:.65rem .75rem!important;font-weight:700!important;font-size:.82rem!important;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em;margin-top:.5rem;text-decoration:none!important;line-height:1;box-sizing:border-box}.sw-coll-bekijk:hover{background:linear-gradient(135deg,#062d5c,#0a5abf)!important;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,61,125,.2)}.sw-coll-bekijk svg{flex-shrink:0;transition:transform .2s}.sw-coll-bekijk:hover svg{transform:translateX(3px)}.sw-lk-active{background:rgba(15,111,227,.08);border-radius:6px}.sw-lk-active .checkbox__label-text{color:#0F6FE3!important;font-weight:700!important}[class*=\"sw-fake-lk-\"] input:checked+.checkbox__label .checkbox__label-text,[class*=\"sw-fake-lk-\"] input:checked~.checkbox__label .checkbox__label-text{color:#0F6FE3!important;font-weight:700!important}[class*=\"sw-fake-lk-\"] input:checked+.checkbox__label .icon-checkmark,[class*=\"sw-fake-lk-\"] input:checked~.checkbox__label .icon-checkmark{background:#0F6FE3!important;border-color:#0F6FE3!important}</style><script>\n(function(){\n  function enhanceColCards(){\n    var cards = document.querySelectorAll('.product-card');\n    cards.forEach(function(card){\n      if(card.dataset.swEnh) return;\n      card.dataset.swEnh = '1';\n      // Op voorraad badge\n      if(!card.querySelector('.sw-coll-stock')){\n        var mediaContainer = card.querySelector('.product-media-container, .card-gallery, .product-media');\n        if(mediaContainer){\n          mediaContainer.style.position = 'relative';\n          var stock = document.createElement('span');\n          stock.className = 'sw-coll-stock';\n          stock.textContent = 'Op voorraad';\n          mediaContainer.appendChild(stock);\n        }\n      }\n      // Sterren rating onder de titel\n      if(!card.querySelector('.sw-coll-stars')){\n        var title = card.querySelector('.product-card__title, [class*=\"product-card__title\"], product-title, .product-title');\n        if(title){\n          var stars = document.createElement('div');\n          stars.className = 'sw-coll-stars';\n          stars.innerHTML = '&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span>';\n          var titleEl = title.tagName === 'PRODUCT-TITLE' ? title : title;\n          titleEl.insertAdjacentElement('afterend', stars);\n        }\n      }\n      // Vervang Quick-add knop door \"Bekijk Product\" link\n      var qaContainer = card.querySelector('.quick-add');\n      var productLink = card.querySelector('.product-card__link, a[href*=\"/products/\"]');\n      if(qaContainer && productLink && !qaContainer.dataset.swReplaced){\n        qaContainer.dataset.swReplaced = '1';\n        var prodHref = productLink.getAttribute('href');\n        var bekijkBtn = document.createElement('a');\n        bekijkBtn.href = prodHref;\n        bekijkBtn.className = 'sw-coll-bekijk';\n        bekijkBtn.innerHTML = 'Bekijk Product <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>';\n        qaContainer.style.display = 'none';\n        qaContainer.parentNode.insertBefore(bekijkBtn, qaContainer.nextSibling);\n      }\n    });\n  }\n  function rnK(){\n    document.querySelectorAll('.facets__label,.facets__summary .facets__label').forEach(function(el){\n      var t=el.textContent.trim();\n      if(t==='Kleur'||t==='Color')el.textContent='Kleur behuizing';\n    });\n  }\n  function findFacetByName(name){\n    var details=document.querySelectorAll('details.facets__item,.facets__item details,.facets__item');\n    for(var i=0;i<details.length;i++){\n      var lbl=details[i].querySelector('.facets__label');\n      if(lbl&&lbl.textContent.trim().toLowerCase().indexOf(name.toLowerCase())>-1)return details[i];\n    }\n    return null;\n  }\n  function addNeeOption(){\n    if(document.querySelector('.sw-fake-nee'))return;\n    var dimFacet=findFacetByName('Dimbaar');\n    if(!dimFacet)return;\n    var list=dimFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');\n    if(!list)return;\n    var existingItem=list.querySelector('.facets__inputs-list-item,li');\n    if(!existingItem)return;\n    var hasNee=Array.from(list.querySelectorAll('label,.checkbox__label-text')).some(function(el){return el.textContent.trim()==='Nee';});\n    if(hasNee)return;\n    var clone=existingItem.cloneNode(true);\n    clone.classList.add('sw-fake-nee');\n    var lblTxt=clone.querySelector('.checkbox__label-text,label span,label');\n    if(lblTxt)lblTxt.textContent='Nee';\n    var input=clone.querySelector('input');\n    if(input){input.disabled=true;input.checked=false;input.value='Nee';}\n    var countEl=clone.querySelector('.facets__count,.facets__item-count');\n    if(countEl)countEl.textContent='(0)';\n    clone.style.opacity='.55';\n    list.appendChild(clone);\n  }\n  function splitLichtkleur(){\n    if(document.querySelector('.sw-fake-lk-2700'))return;\n    var lkFacet=findFacetByName('Lichtkleur');\n    if(!lkFacet)return;\n    var list=lkFacet.querySelector('.facets__inputs,ul,.facets__inputs-list');\n    if(!list)return;\n    var origItem=null;\n    var origInputName='filter.p.product_option.lichtkleur';\n    var origInputValue='Instelbaar (2700K-4000K)';\n    Array.from(list.querySelectorAll('.facets__inputs-list-item,li')).forEach(function(it){\n      var t=it.textContent;\n      if(t.indexOf('Instelbaar')>-1||t.indexOf('2700K-4000K')>-1){\n        origItem=it;\n        var oi=it.querySelector('input');\n        if(oi){origInputName=oi.name||origInputName;origInputValue=oi.value||origInputValue;}\n        it.style.display='none';\n      }\n    });\n    if(!origItem)origItem=list.querySelector('.facets__inputs-list-item,li');\n    if(!origItem)return;\n    var urlSel=new URLSearchParams(window.location.search).get('sw_lk');\n    [{c:'2700',n:'2700K (Warm wit)'},{c:'3000',n:'3000K (Sfeer wit)'},{c:'4000',n:'4000K (Daglicht)'}].forEach(function(opt){\n      var clone=origItem.cloneNode(true);\n      clone.style.display='';\n      clone.classList.add('sw-fake-lk-'+opt.c);\n      clone.setAttribute('data-sw-lk',opt.c);\n      var lbl=clone.querySelector('.checkbox__label-text,label span');\n      if(lbl)lbl.textContent=opt.n;\n      var input=clone.querySelector('input');\n      if(input){\n        input.name=origInputName;\n        input.value=origInputValue;\n        input.checked=(urlSel===opt.c);\n        input.setAttribute('data-sw-lk',opt.c);\n        input.addEventListener('click',function(){\n          var p=new URLSearchParams(window.location.search);\n          if(input.checked){p.set('sw_lk',opt.c);}else{p.delete('sw_lk');}\n          // Bewaar voor na de reload (Shopify zal de form submitten)\n          try{sessionStorage.setItem('sw_lk_pending',input.checked?opt.c:'');}catch(e){}\n        },true);\n      }\n      list.appendChild(clone);\n      if(urlSel===opt.c){\n        clone.classList.add('sw-lk-active');\n      }\n    });\n    // After Shopify reload, sync sw_lk into URL if missing\n    try{\n      var pending=sessionStorage.getItem('sw_lk_pending');\n      if(pending!==null && pending!==''){\n        var p=new URLSearchParams(window.location.search);\n        if(p.get('sw_lk')!==pending && p.get('filter.p.product_option.lichtkleur')){\n          p.set('sw_lk',pending);\n          window.history.replaceState({},'','?'+p.toString());\n          var inp=document.querySelector('.sw-fake-lk-'+pending+' input');\n          if(inp)inp.checked=true;\n          var cl=document.querySelector('.sw-fake-lk-'+pending);\n          if(cl)cl.classList.add('sw-lk-active');\n        }\n        if(!p.get('filter.p.product_option.lichtkleur')){\n          sessionStorage.removeItem('sw_lk_pending');\n        }\n      }\n    }catch(e){}\n  }\n  // Map: product handle pattern -> vorm\n  function getVorm(handle){\n    if(!handle)return null;\n    if(handle.indexOf('aristo')>-1||handle.indexOf('miran')>-1)return 'rond';\n    if(handle.indexOf('laom')>-1)return 'vierkant';\n    return null;\n  }\n  function applyVormFilter(){\n    var params=new URLSearchParams(window.location.search);\n    var actives=params.getAll('sw_vorm');\n    var cards=document.querySelectorAll('product-card, .product-card');\n    cards.forEach(function(c){\n      var link=c.querySelector('a[href*=\"/products/\"]');\n      var handle=link?link.getAttribute('href').split('/products/')[1].split('?')[0].split('#')[0]:'';\n      var vorm=getVorm(handle);\n      var gridItem=c.closest('li, .grid__item, .product-grid__card-wrapper')||c;\n      if(actives.length===0||(vorm&&actives.indexOf(vorm)>-1)){\n        gridItem.style.display='';\n      } else {\n        gridItem.style.display='none';\n      }\n    });\n  }\n  function addVormFilter(){\n    if(document.querySelector('.sw-vorm-facet'))return;\n    var kleurFacet=findFacetByName('Kleur');\n    if(!kleurFacet)return;\n    var vormHtml='<details class=\"facets__item sw-vorm-facet\" open><summary class=\"facets__summary\"><span class=\"facets__label\">Vorm</span><span class=\"facets__icon\"></span></summary><div class=\"facets__panel\"><ul class=\"facets__inputs facets__inputs-list\">'+\n      [{v:'rond',n:'Rond'},{v:'vierkant',n:'Vierkant'},{v:'rechthoek',n:'Rechthoek'}].map(function(o){\n        return '<li class=\"facets__inputs-list-item\"><label class=\"checkbox\"><input type=\"checkbox\" class=\"checkbox__input\" name=\"sw_vorm\" value=\"'+o.v+'\"><span class=\"checkbox__label\"><span class=\"icon-checkmark\"></span><span class=\"checkbox__label-text\">'+o.n+'</span></span></label></li>';\n      }).join('')+'</ul></div></details>';\n    kleurFacet.insertAdjacentHTML('beforebegin',vormHtml);\n    var vormInputs=document.querySelectorAll('.sw-vorm-facet input');\n    var urlParams=new URLSearchParams(window.location.search);\n    var activeVorms=urlParams.getAll('sw_vorm');\n    vormInputs.forEach(function(inp){\n      if(activeVorms.indexOf(inp.value)>-1)inp.checked=true;\n      inp.addEventListener('change',function(){\n        var params=new URLSearchParams(window.location.search);\n        params.delete('sw_vorm');\n        document.querySelectorAll('.sw-vorm-facet input:checked').forEach(function(i){\n          params.append('sw_vorm',i.value);\n        });\n        var newSearch=params.toString();\n        window.history.replaceState({},'','?'+newSearch);\n        applyVormFilter();\n      });\n    });\n    applyVormFilter();\n  }\n  var _runTimer=null;\n  function runAll(){rnK();addNeeOption();splitLichtkleur();addVormFilter();enhanceColCards();applyVormFilter();}\n  function runAllDebounced(){\n    if(_runTimer)clearTimeout(_runTimer);\n    _runTimer=setTimeout(runAll,120);\n  }\n  document.addEventListener('DOMContentLoaded',runAll);\n  setTimeout(runAll,600);\n  document.addEventListener('shopify:section:load',runAll);\n  var obs=new MutationObserver(function(muts){\n    var hasFacetChange=muts.some(function(m){\n      return Array.from(m.addedNodes).some(function(n){\n        return n.nodeType===1&&(n.classList&&(n.classList.contains('facets__item')||n.querySelector&&n.querySelector('.facets__item')));\n      });\n    });\n    if(hasFacetChange)runAllDebounced();else rnK();\n  });\n  document.addEventListener('DOMContentLoaded',function(){\n    var f=document.querySelector('.facets-block-wrapper--vertical,.facets__form-wrapper');\n    if(f)obs.observe(f,{childList:true,subtree:true});\n  });\n})();\n</script>",
