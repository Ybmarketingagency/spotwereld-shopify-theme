{
  "sections": {
    "spotwereld_product_enhancements": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{%- assign cf = '' -%}{%- if product.tags contains 'aristo' -%}{%- assign cf = 'aristo' -%}{%- endif -%}{%- if product.tags contains 'miran' -%}{%- assign cf = 'miran' -%}{%- endif -%}<style>.product-form__submit,.product-form button[type=\"submit\"],.button.button--primary[data-type=\"add-to-cart\"]{background:linear-gradient(135deg,#083D7D 0%,#0F6FE3 100%)!important;border:none!important;border-radius:8px!important;font-weight:700!important;letter-spacing:.03em!important;font-size:1rem!important}.product-form__submit:hover,.product-form button[type=\"submit\"]:hover{background:linear-gradient(135deg,#062d5c 0%,#0a5abf 100%)!important}.shopify-payment-button__button--unbranded{background:linear-gradient(135deg,#0F6FE3 0%,#083D7D 100%)!important;border-radius:8px!important}.sw-color-picker a:hover{border-color:#061f40!important}.sw-spec-badges{display:flex;flex-wrap:wrap;gap:.5rem;margin:.75rem 0 1rem}.sw-spec-badge{display:inline-flex;align-items:center;gap:.375rem;padding:.3rem .7rem;background:#f0f4f8;border-radius:20px;font-size:.8rem;color:#374151;font-weight:500}.sw-spec-badge strong{color:#061f40;font-weight:700}</style>{%- if cf != '' -%}{%- assign ck = product.options_with_values[0].values[0] -%}<div id=\"sw-color-data\" style=\"display:none\" data-current-handle=\"{{ product.handle }}\" data-current-color=\"{{ ck | escape }}\">{%- for p in collections['inbouwspots'].products -%}{%- if p.tags contains cf -%}{%- assign pk = p.options_with_values[0].values[0] -%}<span data-handle=\"{{ p.handle }}\" data-color=\"{{ pk | escape }}\" data-url=\"{{ p.url }}\"></span>{%- endif -%}{%- endfor -%}</div><script>document.addEventListener('DOMContentLoaded',function(){var d=document.getElementById('sw-color-data');if(!d)return;var currentHandle=d.dataset.currentHandle,currentColor=d.dataset.currentColor,items=d.querySelectorAll('span');var html='<div class=\"sw-color-picker\" style=\"margin:0 0 1rem\"><p style=\"font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin:0 0 .625rem\">Kleur: <strong style=\"color:#061f40\">\"+currentColor+\"</strong></p><div style=\"display:flex;flex-wrap:wrap;gap:.5rem\">';items.forEach(function(s){var isActive=s.dataset.handle===currentHandle;html+=isActive?'<span style=\"display:inline-flex;align-items:center;padding:.375rem .875rem;border:2px solid #061f40;border-radius:4px;font-size:.875rem;color:#fff;background:#061f40;font-weight:600\">'+s.dataset.color+'</span>':'<a href=\"'+s.dataset.url+'\" style=\"display:inline-flex;align-items:center;padding:.375rem .875rem;border:1.5px solid #d1d5db;border-radius:4px;font-size:.875rem;color:#061f40;background:#fff;text-decoration:none\">'+s.dataset.color+'</a>';});html+='</div></div>';var buyBtn=document.querySelector('.product-form__submit,.product-form button[type=\"submit\"]');if(buyBtn){var container=buyBtn.closest('.product-form')||buyBtn.parentElement;if(container)container.insertAdjacentHTML('beforebegin',html);}var specBadges='<div class=\"sw-spec-badges\"><span class=\"sw-spec-badge\"><strong>IP65</strong> Spatwaterdicht</span><span class=\"sw-spec-badge\"><strong>CCT</strong> 2700K/3000K/4000K</span><span class=\"sw-spec-badge\"><strong>Dimbaar</strong> via schakelaar</span><span class=\"sw-spec-badge\">&#10003; <strong>29mm</strong> inbouwdiepte</span></div>';var colorPicker=document.querySelector('.sw-color-picker');if(colorPicker)colorPicker.insertAdjacentHTML('beforebegin',specBadges);});</script>{%- endif -%}",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
