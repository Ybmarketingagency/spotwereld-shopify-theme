5rem;color:#1e293b;border-bottom:1px solid #e5e7eb\">25.000 uur</td></tr><tr style=\"background:#f8fafc\"><td style=\"padding:.625rem .875rem;font-weight:600;color:#374151;border-bottom:1px solid #e5e7eb\">Spanning</td><td style=\"padding:.625rem .875rem;color:#1e293b;border-bottom:1px solid #e5e7eb\">230V</td></tr><tr><td style=\"padding:.625rem .875rem;font-weight:600;color:#374151\">Lichtkleur</td><td style=\"padding:.625rem .875rem;color:#1e293b\">{%- if product.tags contains 'aristo' or product.tags contains 'miran' -%}2700K / 3000K / 4000K (instelbaar){%- else -%}{{ product.metafields.custom.lichtkleur | default: '2700K (warm-wit)' }}{%- endif -%}</td></tr></table></div></div></div></section><style>@media(max-width:749px){section .sw-desc-grid{grid-template-columns:1fr!important}}</style>",
