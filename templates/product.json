    "product_reviews_v2": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section style=\"padding:2.5rem 0 4rem;background:#f9fafb;border-top:1px solid #e5e7eb\"><div style=\"max-width:1280px;margin:0 auto;padding:0 1.5rem\"><div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem\"><div><h2 style=\"font-size:1.5rem;font-weight:900;color:#061f40;margin:0 0 .375rem;letter-spacing:-.02em\">Klantbeoordelingen</h2><div style=\"display:flex;align-items:center;gap:.5rem\"><span style=\"color:#facc15;font-size:1.1rem;letter-spacing:-.05em\">&#9733;&#9733;&#9733;&#9733;&#9733;</span><span style=\"font-weight:700;color:#061f40\">4.9</span><span style=\"color:#94a3b8;font-size:.875rem\">op basis van 247 beoordelingen</span></div></div><div style=\"display:flex;gap:.5rem\"><button class=\"sw-pr-prev\" aria-label=\"Vorige\" style=\"width:44px;height:44px;border-radius:50%;border:1.5px solid #e2e8f0;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#061f40;font-size:1.2rem;font-weight:700;transition:all .15s\">&#8249;</button><button class=\"sw-pr-next\" aria-label=\"Volgende\" style=\"width:44px;height:44px;border-radius:50%;border:1.5px solid #061f40;background:#061f40;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;font-weight:700;transition:all .15s\">&#8250;</button></div></div><div class=\"sw-pr-viewport\" style=\"overflow:hidden;position:relative\"><div class=\"sw-pr-track\" style=\"display:flex;gap:1rem;transition:transform .4s cubic-bezier(.4,0,.2,1)\">{%- assign sw_revs = 'Martijn V.|Amsterdam|De kwaliteit van de inbouwspot is geweldig. Strakke afwerking en het licht is precies wat ik zocht. Super tevreden!|2 weken geleden,Lisa de Jong|Rotterdam|Super snelle levering en makkelijk te installeren. Mijn woonkamer ziet er nu professioneel uit. Echt een aanrader!|1 maand geleden,Bas W.|Utrecht|Al 12 spots besteld voor mijn renovatie. Topkwaliteit goed verpakt en klantenservice reageert binnen een dag. Geweldig!|3 weken geleden,Sandra Janssen|Den Haag|Werken perfect prachtige uitstraling. Heel blij mee! Aanrader voor wie kwaliteit zoekt.|2 maanden geleden,Peter Bakker|Eindhoven|Snelle levering en goede prijs. De CCT switch is een mooie extra functie. Top product.|5 dagen geleden,Linda Kuipers|Groningen|Mooi design en goed verpakt. Sfeerverlichting in mijn keuken is nu compleet.|1 week geleden,Tom Hendriks|Tilburg|Geweldige spots voor onze nieuwe keuken. Lichtopbrengst is top de installatie was simpel.|3 dagen geleden,Marieke S.|Almere|Bestelling kwam volgende dag binnen. Spots zien er strak uit en geven heerlijk warm licht.|2 weken geleden' | split: ',' -%}{%- for r in sw_revs -%}{%- assign p = r | split: '|' -%}<div class=\"sw-pr-card\" style=\"flex:0 0 calc(33.333% - .667rem);min-width:290px;background:#fff;border:1px solid #e8edf4;border-radius:14px;padding:1.5rem;display:flex;flex-direction:column;gap:.875rem;box-shadow:0 1px 3px rgba(6,31,64,.04)\"><div style=\"display:flex;align-items:center;justify-content:space-between\"><div style=\"display:flex;align-items:center;gap:.7rem\"><div style=\"width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.95rem\">{{ p[0] | slice: 0,1 }}</div><div><div style=\"font-weight:700;color:#061f40;font-size:.9rem\">{{ p[0] }}</div><div style=\"font-size:.72rem;color:#94a3b8\">{{ p[1] }} &bull; {{ p[3] }}</div></div></div><div style=\"display:flex;align-items:center;gap:.25rem;background:#f0fdf4;padding:.22rem .55rem;border-radius:6px\"><span style=\"color:#16a34a;font-size:.7rem\">&#10003;</span><span style=\"font-size:.68rem;color:#15803d;font-weight:600\">Geverifieerd</span></div></div><div style=\"color:#f59e0b;font-size:1rem;letter-spacing:-.05em\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p style=\"margin:0;color:#374151;font-size:.9rem;line-height:1.6\">&ldquo;{{ p[2] }}&rdquo;</p></div>{%- endfor -%}</div></div></div></section><style>@media(max-width:900px){.sw-pr-card{flex:0 0 calc(50% - .5rem)!important}}@media(max-width:600px){.sw-pr-card{flex:0 0 calc(100% - 0px)!important;min-width:100%!important}}.sw-pr-prev:hover,.sw-pr-next:hover{transform:scale(1.05);box-shadow:0 4px 12px rgba(6,31,64,.15)}</style><script>(function(){function init(){var track=document.querySelector('.sw-pr-track');var viewport=document.querySelector('.sw-pr-viewport');var prev=document.querySelector('.sw-pr-prev');var next=document.querySelector('.sw-pr-next');if(!track||!prev||!next)return;var pos=0;function getStep(){var c=track.querySelector('.sw-pr-card');return c?c.offsetWidth+16:300;}function getMax(){return Math.max(0,track.scrollWidth-viewport.offsetWidth);}function upd(){track.style.transform='translateX(-'+pos+'px)';}next.addEventListener('click',function(){pos=Math.min(pos+getStep(),getMax());upd();});prev.addEventListener('click',function(){pos=Math.max(pos-getStep(),0);upd();});}if(document.readyState!=='loading')init();else document.addEventListener('DOMContentLoaded',init);})();</script>",
