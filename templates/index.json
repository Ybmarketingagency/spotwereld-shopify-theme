        "custom_liquid": "<style>.sw-usp{display:grid;grid-template-columns:repeat(2,1fr)}@media(min-width:768px){.sw-usp{grid-template-columns:repeat(4,1fr)}}</style><div style=\"background:#f3f4f6;border-bottom:1px solid #e5e7eb\"><div style=\"max-width:1280px;margin:0 auto;padding:0 1rem\"><div class=\"sw-usp\"><div style=\"display:flex;align-items:center;gap:0.75rem;padding:1.25rem 1rem;border-right:1px solid #e5e7eb\"><div style=\"width:2.5rem;height:2.5rem;border-radius:9999px;background:#EBF2FF;display:flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#083D7D\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"/><polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg></div><div><p style=\"font-weight:600;color:#111827;font-size:0.875rem;margin:0\">Gratis Verzending</p><p style=\"color:#6b7280;font-size:0.75rem;margin:0\">Bij bestellingen boven &euro;50</p></div></div><div style=\"display:flex;align-items:center;gap:0.75rem;padding:1.25rem 1rem;border-right:1px solid #e5e7eb\"><div style=\"width:2.5rem;height:2.5rem;border-radius:9999px;background:#EBF2FF;display:flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#083D7D\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"/></svg></div><div><p style=\"font-weight:600;color:#111827;font-size:0.875rem;margin:0\">Snelle Levering</p><p style=\"color:#6b7280;font-size:0.75rem;margin:0\">Voor 22:00 besteld, morgen in huis</p></div></div><div style=\"display:flex;align-items:center;gap:0.75rem;padding:1.25rem 1rem;border-right:1px solid #e5e7eb\"><div style=\"width:2.5rem;height:2.5rem;border-radius:9999px;background:#EBF2FF;display:flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#083D7D\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg></div><div><p style=\"font-weight:600;color:#111827;font-size:0.875rem;margin:0\">2 Jaar Garantie</p><p style=\"color:#6b7280;font-size:0.75rem;margin:0\">Kwaliteit gegarandeerd</p></div></div><div style=\"display:flex;align-items:center;gap:0.75rem;padding:1.25rem 1rem\"><div style=\"width:2.5rem;height:2.5rem;border-radius:9999px;background:#EBF2FF;display:flex;align-items:center;justify-content:center;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#083D7D\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"1 4 1 10 7 10\"/><path d=\"M3.51 15a9 9 0 1 0 .49-4.47\"/></svg></div><div><p style=\"font-weight:600;color:#111827;font-size:0.875rem;margin:0\">30 Dagen Retour</p><p style=\"color:#6b7280;font-size:0.75rem;margin:0\">Niet goed, geld terug</p></div></div></div></div></div>",
