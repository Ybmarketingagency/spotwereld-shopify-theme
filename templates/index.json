    "spotwereld_reviews": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.sw-rev-wrap{overflow:hidden}.sw-rev-track{display:flex;transition:transform 0.4s ease}.sw-rev-item{flex-shrink:0;padding:0 0.75rem;box-sizing:border-box}.sw-rev-card{background:rgba(255,255,255,0.1);border-radius:1rem;padding:1.5rem;border:1px solid rgba(255,255,255,0.2);display:flex;flex-direction:column;gap:1rem;height:100%;box-sizing:border-box}.sw-rev-text{color:#bfdbfe;font-size:0.875rem;line-height:1.6;flex:1;margin:0}.sw-rev-author{font-weight:700;color:#fff;font-size:0.875rem;margin:0}.sw-rev-city{color:#93c5fd;font-size:0.75rem;margin:0.125rem 0 0}.sw-rev-nav{display:flex;justify-content:center;align-items:center;gap:1rem;margin-top:2rem}.sw-rev-btn{width:2.75rem;height:2.75rem;border-radius:50%;border:2px solid rgba(255,255,255,0.5);background:transparent;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0}.sw-rev-btn:hover{background:rgba(255,255,255,0.15);border-color:#fff}</style><section style=\"padding:5rem 0;background:#083D7D\"><div style=\"max-width:1280px;margin:0 auto;padding:0 1.5rem\"><div style=\"text-align:center;margin-bottom:2.5rem\"><div style=\"font-size:1.5rem;color:#facc15;margin-bottom:0.75rem\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><h2 style=\"font-size:1.75rem;font-weight:800;color:#fff;margin:0 0 0.375rem\">Wat onze klanten zeggen</h2><p style=\"color:#93c5fd;font-size:0.9375rem;margin:0\">500+ tevreden klanten gingen je voor</p></div><div class=\"sw-rev-wrap\" id=\"swRevWrap\"><div class=\"sw-rev-track\" id=\"swRevTrack\"><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;Super snelle levering en de inbouwspots zien er prachtig uit. Echt een verschil met mijn oude verlichting. Absoluut aanrader!&rdquo;</p><div><p class=\"sw-rev-author\">Thomas de Vries</p><p class=\"sw-rev-city\">Amsterdam</p></div></div></div><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;Geweldige kwaliteit voor een eerlijke prijs. De klantenservice heeft me goed geholpen bij het kiezen van de juiste spots voor mijn woonkamer.&rdquo;</p><div><p class=\"sw-rev-author\">Laura Bakker</p><p class=\"sw-rev-city\">Rotterdam</p></div></div></div><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;Besteld op maandag, woensdag al geleverd. De LED strips zijn van topkwaliteit en makkelijk te installeren. Heel tevreden!&rdquo;</p><div><p class=\"sw-rev-author\">Stefan Hendriks</p><p class=\"sw-rev-city\">Utrecht</p></div></div></div><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;De hanglampen zijn nog mooier dan op de foto. Strak ontwerp, heel aangenaam licht. Onze eetkamer is er echt mee getransformeerd!&rdquo;</p><div><p class=\"sw-rev-author\">Marieke van den Berg</p><p class=\"sw-rev-city\">Den Haag</p></div></div></div><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;Al meerdere keren bij Spotwereld besteld. Altijd dezelfde topkwaliteit en de bezorging is altijd snel. Ik bestel nergens anders meer.&rdquo;</p><div><p class=\"sw-rev-author\">Joost Vermeer</p><p class=\"sw-rev-city\">Eindhoven</p></div></div></div><div class=\"sw-rev-item\"><div class=\"sw-rev-card\"><div style=\"color:#facc15\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class=\"sw-rev-text\">&ldquo;De trapverlichting is prachtig! Stapsgewijs oplichten is precies wat ik zocht. Montage was eenvoudig dankzij de duidelijke handleiding.&rdquo;</p><div><p class=\"sw-rev-author\">Anke de Boer</p><p class=\"sw-rev-city\">Groningen</p></div></div></div></div></div><div class=\"sw-rev-nav\"><button class=\"sw-rev-btn\" id=\"swRevPrev\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"15 18 9 12 15 6\"/></svg></button><div style=\"display:flex;gap:0.5rem;align-items:center\" id=\"swRevDots\"></div><button class=\"sw-rev-btn\" id=\"swRevNext\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"9 18 15 12 9 6\"/></svg></button></div></div></section><script>var swRevCur=0,swRevTotal=6;function swRevVis(){var w=document.getElementById('swRevWrap').offsetWidth;return w<640?1:w<1024?2:3;}function swRevPages(){return Math.ceil(swRevTotal/swRevVis());}function swRevBuild(){var vis=swRevVis(),iw=document.getElementById('swRevWrap').offsetWidth/vis;document.querySelectorAll('.sw-rev-item').forEach(function(el){el.style.width=iw+'px';el.style.minWidth=iw+'px';});var dc=document.getElementById('swRevDots');dc.innerHTML='';for(var i=0;i<swRevPages();i++){var d=document.createElement('button');d.style.cssText='width:.5rem;height:.5rem;border-radius:50%;border:none;padding:0;cursor:pointer;background:'+(i===swRevCur?'#fff':'rgba(255,255,255,0.3)');d.setAttribute('data-i',i);d.onclick=function(){swRevGo(+this.getAttribute('data-i'));};dc.appendChild(d);}}function swRevGo(p){var pages=swRevPages();swRevCur=(p+pages)%pages;var vis=swRevVis(),iw=document.getElementById('swRevWrap').offsetWidth/vis;document.getElementById('swRevTrack').style.transform='translateX(-'+(swRevCur*vis*iw)+'px)';document.querySelectorAll('#swRevDots button').forEach(function(d,i){d.style.background=i===swRevCur?'#fff':'rgba(255,255,255,0.3)';});}document.getElementById('swRevPrev').addEventListener('click',function(){swRevGo(swRevCur-1);});document.getElementById('swRevNext').addEventListener('click',function(){swRevGo(swRevCur+1);});swRevBuild();window.addEventListener('resize',function(){swRevBuild();swRevGo(0);});<\/script>",
        "color_scheme": "",
