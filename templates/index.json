    "spotwereld_help_banner": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.sw-help-grid{display:grid;grid-template-columns:1fr;gap:1.5rem}@media(min-width:768px){.sw-help-grid{grid-template-columns:repeat(3,1fr)}}.sw-help-card{background:rgba(255,255,255,0.1);border-radius:1rem;padding:1.25rem;transition:background 0.2s}.sw-help-card:hover{background:rgba(255,255,255,0.2)}</style><div style=\"background:#061f40;padding:2rem 0 3rem\"><div style=\"max-width:72rem;margin:0 auto;padding:0 1.5rem\"><div style=\"position:relative;background:linear-gradient(135deg,#142957,#1a3d8f);border-radius:1.5rem;overflow:hidden;box-shadow:0 25px 50px -12px rgba(0,0,0,0.25)\"><div style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;opacity:0.1\"><div style=\"position:absolute;top:20px;left:40px;width:12rem;height:12rem;border:2px solid #fff;border-radius:9999px\"></div><div style=\"position:absolute;bottom:-40px;right:-40px;width:16rem;height:16rem;border:2px solid #fff;border-radius:9999px\"></div></div><div style=\"position:relative;padding:2rem 2.5rem\"><div class=\"sw-help-grid\"><div style=\"color:#fff\"><h2 style=\"font-size:1.5rem;font-weight:700;color:#fff;margin:0 0 0.5rem\">Kunnen we je helpen?</h2><p style=\"font-size:0.875rem;color:#bfdbfe;line-height:1.6;margin:0\">Onze klantenservice denkt graag met je mee. Samen zorgen we voor de juiste oplossing in elke situatie.</p></div><div class=\"sw-help-card\"><div style=\"display:flex;align-items:flex-start;gap:0.75rem\"><div style=\"background:#fff;border-radius:9999px;padding:0.75rem;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#142957\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg></div><div><h3 style=\"font-size:1.125rem;font-weight:600;color:#fff;margin:0 0 0.5rem\">Snel regelen in je account</h3><div style=\"display:flex;flex-direction:column;gap:0.25rem\"><a href=\"/account\" style=\"font-size:0.875rem;color:#bfdbfe;text-decoration:underline\">Volg je bestelling</a><a href=\"/account\" style=\"font-size:0.875rem;color:#bfdbfe;text-decoration:underline\">Wijzig gegevens</a><a href=\"/account\" style=\"font-size:0.875rem;color:#bfdbfe;text-decoration:underline\">Retourneer een artikel</a></div></div></div></div><div class=\"sw-help-card\"><div style=\"display:flex;align-items:flex-start;gap:0.75rem\"><div style=\"background:#fff;border-radius:9999px;padding:0.75rem;flex-shrink:0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#142957\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg></div><div><h3 style=\"font-size:1.125rem;font-weight:600;color:#fff;margin:0 0 0.5rem\">Advies nodig?</h3><p style=\"font-size:0.875rem;color:#bfdbfe;margin:0 0 0.25rem\">Bel <a href=\"tel:0850600936\" style=\"font-weight:600;color:#fff\">(0)85 060 09 36</a>.</p><p style=\"font-size:0.875rem;color:#bfdbfe;margin:0\">Onze <a href=\"tel:0850600936\" style=\"text-decoration:underline;color:#bfdbfe\">klantenservice</a> is bereikbaar van ma t/m vr 08:30 tot 17:00.</p></div></div></div></div><div style=\"margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem\"><span style=\"font-weight:600;font-size:0.875rem;color:#fff\">Veilig betalen met:</span><div style=\"display:flex;gap:0.75rem;flex-wrap:wrap\"><div style=\"background:#fff;border-radius:0.5rem;padding:0.375rem 0.75rem\"><img src=\"https://i.imgur.com/R6phmdS.jpeg\" alt=\"iDEAL\" style=\"height:1.25rem;width:auto;object-fit:contain\"></div><div style=\"background:#fff;border-radius:0.5rem;padding:0.375rem 0.75rem\"><img src=\"https://i.imgur.com/4TBWuxJ.jpeg\" alt=\"Visa\" style=\"height:1.25rem;width:auto;object-fit:contain\"></div><div style=\"background:#fff;border-radius:0.5rem;padding:0.375rem 0.75rem\"><img src=\"https://i.imgur.com/NZVHnOX.jpeg\" alt=\"Mastercard\" style=\"height:1.25rem;width:auto;object-fit:contain\"></div><div style=\"background:#fff;border-radius:0.5rem;padding:0.375rem 0.75rem\"><img src=\"https://i.imgur.com/w6Prqtx.jpeg\" alt=\"Klarna\" style=\"height:1.25rem;width:auto;object-fit:contain\"></div></div></div></div></div></div></div>",
