    "spotwereld_populaire_producten": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>.sw-pp-outer{position:relative}.sw-pp-wrap{overflow:hidden}.sw-pp-track{display:flex;transition:transform .4s ease;gap:1rem}.sw-pp-card{flex-shrink:0;background:#fff;border:1px solid #e5e7eb;border-radius:.75rem;padding:.875rem .875rem 1rem;box-sizing:border-box;text-decoration:none;color:inherit;display:flex;flex-direction:column;position:relative;transition:all .2s;box-shadow:0 1px 2px rgba(0,0,0,.04)}.sw-pp-card:hover{border-color:#cbd5e1;box-shadow:0 4px 16px rgba(8,61,125,.1);transform:translateY(-2px)}.sw-pp-badge{position:absolute;top:.5rem;left:.5rem;z-index:2;display:inline-flex;align-items:center;gap:.25rem;font-size:.68rem;font-weight:700;padding:.22rem .5rem;border-radius:4px;letter-spacing:.02em}.sw-pp-badge--korting{background:#f97316;color:#fff}.sw-pp-badge--bestseller{background:#16a34a;color:#fff}.sw-pp-badge--nieuw{background:#0F6FE3;color:#fff}.sw-pp-stock{position:absolute;top:.5rem;right:.5rem;z-index:2;font-size:.65rem;font-weight:600;color:#16a34a;background:rgba(255,255,255,.95);padding:.18rem .45rem;border-radius:4px;display:inline-flex;align-items:center;gap:.25rem}.sw-pp-stock::before{content:'';width:6px;height:6px;border-radius:50%;background:#16a34a}.sw-pp-img-wrap{aspect-ratio:1;background:#f8fafc;border-radius:.5rem;overflow:hidden;margin-bottom:.625rem;display:flex;align-items:center;justify-content:center}.sw-pp-img{width:100%;height:100%;object-fit:contain;display:block}.sw-pp-name{font-weight:600;color:#1e293b;font-size:.85rem;margin:0 0 .375rem;line-height:1.35;min-height:2.3em;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.sw-pp-stars{color:#f59e0b;font-size:.72rem;letter-spacing:-.05em;margin-bottom:.25rem}.sw-pp-stars span{color:#94a3b8;font-size:.7rem;margin-left:.2rem;letter-spacing:0}.sw-pp-pricewrap{display:flex;align-items:baseline;gap:.4rem;margin-bottom:.625rem}.sw-pp-price{color:#061f40;font-weight:800;font-size:1.05rem;margin:0;line-height:1}.sw-pp-compare{color:#94a3b8;font-size:.78rem;text-decoration:line-through}.sw-pp-cart{display:flex;align-items:center;justify-content:center;gap:.4rem;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;border:none;border-radius:.5rem;padding:.55rem .75rem;font-weight:700;font-size:.82rem;cursor:pointer;width:100%;transition:all .15s;letter-spacing:.01em}.sw-pp-cart:hover{background:linear-gradient(135deg,#062d5c,#0a5abf);transform:translateY(-1px)}.sw-pp-cart svg{flex-shrink:0}.sw-pp-btn{position:absolute;top:calc(50% - 2rem);transform:translateY(-50%);width:2.75rem;height:2.75rem;border-radius:50%;background:#fff;border:2px solid #e5e7eb;box-shadow:0 2px 8px rgba(0,0,0,.12);cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:3;transition:all .2s;color:#111827}.sw-pp-btn:hover{background:#083D7D;border-color:#083D7D;color:#fff}#swPpPrev{left:-.75rem}#swPpNext{right:-.75rem}</style><section style=\"padding:3rem 0 3.5rem;background:#f8fafc\"><div style=\"max-width:1280px;margin:0 auto;padding:0 2rem\"><div style=\"display:flex;align-items:center;gap:1rem;margin-bottom:1.75rem\"><div><h2 style=\"font-size:1.5rem;font-weight:800;color:#061f40;margin:0;letter-spacing:-.02em\">Populaire Producten</h2><p style=\"color:#6b7280;font-size:.875rem;margin:.25rem 0 0\">Onze best verkochte LED spots en lampen</p></div><div style=\"flex:1;height:1px;background:linear-gradient(to right,#0F6FE3,transparent);min-width:50px\"></div></div><div class=\"sw-pp-outer\" style=\"padding:0 1.25rem\"><button class=\"sw-pp-btn\" id=\"swPpPrev\" aria-label=\"Vorige\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"15 18 9 12 15 6\"/></svg></button><div class=\"sw-pp-wrap\" id=\"swPpWrap\"><div class=\"sw-pp-track\" id=\"swPpTrack\">{%- assign pp_col = collections['inbouwspots'] -%}{%- assign sw_kortingen = ',-20% Korting,,,-15% Korting,,,-10% Korting' | split: ',' -%}{%- if pp_col -%}{%- for prod in pp_col.products limit:8 -%}{%- assign sw_kort = sw_kortingen[forloop.index0] -%}<a href=\"{{ prod.url }}\" class=\"sw-pp-card\">{%- if prod.compare_at_price > prod.price -%}{%- assign sw_pct = prod.compare_at_price | minus: prod.price | times: 100 | divided_by: prod.compare_at_price -%}<span class=\"sw-pp-badge sw-pp-badge--korting\">-{{ sw_pct }}% Korting</span>{%- elsif sw_kort != '' -%}<span class=\"sw-pp-badge sw-pp-badge--korting\">{{ sw_kort }}</span>{%- endif -%}{%- if prod.available -%}<span class=\"sw-pp-stock\">Op voorraad</span>{%- endif -%}<div class=\"sw-pp-img-wrap\"><img class=\"sw-pp-img\" src=\"{{ prod.featured_image | img_url: '400x400' }}\" alt=\"{{ prod.title | escape }}\" loading=\"lazy\"></div><p class=\"sw-pp-name\">{{ prod.title | remove: 'LED Inbouwspot ' }}</p><div class=\"sw-pp-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<span>(4.9)</span></div><div class=\"sw-pp-pricewrap\"><p class=\"sw-pp-price\">{{ prod.price_min | money }}</p>{%- if prod.compare_at_price > prod.price -%}<span class=\"sw-pp-compare\">{{ prod.compare_at_price | money }}</span>{%- endif -%}</div><span class=\"sw-pp-cart\">Bekijk Product <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg></span></a>{%- endfor -%}{%- endif -%}</div></div><button class=\"sw-pp-btn\" id=\"swPpNext\" aria-label=\"Volgende\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"9 18 15 12 9 6\"/></svg></button></div></div></section><script>var swPpCur=0;function swPpVis(){var w=document.getElementById('swPpWrap').offsetWidth;return w<640?2:w<1024?3:4;}function swPpBuild(){var vis=swPpVis(),gap=16,wrap=document.getElementById('swPpWrap'),iw=(wrap.offsetWidth-(gap*(vis-1)))/vis;document.querySelectorAll('.sw-pp-card').forEach(function(el){el.style.width=iw+'px';el.style.minWidth=iw+'px';});}function swPpGo(dir){var vis=swPpVis(),n=document.querySelectorAll('.sw-pp-card').length,max=Math.max(0,n-vis),gap=16,iw=(document.getElementById('swPpWrap').offsetWidth-(gap*(vis-1)))/vis;swPpCur=Math.min(Math.max(swPpCur+dir,0),max);document.getElementById('swPpTrack').style.transform='translateX(-'+(swPpCur*(iw+gap))+'px)';}document.getElementById('swPpPrev').addEventListener('click',function(e){e.preventDefault();swPpGo(-1);});document.getElementById('swPpNext').addEventListener('click',function(e){e.preventDefault();swPpGo(1);});swPpBuild();window.addEventListener('resize',function(){swPpBuild();swPpCur=0;document.getElementById('swPpTrack').style.transform='translateX(0)';});<\/script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
