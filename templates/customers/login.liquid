{% layout 'theme' %}

<style>
.sw-auth-wrap{min-height:calc(100vh - 200px);display:flex;align-items:center;justify-content:center;padding:3rem 1.25rem;background:linear-gradient(135deg,#f8fafc 0%,#eef2f9 100%);position:relative;overflow:hidden}
.sw-auth-wrap::before{content:'';position:absolute;top:-200px;right:-200px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(15,111,227,0.08) 0%,transparent 70%);pointer-events:none}
.sw-auth-wrap::after{content:'';position:absolute;bottom:-150px;left:-150px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(8,61,125,0.06) 0%,transparent 70%);pointer-events:none}
.sw-auth-card{background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(6,31,64,.08),0 4px 12px rgba(6,31,64,.04);max-width:440px;width:100%;padding:2.5rem 2rem;position:relative;z-index:1;border:1px solid rgba(226,232,240,.6)}
.sw-auth-logo{display:flex;align-items:center;justify-content:center;gap:.5rem;margin-bottom:1.5rem}
.sw-auth-logo img{width:36px;height:36px}
.sw-auth-logo span{font-weight:900;font-size:1.4rem;color:#061f40;letter-spacing:-.02em}
.sw-auth-logo span em{font-style:normal;color:#facc15}
.sw-auth-title{font-size:1.75rem;font-weight:900;color:#061f40;margin:0 0 .375rem;text-align:center;letter-spacing:-.02em}
.sw-auth-sub{color:#64748b;text-align:center;margin:0 0 1.75rem;font-size:.92rem;line-height:1.5}
.sw-auth-field{margin-bottom:1rem}
.sw-auth-label{display:block;font-size:.78rem;font-weight:700;color:#475569;margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em}
.sw-auth-input{width:100%;padding:.85rem 1rem;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.95rem;outline:none;transition:all .15s;box-sizing:border-box;font-family:inherit;background:#fff;color:#1e293b}
.sw-auth-input:focus{border-color:#0F6FE3;box-shadow:0 0 0 3px rgba(15,111,227,.12)}
.sw-auth-row{display:flex;justify-content:space-between;align-items:center;margin:0 0 1.25rem;font-size:.85rem}
.sw-auth-row a{color:#0F6FE3;text-decoration:none;font-weight:600}
.sw-auth-row a:hover{text-decoration:underline}
.sw-auth-btn{width:100%;background:linear-gradient(135deg,#083D7D,#0F6FE3);color:#fff;border:0;border-radius:8px;padding:.95rem 1rem;font-weight:700;font-size:.95rem;cursor:pointer;transition:all .15s;font-family:inherit;letter-spacing:.01em;display:inline-flex;align-items:center;justify-content:center;gap:.4rem}
.sw-auth-btn:hover{background:linear-gradient(135deg,#062d5c,#0a5abf);transform:translateY(-1px);box-shadow:0 6px 16px rgba(8,61,125,.25)}
.sw-auth-divider{display:flex;align-items:center;gap:.75rem;margin:1.5rem 0;color:#94a3b8;font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;font-weight:600}
.sw-auth-divider::before,.sw-auth-divider::after{content:'';flex:1;height:1px;background:#e2e8f0}
.sw-auth-alt{text-align:center;margin:0;color:#64748b;font-size:.9rem}
.sw-auth-alt a{color:#0F6FE3;font-weight:700;text-decoration:none}
.sw-auth-alt a:hover{text-decoration:underline}
.sw-auth-errors{background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:.75rem 1rem;border-radius:8px;margin:0 0 1rem;font-size:.85rem;line-height:1.5}
.sw-auth-errors ul{margin:0;padding-left:1.25rem}
.sw-auth-success{background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;padding:.75rem 1rem;border-radius:8px;margin:0 0 1rem;font-size:.85rem}
.sw-auth-trust{display:flex;justify-content:center;gap:1.5rem;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #f0f3f8;color:#64748b;font-size:.72rem}
.sw-auth-trust span{display:flex;align-items:center;gap:.25rem}
.sw-auth-recover{display:none}
.sw-auth-recover.sw-show{display:block}
.sw-auth-login.sw-hide{display:none}
@media(max-width:480px){.sw-auth-card{padding:1.75rem 1.25rem}.sw-auth-title{font-size:1.4rem}}
</style>

<div class="sw-auth-wrap">
  <div class="sw-auth-card">
    <div class="sw-auth-logo">
      <img src="https://i.imgur.com/2ROeTRS.png" alt="Spotwereld">
      <span>Spot<em>wereld</em></span>
    </div>

    {%- comment -%} LOGIN FORM {%- endcomment -%}
    <div class="sw-auth-login" id="sw-login-pane">
      <h1 class="sw-auth-title">Welkom terug</h1>
      <p class="sw-auth-sub">Log in om je bestellingen te bekijken en sneller af te rekenen.</p>

      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <div class="sw-auth-errors">
            <strong>Inloggen mislukt</strong>
            <ul>
              {%- for field in form.errors -%}
                <li>{{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="sw-auth-field">
          <label for="CustomerEmail" class="sw-auth-label">E-mail</label>
          <input type="email" name="customer[email]" id="CustomerEmail" class="sw-auth-input" autocomplete="email" autocapitalize="off" autocorrect="off" required placeholder="jouw@email.nl">
        </div>

        {%- if form.password_needed -%}
          <div class="sw-auth-field">
            <label for="CustomerPassword" class="sw-auth-label">Wachtwoord</label>
            <input type="password" name="customer[password]" id="CustomerPassword" class="sw-auth-input" autocomplete="current-password" required placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;">
          </div>

          <div class="sw-auth-row">
            <span></span>
            <a href="#sw-recover" id="sw-recover-link">Wachtwoord vergeten?</a>
          </div>
        {%- endif -%}

        <button type="submit" class="sw-auth-btn">
          Inloggen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      {%- endform -%}

      <div class="sw-auth-divider">Nieuw bij Spotwereld?</div>
      <p class="sw-auth-alt"><a href="{{ routes.account_register_url }}">Maak een account aan &rarr;</a></p>
    </div>

    {%- comment -%} RECOVER PASSWORD PANE {%- endcomment -%}
    <div class="sw-auth-recover" id="sw-recover-pane">
      <h1 class="sw-auth-title">Wachtwoord vergeten?</h1>
      <p class="sw-auth-sub">Geen probleem. Vul je e-mail in en we sturen je een link om een nieuw wachtwoord in te stellen.</p>

      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <div class="sw-auth-success">
            &#10003; We hebben je een e-mail gestuurd met instructies om je wachtwoord opnieuw in te stellen.
          </div>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="sw-auth-errors">
            <ul>{% for field in form.errors %}<li>{{ form.errors.messages[field] }}</li>{% endfor %}</ul>
          </div>
        {%- endif -%}

        <div class="sw-auth-field">
          <label for="RecoverEmail" class="sw-auth-label">E-mail</label>
          <input type="email" name="email" id="RecoverEmail" class="sw-auth-input" autocomplete="email" required placeholder="jouw@email.nl">
        </div>

        <button type="submit" class="sw-auth-btn">Stuur reset-link</button>
      {%- endform -%}

      <div class="sw-auth-divider">of</div>
      <p class="sw-auth-alt"><a href="#sw-login" id="sw-back-login">&larr; Terug naar inloggen</a></p>
    </div>

    <div class="sw-auth-trust">
      <span>&#128274; Veilig &amp; versleuteld</span>
      <span>&#9889; Snel afrekenen</span>
    </div>
  </div>
</div>

<script>
(function(){
  var loginPane = document.getElementById('sw-login-pane');
  var recoverPane = document.getElementById('sw-recover-pane');
  var recoverLink = document.getElementById('sw-recover-link');
  var backLink = document.getElementById('sw-back-login');
  function showRecover(){ loginPane.classList.add('sw-hide'); recoverPane.classList.add('sw-show'); history.replaceState(null,'','#recover'); }
  function showLogin(){ loginPane.classList.remove('sw-hide'); recoverPane.classList.remove('sw-show'); history.replaceState(null,'',location.pathname); }
  if (recoverLink) recoverLink.addEventListener('click', function(e){ e.preventDefault(); showRecover(); });
  if (backLink) backLink.addEventListener('click', function(e){ e.preventDefault(); showLogin(); });
  if (location.hash === '#recover' || location.hash === '#sw-recover') showRecover();
})();
</script>
