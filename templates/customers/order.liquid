{% layout 'theme' %}

<style>
.sw-ord-wrap{max-width:1000px;margin:2rem auto;padding:0 1.25rem;font-family:inherit}
.sw-ord-back{display:inline-flex;align-items:center;gap:.35rem;color:#0F6FE3;text-decoration:none;font-weight:600;font-size:.88rem;margin-bottom:1rem}
.sw-ord-back:hover{text-decoration:underline}
.sw-ord-head{background:linear-gradient(120deg,#061f40,#0a2d5e);color:#fff;border-radius:16px;padding:1.75rem 2rem;margin-bottom:1.5rem;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem}
.sw-ord-head h1{font-size:1.6rem;font-weight:900;margin:0 0 .25rem;letter-spacing:-.02em}
.sw-ord-head .meta{color:rgba(255,255,255,.7);font-size:.88rem;margin:0}
.sw-ord-status{display:flex;flex-direction:column;align-items:flex-end;gap:.35rem}
.sw-status{display:inline-block;padding:.3rem .7rem;border-radius:6px;font-size:.75rem;font-weight:700;letter-spacing:.03em}
.sw-status-paid{background:#dcfce7;color:#15803d}
.sw-status-pending{background:#fef3c7;color:#92400e}
.sw-status-refunded{background:#fee2e2;color:#991b1b}
.sw-status-default{background:rgba(255,255,255,.2);color:#fff}
.sw-ord-grid{display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start}
.sw-ord-card{background:#fff;border-radius:12px;border:1px solid #e8edf4;padding:1.5rem;margin-bottom:1.5rem}
.sw-ord-card h2{font-size:1.05rem;font-weight:800;color:#061f40;margin:0 0 1rem;letter-spacing:-.01em}
.sw-ord-items{width:100%;border-collapse:collapse}
.sw-ord-items th{text-align:left;padding:.6rem .5rem;font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:#94a3b8;font-weight:700;border-bottom:1px solid #e8edf4}
.sw-ord-items td{padding:.85rem .5rem;border-bottom:1px solid #f0f3f8;color:#1e293b;font-size:.9rem;vertical-align:top}
.sw-ord-items tr:last-child td{border-bottom:0}
.sw-ord-item-prod{display:flex;gap:.85rem;align-items:flex-start;min-width:200px}
.sw-ord-item-prod img{width:60px;height:60px;object-fit:cover;border-radius:6px;background:#f8fafc;flex-shrink:0}
.sw-ord-item-prod a{color:#061f40;font-weight:600;text-decoration:none;line-height:1.3;display:block}
.sw-ord-item-prod a:hover{color:#0F6FE3}
.sw-ord-item-prod .var{color:#94a3b8;font-size:.78rem;margin-top:.2rem}
.sw-ord-side{position:sticky;top:1rem}
.sw-ord-totals{display:flex;flex-direction:column;gap:.5rem}
.sw-ord-row{display:flex;justify-content:space-between;color:#475569;font-size:.9rem}
.sw-ord-row.total{padding-top:.75rem;margin-top:.5rem;border-top:1px solid #e8edf4;font-weight:800;color:#061f40;font-size:1.05rem}
.sw-ord-addr p{margin:0;color:#1e293b;font-size:.88rem;line-height:1.55}
@media(max-width:768px){.sw-ord-grid{grid-template-columns:1fr}.sw-ord-side{position:static}.sw-ord-item-prod img{width:48px;height:48px}}
</style>

<div class="sw-ord-wrap">
  <a href="{{ routes.account_url }}" class="sw-ord-back">&larr; Terug naar account</a>

  <div class="sw-ord-head">
    <div>
      <h1>Bestelling {{ order.name }}</h1>
      <p class="meta">Geplaatst op {{ order.created_at | date: '%d %B %Y om %H:%M' }}</p>
    </div>
    <div class="sw-ord-status">
      <span class="sw-status sw-status-{%- case order.financial_status -%}{%- when 'paid' -%}paid{%- when 'pending' -%}pending{%- when 'refunded' -%}refunded{%- else -%}default{%- endcase -%}">{{ order.financial_status_label }}</span>
      {%- if order.fulfillment_status_label != blank -%}
        <span class="sw-status sw-status-default">{{ order.fulfillment_status_label }}</span>
      {%- endif -%}
    </div>
  </div>

  <div class="sw-ord-grid">
    <div>
      <div class="sw-ord-card">
        <h2>Producten</h2>
        <table class="sw-ord-items">
          <thead>
            <tr>
              <th>Product</th>
              <th>Aantal</th>
              <th style="text-align:right">Prijs</th>
            </tr>
          </thead>
          <tbody>
            {%- for line_item in order.line_items -%}
              <tr>
                <td>
                  <div class="sw-ord-item-prod">
                    {%- if line_item.image -%}
                      <img src="{{ line_item.image | image_url: width: 120 }}" alt="{{ line_item.title | escape }}">
                    {%- endif -%}
                    <div>
                      <a href="{{ line_item.url }}">{{ line_item.title }}</a>
                      {%- if line_item.variant_title and line_item.variant_title != 'Default Title' -%}
                        <div class="var">{{ line_item.variant_title }}</div>
                      {%- endif -%}
                    </div>
                  </div>
                </td>
                <td>{{ line_item.quantity }}</td>
                <td style="text-align:right"><strong>{{ line_item.final_line_price | money }}</strong></td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>

      {%- if order.shipping_address -%}
        <div class="sw-ord-card">
          <h2>Verzendadres</h2>
          <div class="sw-ord-addr">
            <p>
              <strong>{{ order.shipping_address.first_name }} {{ order.shipping_address.last_name }}</strong><br>
              {%- if order.shipping_address.company != blank %}{{ order.shipping_address.company }}<br>{%- endif -%}
              {{ order.shipping_address.address1 }}{% if order.shipping_address.address2 != blank %}, {{ order.shipping_address.address2 }}{% endif %}<br>
              {{ order.shipping_address.zip }} {{ order.shipping_address.city }}<br>
              {{ order.shipping_address.country }}
            </p>
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="sw-ord-side">
      <div class="sw-ord-card">
        <h2>Overzicht</h2>
        <div class="sw-ord-totals">
          <div class="sw-ord-row"><span>Subtotaal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
          {%- for discount in order.cart_level_discount_applications -%}
            <div class="sw-ord-row" style="color:#16a34a"><span>Korting ({{ discount.title }})</span><span>&minus;{{ discount.total_allocated_amount | money }}</span></div>
          {%- endfor -%}
          <div class="sw-ord-row"><span>Verzending</span><span>{{ order.shipping_price | money }}</span></div>
          {%- if order.tax_price > 0 -%}
            <div class="sw-ord-row"><span>BTW</span><span>{{ order.tax_price | money }}</span></div>
          {%- endif -%}
          <div class="sw-ord-row total"><span>Totaal</span><span>{{ order.total_price | money }}</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
